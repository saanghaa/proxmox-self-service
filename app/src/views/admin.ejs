var _syncStatusTimer = null;

function relativeTime(isoStr) {
    if (!isoStr) return IS_ENGLISH ? 'Never' : '없음';
    var diff = Math.floor((Date.now() - new Date(isoStr).getTime()) / 1000);
    if (diff < 60) return IS_ENGLISH ? diff + 's ago' : diff + '초 전';
    if (diff < 3600) return IS_ENGLISH ? Math.floor(diff/60) + 'm ago' : Math.floor(diff/60) + '분 전';
    if (diff < 86400) return IS_ENGLISH ? Math.floor(diff/3600) + 'h ago' : Math.floor(diff/3600) + '시간 전';
    return IS_ENGLISH ? Math.floor(diff/86400) + 'd ago' : Math.floor(diff/86400) + '일 전';
}

