async function loadBackupTab() {
    await Promise.all([loadBackupList(), loadBackupSchedule()]);
}

function escapeHtml(str) {
    return String(str)
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;');
}

function formatBytes(bytes) {
    if (bytes < 1024) return bytes + ' B';
    if (bytes < 1024 * 1024) return (bytes / 1024).toFixed(1) + ' KB';
    return (bytes / (1024 * 1024)).toFixed(1) + ' MB';
}

async function loadBackupList() {
    const tbody = document.getElementById('backupListBody');
    if (!tbody) return;
    tbody.innerHTML = '<tr><td colspan="4" class="empty-msg">' + (IS_ENGLISH ? 'Loading...' : '로딩 중...') + '</td></tr>';
    try {
        const res = await api('GET', '/backup/list');
        if (!res.ok || !res.backups) {
            tbody.innerHTML = '<tr><td colspan="4" class="empty-msg">' + (IS_ENGLISH ? 'Failed to load' : '로드 실패') + '</td></tr>';
            return;
        }
        if (res.backups.length === 0) {
            tbody.innerHTML = '<tr><td colspan="4" class="empty-msg">' + (IS_ENGLISH ? 'No backups found' : '백업 없음') + '</td></tr>';
            syncBackupCreateStatusWithList([]);
            return;
        }
        syncBackupCreateStatusWithList(res.backups);
        tbody.innerHTML = res.backups.map(function(b) {
            const dateStr = new Date(b.createdAt).toLocaleString();
            const fn = escapeHtml(b.filename);
            return '<tr>' +
                '<td class="backup-filename">' + fn + '</td>' +
                '<td>' + formatBytes(b.size) + '</td>' +
                '<td>' + dateStr + '</td>' +
                '<td class="backup-actions">' +
                    '<button class="btn btn-sm btn-secondary" onclick="downloadBackup(\'' + fn + '\')" title="' + (IS_ENGLISH ? 'Download' : '다운로드') + '">' +
                        '<i class="ti ti-download"></i>' +
                    '</button> ' +
                    '<button class="btn btn-sm btn-warning" onclick="openRestoreModal(\'' + fn + '\')" title="' + (IS_ENGLISH ? 'Restore' : '복구') + '">' +
                        '<i class="ti ti-database-import"></i>' +
                    '</button> ' +
                    '<button class="btn btn-sm btn-danger" onclick="deleteBackupFile(\'' + fn + '\')" title="' + (IS_ENGLISH ? 'Delete' : '삭제') + '">' +
                        '<i class="ti ti-trash"></i>' +
                    '</button>' +
                '</td>' +
            '</tr>';
        }).join('');
    } catch(e) {
        tbody.innerHTML = '<tr><td colspan="4" class="empty-msg">' + (IS_ENGLISH ? 'Error loading backups' : '오류 발생') + '</td></tr>';
    }
}

function syncBackupCreateStatusWithList(backups) {
    const statusEl = document.getElementById('backupCreateStatus');
    if (!statusEl) return;
    if (!statusEl.classList.contains('success')) return;
    const txt = (statusEl.textContent || '').trim();
    if (!txt) return;
    const filenames = Array.isArray(backups) ? backups.map(b => String(b.filename || '')) : [];
    const stillExists = filenames.some(name => name && txt.includes(name));
    if (!stillExists) {
        statusEl.textContent = '';
        statusEl.className = 'backup-status-msg';
    }
}

async function triggerCreateBackup() {
    const btn = document.getElementById('createBackupBtn');
    const status = document.getElementById('backupCreateStatus');
    btn.disabled = true;
    btn.textContent = IS_ENGLISH ? 'Creating...' : '생성 중...';
    status.textContent = '';
    status.className = 'backup-status-msg';
    try {
        const res = await api('POST', '/backup/create');
        if (res.ok) {
            status.textContent = (IS_ENGLISH ? 'Created: ' : '생성됨: ') + res.filename;
            status.className = 'backup-status-msg success';
            await loadBackupList();
        } else {
            status.textContent = (IS_ENGLISH ? 'Failed: ' : '실패: ') + (res.error || 'Unknown error');
            status.className = 'backup-status-msg error';
        }
    } catch(e) {
        status.textContent = IS_ENGLISH ? 'Error creating backup' : '백업 생성 오류';
        status.className = 'backup-status-msg error';
    } finally {
        btn.disabled = false;
        btn.innerHTML = '<i class="ti ti-database-export"></i> ' + (IS_ENGLISH ? 'Create Backup' : '백업 생성');
    }
}

async function downloadBackup(filename) {
    try {
        const url = '/api/admin/backup/' + encodeURIComponent(filename) + '/download';
        const res = await fetch(url, { method: 'GET' });
        if (!res.ok) {
            throw new Error(IS_ENGLISH ? 'Download failed' : '다운로드 실패');
        }

        const blob = await res.blob();
        const blobUrl = URL.createObjectURL(blob);
        const link = document.createElement('a');
        link.href = blobUrl;
        link.download = filename;
        document.body.appendChild(link);
        link.click();
        document.body.removeChild(link);
        URL.revokeObjectURL(blobUrl);
    } catch (e) {
        showAlert((IS_ENGLISH ? 'Backup download failed: ' : '백업 다운로드 실패: ') + (e.message || ''), 'error');
    }
}

