async function triggerRestore() {
    const fileInput = document.getElementById('restoreFileInput');
    const restoreType = document.getElementById('restoreType').value;
    const status = document.getElementById('restoreStatus');
    const setRestoreStatus = (msg, cssClass = 'backup-status-msg', hideAfter = 3000) => {
        status.textContent = msg;
        status.className = cssClass;
        if (hideAfter > 0) {
            setTimeout(() => {
                if (status.textContent === msg) {
                    status.textContent = '';
                    status.className = 'backup-status-msg';
                }
            }, hideAfter);
        }
    };

    if (!fileInput.files || fileInput.files.length === 0) {
        setRestoreStatus(IS_ENGLISH ? 'Please select a backup file' : '백업 파일을 선택하세요', 'backup-status-msg error', 2600);
        return;
    }

    const confirmMsg = restoreType === 'full'
        ? (IS_ENGLISH
            ? '⚠️ Full DB restore will DROP ALL DATA and restart the service.\n\nThis CANNOT be undone. Proceed?'
            : '⚠️ 전체 DB 복구 시 모든 데이터가 삭제되고 서비스가 재시작됩니다.\n\n되돌릴 수 없습니다. 진행하시겠습니까?')
        : (IS_ENGLISH
            ? 'Restore system config from this backup?'
            : '이 백업에서 시스템 설정을 복구하시겠습니까?');

    if (!await themedConfirm(
        confirmMsg,
        restoreType === 'full'
            ? (IS_ENGLISH ? 'Full DB Restore' : '전체 DB 복구')
            : (IS_ENGLISH ? 'Restore Config' : '설정 복구')
    )) return;

    setRestoreStatus(IS_ENGLISH ? 'Uploading and restoring...' : '업로드 및 복구 중...', 'backup-status-msg', 0);

    try {
        const formData = new FormData();
        formData.append('backup', fileInput.files[0]);
        formData.append('type', restoreType);

        const res = await fetch('/api/admin/backup/restore', {
            method: 'POST',
            body: formData,
        });
        const data = await res.json();

        if (data.ok) {
            setRestoreStatus(data.message || (IS_ENGLISH ? 'Restore successful' : '복구 완료'), 'backup-status-msg success', 3000);
            if (restoreType === 'full') {
                setTimeout(() => { window.location.reload(); }, 5000);
            }
        } else {
            setRestoreStatus((IS_ENGLISH ? 'Restore failed: ' : '복구 실패: ') + (data.error || ''), 'backup-status-msg error', 3200);
        }
    } catch(e) {
        setRestoreStatus(IS_ENGLISH ? 'Network error during restore' : '복구 중 네트워크 오류', 'backup-status-msg error', 3200);
    }
}

