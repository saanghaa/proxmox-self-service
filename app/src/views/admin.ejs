async function submitPveOtp() {
    var otp = (document.getElementById('pveOtpInput').value || '').trim();
    var errEl = document.getElementById('pveOtpError');
    var btn = document.getElementById('pveOtpSubmitBtn');
    if (!otp || otp.length < 6) {
        errEl.textContent = IS_ENGLISH ? 'Enter a 6-digit OTP code.' : '6자리 OTP 코드를 입력하세요.';
        return;
    }
    btn.disabled = true;
    btn.textContent = IS_ENGLISH ? 'Verifying...' : '인증 중...';
    errEl.textContent = '';
    try {
        const res = await apiDeploy('POST', '/nodes/' + _pveOtpNodeId + '/reveal-token', { otp });
        if (!res.ok) throw new Error(res.error || '조회 실패');
        // OTP 모달 닫고 토큰 표시 모달 새로 오픈
        closePveOtpModal();
        document.getElementById('pveTokenRevealTitle').textContent =
            (IS_ENGLISH ? 'View Token — ' : '토큰 보기 — ') + _pveOtpNodeName;
        document.getElementById('pveRevealWarning').textContent =
            IS_ENGLISH ? 'Sensitive info. Do not screenshot or share your screen.' : '민감 정보입니다. 스크린샷하거나 화면을 공유하지 마세요.';
        document.getElementById('pveRevealSecret').textContent = res.tokenSecret || '-';
        // 30초 카운트다운
        var secs = 30;
        function updateTimer() {
            document.getElementById('pveTimerLabel').textContent =
                IS_ENGLISH ? secs + 's — closes automatically. Do not share your screen.' : secs + '초 후 자동으로 닫힙니다. 화면을 공유하지 마세요.';
            document.getElementById('pveTimerFill').style.width = (secs / 30 * 100) + '%';
        }
        updateTimer();
        _pveCountdownTimer = setInterval(function() {
            secs--;
            if (secs <= 0) { clearInterval(_pveCountdownTimer); _pveCountdownTimer = null; closePveTokenRevealModal(); return; }
            updateTimer();
        }, 1000);
        document.getElementById('pveTokenRevealModal').classList.add('active');
    } catch (e) {
        var msg = e.message;
        if (msg === 'OTP_NOT_ENABLED') {
            msg = IS_ENGLISH ? 'OTP must be enabled before viewing token secrets.' : '토큰 시크릿 조회 전 OTP를 먼저 활성화해야 합니다.';
        } else if (msg === 'INVALID_OTP') {
            msg = IS_ENGLISH ? 'The OTP code is invalid.' : 'OTP 코드가 올바르지 않습니다.';
        }
        errEl.textContent = (IS_ENGLISH ? 'Failed: ' : '실패: ') + msg;
        btn.disabled = false;
        btn.textContent = IS_ENGLISH ? 'Verify' : '인증';
    }
}

function ptmCopy(spanId, btn) {
    var text = document.getElementById(spanId) ? document.getElementById(spanId).textContent : '';
    if (!text) return;
    function onCopied() {
        var orig = btn.textContent;
        btn.textContent = '✓';
        btn.style.color = '#22c55e';
        setTimeout(function() { btn.textContent = orig; btn.style.color = ''; }, 2000);
    }
    function fallback() {
        var ta = document.createElement('textarea');
        ta.value = text;
        ta.style.cssText = 'position:fixed;top:-9999px;left:-9999px;opacity:0';
        document.body.appendChild(ta);
        ta.focus(); ta.select();
        try { document.execCommand('copy'); onCopied(); } catch(e) {}
        document.body.removeChild(ta);
    }
    if (navigator.clipboard && window.isSecureContext) {
        navigator.clipboard.writeText(text).then(onCopied).catch(fallback);
    } else {
        fallback();
    }
}

