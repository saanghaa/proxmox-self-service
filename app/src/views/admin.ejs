        .stats-accordion-body { padding: 1.25rem; background: #fff; }
        .stats-accordion-body.collapsed { display: none; }
        @media (max-width: 900px) { .stats-grid { grid-template-columns: 1fr; } }
        /* PVE 노드 리소스 카드 */
        .pve-nodes-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
            gap: 1rem;
            align-items: start;
        }
        .pve-node-card {
            border: 1px solid #e2e8f0; border-radius: 8px; padding: 1.1rem 1.25rem; background: #fff;
            animation: pveCardFadeIn 0.8s ease both;
        }
        @keyframes pveCardFadeIn {
            from { opacity: 0; transform: translateY(-8px); }
            to   { opacity: 1; transform: translateY(0); }
        }
        .pve-node-card.offline { border-color: #fca5a5; background: #fff5f5; }
        .pve-node-card-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 0; cursor: pointer; user-select: none; }
        .pve-node-card-header:hover { opacity: 0.92; }
        .pve-node-card-body { margin-top: 0.85rem; }
        .pve-node-card-body.collapsed { display: none; }
        .pve-node-card-right { display: inline-flex; align-items: center; gap: 0.45rem; }
        .pve-node-card-toggle-icon { color: #64748b; font-size: 0.95rem; transition: transform 0.2s ease; }
        .pve-node-card-toggle-icon.collapsed { transform: rotate(-90deg); }
        .vm-inv-node-body.collapsed { display: none; }
        .vm-inv-node-toggle { color: #94a3b8; font-size: 0.95rem; transition: transform 0.2s ease; }
        .vm-inv-node-toggle.collapsed { transform: rotate(-90deg); }
        .pve-node-card-name { font-weight: 700; font-size: 0.95rem; color: #1e293b; display: flex; align-items: center; gap: 0.4rem; }
        .pve-node-dot { width: 8px; height: 8px; border-radius: 50%; flex-shrink: 0; }
        .pve-node-dot.online { background: #22c55e; }
        .pve-node-dot.offline { background: #ef4444; }
        .pve-node-uptime { font-size: 0.72rem; color: #94a3b8; }
        .pve-res-row { margin-bottom: 0.65rem; }
        .pve-res-label { display: flex; justify-content: space-between; font-size: 0.78rem; color: #64748b; margin-bottom: 0.2rem; }
        .pve-res-bar { height: 7px; border-radius: 4px; background: #e2e8f0; overflow: hidden; }
        .pve-res-bar-fill { height: 100%; border-radius: 4px; transition: width 0.4s ease; }
        .pve-res-bar-fill.cpu { background: var(--tpl-accent); }
        .pve-res-bar-fill.mem { background: #0ea5e9; }
        .pve-res-bar-fill.disk { background: #10b981; }
        .pve-res-bar-fill.high { background: #f59e0b; }
        .pve-res-bar-fill.critical { background: #ef4444; }
        .pve-res-divider { border: none; border-top: 1px dashed #e2e8f0; margin: 0.6rem 0 0.5rem; }
        .pve-res-sub-label { font-size: 0.72rem; font-weight: 600; color: #94a3b8; margin-bottom: 0.5rem; letter-spacing: 0.04em; }
        .pve-shared-section { margin-top: 1.25rem; }
        .pve-shared-section-title { font-size: 0.8rem; font-weight: 700; color: #475569; margin-bottom: 0.75rem; display: flex; align-items: center; gap: 0.4rem; }
        .pve-shared-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(240px, 1fr)); gap: 0.75rem; }
        .pve-storage-pool-card { border: 1px solid #e2e8f0; border-radius: 6px; padding: 0.75rem 1rem; background: #f8fafc; animation: pveCardFadeIn 0.35s ease both; }
        .pve-storage-pool-name { font-size: 0.82rem; font-weight: 600; color: #334155; margin-bottom: 0.15rem; }
        .pve-storage-pool-type { font-size: 0.7rem; color: #94a3b8; margin-bottom: 0.5rem; }

