<body class="theme-template-<%= locals.activeThemeTemplate || 'proxmox' %>">
<%
const menuIconClassMap = {
    DASHBOARD: 'ti ti-layout-dashboard',
    ADMIN_PANEL: 'ti ti-shield-lock',
    CHANGE_PASSWORD: 'ti ti-key',
    LOGOUT: 'ti ti-logout',
    VM_REQUESTS: 'ti ti-list-check',
    DELETED_VM_MANAGEMENT: 'ti ti-trash',
    USER_MANAGEMENT: 'ti ti-users',
    GROUP_MANAGEMENT: 'ti ti-users-group',
    GROUP_QUOTA: 'ti ti-chart-bar',
    NOTIFICATION_SETTINGS: 'ti ti-bell',
    PASSWORD_POLICY: 'ti ti-lock-password',
    AUDIT_LOGS: 'ti ti-file-text',
    MENU_SETTINGS: 'ti ti-settings',
    UI_SETTINGS: 'ti ti-palette',
    PROXMOX_CONNECTION: 'ti ti-server',
    BACKUP_MANAGEMENT: 'ti ti-database-export'
};
function getMenuIconClass(menuKey) {
    return menuIconClassMap[menuKey] || 'ti ti-circle';
}
function stripLeadingIconText(text) {
    return String(text || '').replace(/^[^A-Za-z0-9가-힣(\[]+/u, '').trim();
}
const themeOptions = locals.themeTemplateOptions || [];
const currentThemeTemplate = locals.activeThemeTemplate || 'proxmox';
const currentThemeOption = themeOptions.find(t => t.id === currentThemeTemplate) || themeOptions[0];
const adminTabEn = {
    VM_REQUESTS: 'VM Create Requests',
    DELETED_VM_MANAGEMENT: 'Deleted VMs',
    USER_MANAGEMENT: 'Users',
    GROUP_MANAGEMENT: 'Groups',
    GROUP_QUOTA: 'Group Quota',
    STATS: 'Statistics',
    STATISTICS: 'Statistics',
    NOTIFICATION_SETTINGS: 'Notifications',
    PASSWORD_POLICY: 'Password Policy',
    AUDIT_LOGS: 'Audit Logs',
    MENU_SETTINGS: 'Menu Settings',
    UI_SETTINGS: 'UI Text Settings',
    PROXMOX_CONNECTION: 'Proxmox Connection',
    BACKUP_MANAGEMENT: 'Backup & Restore',
    SETTINGS_HUB: 'Settings'
};
function adminLabel(menuKey, displayName, fallbackEn) {
    const raw = stripLeadingIconText(displayName);
    if (isEnglish && /[가-힣]/.test(raw)) return adminTabEn[menuKey] || fallbackEn || raw;
    return raw;
}

// Guard against UI label misconfiguration leaking the wrong language.
function localeText(raw, fallbackKo, fallbackEn) {
    const v = stripLeadingIconText(raw);
    if (isEnglish) {
        if (!v || /[가-힣]/.test(v)) return fallbackEn || v || '';
        return v;
    }
    if (!v) return fallbackKo || v || '';
    // KO mode: if it looks like English-only text, fall back to Korean.
    if (!/[가-힣]/.test(v) && /[A-Za-z]/.test(v)) return fallbackKo || v;
    return v;
}
%>

<div class="header">
    <h1 class="header-brand">
        <img src="<%= adminLogoSrc %>" alt="<%= adminLogoAlt %>">
        <span>Horizon</span>
    </h1>
    <div class="header-right">
        <span><%= user.email %></span>
        <% if (headerMenus && headerMenus.length > 0) { %>
            <% headerMenus.forEach(function(menu) { %>
                <% if (menu.menu_key === 'CHANGE_PASSWORD') { return; } %>
                <a href="<%= menu.path %>"
                   class="<%= menu.css_class || '' %>"
                   data-menu-uuid="<%= menu.uuid %>"
                   data-menu-key="<%= menu.menu_key %>">
                    <i class="menu-icon <%= getMenuIconClass(menu.menu_key) %>" aria-hidden="true"></i><%= stripLeadingIconText(menu.display_name) %>
                </a>
            <% }); %>
        <% } else { %>
            <!-- Fallback: 기본 메뉴 -->
            <a href="/" class="btn-dashboard"><i class="menu-icon ti ti-layout-dashboard" aria-hidden="true"></i><%= isEnglish ? 'Dashboard' : '대시보드' %></a>
            <a href="/auth/logout"><i class="menu-icon ti ti-logout" aria-hidden="true"></i><%= isEnglish ? 'Logout' : '로그아웃' %></a>
        <% } %>
        <!-- Personal settings menu -->
        <div class="personal-menu" id="personalMenu">
            <button type="button"
                    class="personal-button"
                    id="personalButton"
