async function createUser() {
    const email = document.getElementById('newUserEmail').value.trim();
    const password = document.getElementById('newUserPassword').value;
    const groupId = document.getElementById('newUserGroup').value || undefined;
    const isAdmin = document.getElementById('newUserAdmin').checked;

    if (!email || !password) { showAlert(IS_ENGLISH ? 'Email and password are required' : '이메일과 비밀번호는 필수입니다', 'error'); return; }

    try {
        await api('POST', '/users', { email, password, isAdmin, groupId });
        closeAllModals();
        showAlert((IS_ENGLISH ? 'User created: ' : '사용자 생성 완료: ') + email, 'success');
        loadUsers();
    } catch (e) { showAlert((IS_ENGLISH ? 'Failed: ' : '실패: ') + e.message, 'error'); }
}

