<script src="/vendor/flatpickr/flatpickr.min.js"></script>
<script src="/vendor/flatpickr/plugins/confirmDate/confirmDate.js"></script>
<script>
// Must be defined before any synchronous initializer touches it.
// Using `var` avoids TDZ crashes like: "Cannot access 'IS_ENGLISH' before initialization".
var IS_ENGLISH = <%= isEnglish ? 'true' : 'false' %>;

// === State ===
const currentUserEmail = '<%= user.email %>';
const DEFAULT_ADMIN_EMAIL = '<%= initialAdminEmail %>';
let allUsers = [];
let allGroups = [];
let allVms = [];
let proxmoxNodes = [];
let auditPage = 1;
let userSortField = null;
let userSortDirection = null; // 'asc' or 'desc'
let vmreqBridgeMeta = {};
let editingPveNodeId = null;
let auditFilters = {
    from: '',
    to: '',
    user: '',
    action: '',
    result: '',
    ip: '',
};
const DNS_PRESETS = {
    google: { primary: '8.8.8.8', secondary: '8.8.4.4' },
    skt: { primary: '219.250.36.130', secondary: '210.220.163.82' },
    kt: { primary: '168.126.63.1', secondary: '168.126.63.2' },
    lg: { primary: '164.124.101.2', secondary: '203.248.252.2' },
    custom: { primary: '', secondary: '' },
};

// Section labels from server (for dynamic button text and headers)
const sectionLabels = <%- JSON.stringify(sectionLabels || {}) %>;

// UUID-based labels for UI elements (modals, forms, messages, etc.)
const uuidLabels = <%- JSON.stringify(uuidLabels || {}) %>;

// === Helper Functions for UUID-based Lookups ===
/**
 * Get button label by button_key from section labels
 * @param {string} section - Section name (e.g., 'user_management')
 * @param {string} buttonKey - Button key (e.g., 'PW_RESET')
 * @param {string} fallback - Fallback text if not found
 * @returns {string} Button display name
 */
function getButtonLabel(section, buttonKey, fallback) {
    const buttons = sectionLabels?.admin?.[section]?.buttons || [];
    const button = buttons.find(b => b.button_key === buttonKey && b.is_visible);
    return button?.display_name || fallback;
}

/**
 * Get header label by header_key from section labels
 * @param {string} section - Section name (e.g., 'user_management')
 * @param {string} headerKey - Header key (e.g., 'EMAIL')
 * @param {string} fallback - Fallback text if not found
 * @returns {string} Header display name
 */
function getHeaderLabel(section, headerKey, fallback) {
    const headers = sectionLabels?.admin?.[section]?.table_headers || [];
    const header = headers.find(h => h.header_key === headerKey && h.is_visible);
    return header?.display_name || fallback;
}

/**
 * Get section title
 * @param {string} section - Section name (e.g., 'user_management')
 * @param {string} fallback - Fallback title if not found
 * @returns {string} Section title
 */
function getSectionTitle(section, fallback) {
    return sectionLabels?.admin?.[section]?.title || fallback;
}

// === Tab switching (UUID-based) ===
// 하드코딩 제거! 이제 tab_id를 JSON에서 직접 가져와서 사용합니다.

// MENU_KEY to load function mapping
const MENU_KEY_TO_LOADER = {
    'USER_MANAGEMENT': loadUsers,
    'GROUP_MANAGEMENT': loadGroups,
    'GROUP_QUOTA': loadQuotaManagement,
    'VM_MANAGEMENT': loadVms,
    'DELETED_VM_MANAGEMENT': loadVms,
    'VM_REQUESTS': loadVmRequests,
    'NOTIFICATION_SETTINGS': loadNotifications,
    'PASSWORD_POLICY': () => { loadPasswordPolicy(); loadSessionPolicy(); loadKeyRotatePolicy(); loadAutoRotatePolicy(); },
    'AUDIT_LOGS': () => loadAuditLogs(1),
    'MENU_SETTINGS': loadMenuSettings,
    'UI_SETTINGS': loadUISettings,
    'PROXMOX_CONNECTION': function() { loadProxmoxNodes(); startSyncStatusPoller(); },
    'BACKUP_MANAGEMENT': loadBackupTab,
    'STATISTICS': loadStats
};
const SETTINGS_MENU_KEYS = ['NOTIFICATION_SETTINGS', 'PASSWORD_POLICY', 'MENU_SETTINGS', 'UI_SETTINGS', 'PROXMOX_CONNECTION', 'BACKUP_MANAGEMENT'];

function isSettingsMenuKey(menuKey) {
    return SETTINGS_MENU_KEYS.includes(menuKey);
}

function toggleSettingsSubTabs(visible) {
    const el = document.getElementById('settingsSubTabs');
    if (!el) return;
    el.classList.toggle('active', !!visible);
}

function setActiveSettingsSubTab(menuKey, selectedElement) {
    document.querySelectorAll('.settings-subtab').forEach(btn => btn.classList.remove('active'));
    if (selectedElement) {
        selectedElement.classList.add('active');
        return;
    }
    const match = document.querySelector('.settings-subtab[data-menu-key="' + menuKey + '"]');
    if (match) match.classList.add('active');
}

function switchSettingsSubTab(uuid, tabId, menuKey, selectedElement) {
    // 모든 탭/콘텐츠 비활성화
    document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
    document.querySelectorAll('.tab-content').forEach(t => t.classList.remove('active'));

    // 상단 "설정" 탭 활성화
    const hubTab = document.getElementById('tab-settings-hub-btn');
    if (hubTab) hubTab.classList.add('active');

    // 서브탭/콘텐츠 활성화
    toggleSettingsSubTabs(true);
    setActiveSettingsSubTab(menuKey, selectedElement);

    const contentElement = document.getElementById(tabId);
    if (contentElement) {
        contentElement.classList.add('active');
    } else {
        console.error('[switchSettingsSubTab] Tab content not found:', tabId);
    }

    // 데이터 로더 실행
    const loaderFunc = MENU_KEY_TO_LOADER[menuKey];
    if (loaderFunc) loaderFunc();
}

function openSettingsHub(preferredMenuKey) {
    const allSubTabs = Array.from(document.querySelectorAll('.settings-subtab'));
    if (allSubTabs.length === 0) return;

    let target = null;
    if (preferredMenuKey) {
        target = allSubTabs.find(btn => btn.dataset.menuKey === preferredMenuKey) || null;
    }
    if (!target) target = allSubTabs[0];

    switchSettingsSubTab(target.dataset.tabUuid, target.dataset.tabId, target.dataset.menuKey, target);
}

/**
 * UUID 기반 탭 전환
 * @param {string} uuid - 탭의 고유 UUID
 * @param {string} tabId - 탭 콘텐츠 ID (예: "tab-users")
 * @param {string} menuKey - 메뉴 키 (USER_MANAGEMENT, GROUP_MANAGEMENT 등)
 */
function switchTab(uuid, tabId, menuKey) {
    if (isSettingsMenuKey(menuKey)) {
        openSettingsHub(menuKey);
        return;
    }

    // tabId를 직접 사용 (하드코딩 없음!)
    if (!tabId) {
        console.error(`[switchTab] Missing tab_id for UUID: ${uuid}`);
        return;
    }

    // 모든 탭과 콘텐츠 비활성화
    document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
    document.querySelectorAll('.tab-content').forEach(t => t.classList.remove('active'));

    // 선택된 탭 활성화 (UUID로 찾기)
    const selectedTab = document.querySelector(`.tab[data-tab-uuid="${uuid}"]`);
    if (selectedTab) {
        selectedTab.classList.add('active');
    }

    // 해당 콘텐츠 활성화 (tab_id 직접 사용)
    const contentElement = document.getElementById(tabId);
    if (contentElement) {
        contentElement.classList.add('active');
        toggleSettingsSubTabs(false);
    } else {
        console.error(`[switchTab] Tab content not found: ${tabId}`);
    }

    // 다른 탭으로 전환 시 동기화 상태 poller 중지
    if (menuKey !== 'PROXMOX_CONNECTION') stopSyncStatusPoller();
    // VM 요청 탭을 벗어나면 배포 폴러 중지
    if (menuKey !== 'VM_REQUESTS' && _vmReqDeployPoller) {
        clearInterval(_vmReqDeployPoller);
        _vmReqDeployPoller = null;
    }

    // 데이터 로드 함수 실행
    const loaderFunc = MENU_KEY_TO_LOADER[menuKey];
    if (loaderFunc) {
        loaderFunc();
    }
}

/**
 * 레거시 탭 전환 (Fallback용)
 * 기존 코드와의 호환성 유지
 */
function switchTabLegacy(name) {
    if (name === 'settings') {
        openSettingsHub();
        return;
    }

    const legacyTabIdMap = {
        'vm-requests': 'tab-vm-requests',
        'users': 'tab-users',
        'groups': 'tab-groups',
        'vms': 'tab-vms',
        'audit': 'tab-audit'
    };
    const targetTabId = legacyTabIdMap[name];
    if (!targetTabId) return;

    document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
    document.querySelectorAll('.tab-content').forEach(t => t.classList.remove('active'));
    toggleSettingsSubTabs(false);

    const tabEl = document.querySelector('.tab[data-legacy="' + name + '"]');
    if (tabEl) tabEl.classList.add('active');
    const contentEl = document.getElementById(targetTabId);
    if (contentEl) contentEl.classList.add('active');

    if (name === 'vm-requests') loadVmRequests();
    if (name === 'users') loadUsers();
    if (name === 'groups') loadGroups();
    if (name === 'vms') loadVms();
    if (name === 'audit') loadAuditLogs(1);
}

// === Toast ===
const _arToastIcons = { success: 'ti-circle-check', error: 'ti-circle-x', warning: 'ti-alert-triangle', info: 'ti-info-circle' };
const _arToastTitles = {
    success: IS_ENGLISH ? 'Success' : '완료',
    error:   IS_ENGLISH ? 'Error'   : '오류',
    warning: IS_ENGLISH ? 'Warning' : '경고',
    info:    IS_ENGLISH ? 'Info'    : '안내',
};
function showArToast(msg, type = 'info', duration = 5000, options = {}) {
    const container = document.getElementById('ar-toast-container');
    if (!container) return;
    const toast = document.createElement('div');
    toast.className = `ar-toast ${type}${options && options.emphasis ? ' emphasis' : ''}`;
    toast.innerHTML = `
        <i class="ti ${_arToastIcons[type] || 'ti-info-circle'} ar-toast-icon"></i>
        <div class="ar-toast-body">
            <div class="ar-toast-title">${_arToastTitles[type] || ''}</div>
            <div class="ar-toast-msg">${msg}</div>
        </div>`;
    container.appendChild(toast);
    const remove = () => {
        toast.classList.add('hiding');
        toast.addEventListener('animationend', () => toast.remove(), { once: true });
    };
    const timer = setTimeout(remove, duration);
    toast.addEventListener('click', () => { clearTimeout(timer); remove(); });
}

// === Alert ===
function showAlert(msg, type) {
    const toastType = type === 'success' ? 'success' : type === 'error' ? 'error' : type === 'warning' ? 'warning' : 'info';
    showArToast(msg, toastType, 4000);
}

function showInlineSaveMsg(elementId, message, type = 'success', hideAfter = 3000) {
    const el = document.getElementById(elementId);
    if (!el) {
        showAlert(message, type === 'error' ? 'error' : 'success');
        return;
    }
    el.className = 'inline-save-msg ' + (type === 'error' ? 'error' : 'success');
    el.textContent = message;
    if (hideAfter > 0) {
        setTimeout(() => {
            if (el.textContent === message) el.textContent = '';
        }, hideAfter);
    }
}

let _themeConfirmResolver = null;
function closeThemeConfirm(result) {
    const modal = document.getElementById('themeConfirmModal');
    if (modal) modal.classList.remove('active');
    if (_themeConfirmResolver) {
        const resolve = _themeConfirmResolver;
        _themeConfirmResolver = null;
        resolve(!!result);
    }
}
function themedConfirm(message, title) {
    const modal = document.getElementById('themeConfirmModal');
    const titleEl = document.getElementById('themeConfirmTitle');
    const msgEl = document.getElementById('themeConfirmMessage');
    const okBtn = document.getElementById('themeConfirmOkBtn');
    const cancelBtn = document.getElementById('themeConfirmCancelBtn');
    if (!modal || !titleEl || !msgEl || !okBtn || !cancelBtn) return Promise.resolve(confirm(message));

    titleEl.textContent = title || (IS_ENGLISH ? 'Confirm' : '확인');
    msgEl.textContent = message || '';
    okBtn.textContent = IS_ENGLISH ? 'Confirm' : '확인';
    cancelBtn.textContent = IS_ENGLISH ? 'Cancel' : '취소';
    modal.classList.add('active');

    return new Promise(resolve => {
        _themeConfirmResolver = resolve;
    });
}

document.addEventListener('click', function(e) {
    const modal = document.getElementById('themeConfirmModal');
    if (!modal || !modal.classList.contains('active')) return;
    if (e.target === modal) closeThemeConfirm(false);
});
document.addEventListener('keydown', function(e) {
    const modal = document.getElementById('themeConfirmModal');
    if (!modal || !modal.classList.contains('active')) return;
    if (e.key === 'Escape') closeThemeConfirm(false);
});

// === API helper ===
async function api(method, path, body) {
    const opts = {
        method,
        headers: { 'Content-Type': 'application/json' },
        cache: 'no-store'
    };
    if (body) opts.body = JSON.stringify(body);
    const r = await fetch('/api/admin' + path, opts);

    // Session/OTP might be lost after redeploy (Redis reset). Avoid infinite "Loading..." UIs.
    if (r.status === 401) {
        window.location.href = '/auth/login?returnUrl=' + encodeURIComponent(location.pathname + location.search);
        throw new Error('UNAUTHORIZED');
    }
    if (r.status === 403) {
        window.location.href = '/';
        throw new Error('FORBIDDEN');
    }

    const data = await r.json();
    if (!r.ok) throw new Error(data.error || 'Request failed');
    return data;
}

async function apiDeploy(method, path, body) {
    const opts = {
        method,
        headers: { 'Content-Type': 'application/json' },
        cache: 'no-store'
    };
    if (body) opts.body = JSON.stringify(body);
    const r = await fetch('/api/deploy' + path, opts);

    if (r.status === 401) {
        window.location.href = '/auth/login?returnUrl=' + encodeURIComponent(location.pathname + location.search);
        throw new Error('UNAUTHORIZED');
    }
    if (r.status === 403) {
        window.location.href = '/';
        throw new Error('FORBIDDEN');
    }

    const data = await r.json();
    if (!r.ok) throw new Error(data.error || 'Request failed');
    return data;
}

// === USERS ===
async function loadUsers() {
    try {
        const data = await api('GET', '/users');
        allUsers = data.users;
        renderUsers();
    } catch (e) { showAlert((IS_ENGLISH ? 'Failed to load users: ' : '사용자 목록을 불러오지 못했습니다: ') + e.message, 'error'); }
}

function renderUsers() {
    const tbody = document.getElementById('usersBody');
    if (allUsers.length === 0) {
        tbody.innerHTML = '<tr><td colspan="7" class="loading-center">' + (IS_ENGLISH ? 'No users found' : '사용자가 없습니다') + '</td></tr>';
        return;
    }
		    tbody.innerHTML = allUsers.map(u => {
		        const groups = u.memberships.map(m => '<span class="badge badge-blue">' + m.group.name + '</span>').join(' ');
		        const statusBadge = u.isActive
                    ? '<span class="badge badge-green">' + (IS_ENGLISH ? 'Active' : '활성') + '</span>'
                    : '<span class="badge badge-red">' + (IS_ENGLISH ? 'Inactive' : '비활성') + '</span>';
		        // Keep role names as "Admin/Member" in both languages (product terminology).
		        const adminBadge = u.isAdmin
                    ? '<span class="badge badge-role-admin">Admin</span>'
                    : '<span class="badge badge-role-member">Member</span>';
		        const otpBadge = u.totpEnabled
                    ? '<span class="badge badge-green">' + (IS_ENGLISH ? 'Enabled' : '활성') + '</span>'
                    : '<span class="badge badge-gray">' + (IS_ENGLISH ? 'Off' : '꺼짐') + '</span>';
		        const created = u.createdAt ? u.createdAt.split('T')[0] : '-';

        // UUID 방식: 버튼 레이블을 동적으로 가져옴
        const btnDeactivate = getButtonLabel('user_management', 'DEACTIVATE', 'Deactivate');
        const btnActivate = getButtonLabel('user_management', 'ACTIVATE', 'Activate');
	        const btnDelete = getButtonLabel('user_management', 'DELETE', 'Delete');
	        const btnChangeGroup = getButtonLabel('user_management', 'CHANGE_GROUP', 'Change');
	        const btnPwReset = getButtonLabel('user_management', 'PW_RESET', 'PW Reset');
	        const btnOtpReset = getButtonLabel('user_management', 'OTP_RESET', 'OTP Reset');

	        // 디폴트 관리자 여부
	        const isDefaultAdmin = (u.email === DEFAULT_ADMIN_EMAIL);

        // 활성화/비활성화/삭제 버튼 (디폴트 관리자는 숨김)
        let actionBtn = '';
        if (isDefaultAdmin) {
            actionBtn = '';
        } else if (u.isActive) {
            actionBtn = '<button class="btn btn-warning btn-sm" onclick="deactivateUser(\'' + u.id + '\', \'' + u.email + '\')">' + btnDeactivate + '</button>';
        } else {
            actionBtn = '<button class="btn btn-primary btn-sm" onclick="activateUser(\'' + u.id + '\', \'' + u.email + '\')">' + btnActivate + '</button>' +
                        '<button class="btn btn-danger btn-sm" onclick="deleteUser(\'' + u.id + '\', \'' + u.email + '\')">' + btnDelete + '</button>';
        }

	        // 관리자 권한 토글 (알림 설정 토글과 동일한 UI: 상태 텍스트 + 토글)
	        const adminToggleWrap = (u.email === currentUserEmail || isDefaultAdmin)
	            ? adminBadge
	            : (
	                '<div class="seg-toggle" role="group" aria-label="' + (IS_ENGLISH ? 'Admin role' : '관리자 권한') + '"' +
	                    ' data-user-id="' + u.id + '"' +
	                    ' data-user-email="' + u.email + '"' +
	                    ' data-current-admin="' + (u.isAdmin ? '1' : '0') + '">' +
	                    '<button type="button" class="seg-option ' + (u.isAdmin ? 'active' : '') + '" onclick="setAdminRole(this, true)">Admin</button>' +
	                    '<button type="button" class="seg-option ' + (!u.isAdmin ? 'active' : '') + '" onclick="setAdminRole(this, false)">Member</button>' +
	                '</div>'
	            );

	        return '<tr>' +
	            '<td>' + u.email + '</td>' +
	            '<td>' + statusBadge + '</td>' +
	            '<td>' + adminToggleWrap + '</td>' +
	            '<td>' + otpBadge + '</td>' +
	            '<td>' + (groups || '<span class="text-muted">-</span>') + '</td>' +
	            '<td>' + created + '</td>' +
	            '<td class="manage-cell"><div class="btn-group">' +
	                '<button class="btn btn-warning btn-sm" onclick="openResetPwModal(\'' + u.id + '\')">' + btnPwReset + '</button>' +
	                '<button class="btn btn-warning btn-sm" onclick="resetOtp(\'' + u.id + '\')">' + btnOtpReset + '</button>' +
	                actionBtn +
	            '</div></td></tr>';
	    }).join('');

    // Update sort indicators
    updateSortIndicators();
}

function updateSortIndicators() {
    document.querySelectorAll('#usersTableWrap th.sortable').forEach(th => {
        th.classList.remove('asc', 'desc');
        if (th.dataset.field === userSortField) {
            th.classList.add(userSortDirection);
        }
    });
}

function sortUsers(field) {
    // Toggle sort direction
    if (userSortField === field) {
        if (userSortDirection === 'asc') {
            userSortDirection = 'desc';
        } else if (userSortDirection === 'desc') {
            // Reset to default (no sort)
            userSortField = null;
            userSortDirection = null;
            loadUsers(); // Reload original order
            return;
        }
    } else {
        userSortField = field;
        userSortDirection = 'asc';
    }

    // Sort the array
    allUsers.sort((a, b) => {
        let valA, valB;

        if (field === 'email') {
            valA = a.email.toLowerCase();
            valB = b.email.toLowerCase();
        } else if (field === 'isActive' || field === 'isAdmin' || field === 'totpEnabled') {
            valA = a[field] ? 1 : 0;
            valB = b[field] ? 1 : 0;
        } else if (field === 'groups') {
            valA = a.memberships.length;
            valB = b.memberships.length;
        } else if (field === 'createdAt') {
            valA = new Date(a.createdAt);
            valB = new Date(b.createdAt);
        }

        if (valA < valB) return userSortDirection === 'asc' ? -1 : 1;
        if (valA > valB) return userSortDirection === 'asc' ? 1 : -1;
        return 0;
    });

    renderUsers();
}

function initUserTableSort() {
    document.querySelectorAll('#usersTableWrap th.sortable').forEach(th => {
        th.addEventListener('click', () => sortUsers(th.dataset.field));
    });
}

