function renderGroups() {
    const container = document.getElementById('groupsContainer');
    if (allGroups.length === 0) {
        container.innerHTML = '<p class="loading-center">' + (IS_ENGLISH ? 'No groups found' : '그룹이 없습니다') + '</p>';
        return;
    }
    container.innerHTML = allGroups.map(t => {
        const members = t.members.map(m =>
            '<span class="member-chip">' + m.user.email +
            '<span class="remove" onclick="removeMember(\'' + t.id + '\', \'' + m.user.id + '\')">&times;</span></span>'
        ).join('');

        const deleteBtn = '<button class="btn btn-danger btn-sm ml-05" onclick="deleteGroup(\'' + t.id + '\', \'' + t.name + '\')">' + (IS_ENGLISH ? 'Delete' : '삭제') + '</button>';

        return '<div class="group-card">' +
            '<div class="group-header">' +
                '<strong>' + t.name + '</strong>' +
                '<div class="group-stats">' +
                    '<span class="badge badge-gray">' + t.members.length + ' ' + (IS_ENGLISH ? 'members' : '명') + '</span>' +
                    '<span class="badge badge-gray">' + t._count.jobs + ' ' + (IS_ENGLISH ? 'jobs' : 'jobs') + '</span>' +
                    '<span class="badge badge-gray">' + t._count.vms + ' ' + (IS_ENGLISH ? 'VMs' : 'VM') + '</span>' +
                    '<button class="btn btn-primary btn-sm" onclick="openAddMemberModal(\'' + t.id + '\')">+ ' + (IS_ENGLISH ? 'Member' : '멤버') + '</button>' +
                    '<button class="btn btn-warning btn-sm ml-05" onclick="openEditGroupModal(\'' + t.id + '\', \'' + t.name + '\')">' + (IS_ENGLISH ? 'Edit' : '수정') + '</button>' +
                    deleteBtn +
                '</div>' +
            '</div>' +
            '<div class="member-list">' + (members || '<span class="text-muted-sm">' + (IS_ENGLISH ? 'No members' : '멤버 없음') + '</span>') + '</div>' +
        '</div>';
    }).join('');
}

