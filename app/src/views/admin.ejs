function scheduleAutoDiscoverPveName() {
    if (editingPveNodeId) return;
    if (_pveNameDiscoverTimer) clearTimeout(_pveNameDiscoverTimer);
    _pveNameDiscoverTimer = setTimeout(autoDiscoverPveName, 250);
}

async function autoDiscoverPveName() {
    if (editingPveNodeId) return;

    const host = normalizePveHostInput((document.getElementById('pve-host')?.value || '').trim());
    const tokenId = (document.getElementById('pve-token-id')?.value || '').trim();
    const tokenSecret = (document.getElementById('pve-token-secret')?.value || '').trim();
    const nameInput = document.getElementById('pve-name');

    if (!host || !tokenId || !tokenSecret) return;

    const discoveryKey = [host, tokenId, tokenSecret].join('|');
    if (_lastPveDiscoveryKey === discoveryKey && nameInput && String(nameInput.value || '').trim()) return;

    try {
        const res = await apiDeploy('POST', '/nodes/fetch-name', { host, tokenId, tokenSecret });
        if (!res.ok) throw new Error(res.error || 'DISCOVERY_FAILED');
        const hostInput = document.getElementById('pve-host');
        if (hostInput) hostInput.value = host;
        if (nameInput) nameInput.value = res.name || '';
        _lastPveDiscoveryKey = discoveryKey;
    } catch (_e) {
        _lastPveDiscoveryKey = '';
    }
}

async function createProxmoxNode() {
    const name = (document.getElementById('pve-name')?.value || '').trim();
    const host = normalizePveHostInput((document.getElementById('pve-host')?.value || '').trim());
    const tokenId = (document.getElementById('pve-token-id')?.value || '').trim();
    const tokenSecret = (document.getElementById('pve-token-secret')?.value || '').trim();

    if (!host || !tokenId || (!editingPveNodeId && !tokenSecret) || (editingPveNodeId && !name)) {
        setProxmoxResult(
            IS_ENGLISH
                ? (editingPveNodeId ? 'Enter name/host/token ID.' : 'Enter host/token information first.')
                : (editingPveNodeId ? '이름/호스트/토큰ID를 입력하세요.' : '호스트/토큰 정보를 먼저 입력하세요.'),
            true
        );
        return;
    }

    try {
        const hostInput = document.getElementById('pve-host');
        if (hostInput) hostInput.value = host;

        if (!editingPveNodeId && !name) {
            await autoDiscoverPveName();
        }

        const resolvedName = (document.getElementById('pve-name')?.value || '').trim();

        const method = editingPveNodeId ? 'PUT' : 'POST';
        const path = editingPveNodeId ? '/nodes/' + editingPveNodeId : '/nodes';
        const payload = editingPveNodeId
            ? { name: resolvedName, host, tokenId, tokenSecret: tokenSecret || undefined }
            : { name: resolvedName || undefined, host, tokenId, tokenSecret };
        const res = await apiDeploy(method, path, payload);
        if (res.connectionTest && res.connectionTest !== 'SUCCESS') {
            setProxmoxResult(
                (IS_ENGLISH
                    ? (editingPveNodeId ? 'Node updated, but connection test failed: ' : 'Node created, but connection test failed: ')
                    : (editingPveNodeId ? '노드는 수정되었지만 연결 확인에 실패했습니다: ' : '노드는 등록되었지만 연결 확인에 실패했습니다: ')) + res.connectionTest,
                true
            );
        } else {
            var clusterMessage = '';
            if (!editingPveNodeId && res.clusterSync && typeof res.clusterSync.added === 'number') {
                clusterMessage = IS_ENGLISH
                    ? ' Primary node "' + (res.node?.name || resolvedName || '-') + '" registered, plus ' + res.clusterSync.added + ' additional cluster node(s).'
                    : ' 기준 노드 "' + (res.node?.name || resolvedName || '-') + '" 등록 후 클러스터 노드 ' + res.clusterSync.added + '개를 추가 등록했습니다.';
                if (res.clusterSync.errors && res.clusterSync.errors.length) {
                    clusterMessage += IS_ENGLISH
                        ? ' Some nodes could not be added automatically.'
                        : ' 일부 노드는 자동 등록에 실패했습니다.';
                }
            }
            setProxmoxResult(
                IS_ENGLISH
                    ? (editingPveNodeId ? 'PVE node updated.' : 'PVE node registered.' + clusterMessage)
                    : (editingPveNodeId ? 'PVE 노드가 수정되었습니다.' : 'PVE 노드가 등록되었습니다.' + clusterMessage),
                false
            );
        }
        clearProxmoxForm(true);
        await loadProxmoxNodes();
    } catch (e) {
        setProxmoxResult(
            (IS_ENGLISH
                ? (editingPveNodeId ? 'Update failed: ' : 'Create failed: ')
                : (editingPveNodeId ? '노드 수정 실패: ' : '노드 등록 실패: ')) + e.message,
            true
        );
    }
}

async function testProxmoxNode(nodeId) {
    const node = proxmoxNodes.find((n) => n.id === nodeId);
    if (!node) return;

    const testDataEl = document.getElementById('proxmox-test-data');
    if (testDataEl) {
        testDataEl.innerHTML = '<div class="proxmox-test-data">' + (IS_ENGLISH ? 'Testing connection...' : '연결 테스트 중...') + '</div>';
    }

    try {
        const res = await apiDeploy('POST', '/nodes/' + nodeId + '/test');
        if (!res.ok) {
            throw new Error(res.error || '테스트 실패');
        }

        const items = Array.isArray(res.nodes) ? res.nodes : [];
        if (testDataEl) {
            if (!items.length) {
                testDataEl.innerHTML = '<div class="proxmox-test-data">' + (IS_ENGLISH ? 'Connected. No node details returned.' : '연결 성공. 노드 상세 데이터가 없습니다.') + '</div>';
            } else {
                const list = items.map((n) => {
                    const mem = n.memTotal > 0 ? Math.round((n.memUsed / n.memTotal) * 100) : 0;
                    return escHtml(n.node) + ' | CPU ' + Math.round((n.cpu || 0) * 100) + '% | MEM ' + mem + '%';
                }).join('<br>');
                testDataEl.innerHTML = '<div class="proxmox-test-data">' + list + '</div>';
            }
        }
        await loadProxmoxNodes();
        showAlert((IS_ENGLISH ? 'Node connection OK: ' : '노드 연결이 정상입니다: ') + node.name, 'success');
    } catch (e) {
        if (testDataEl) {
            testDataEl.innerHTML = '<div class="proxmox-test-data">' + (IS_ENGLISH ? 'Test failed: ' : '테스트 실패: ') + escHtml(e.message) + '</div>';
        }
        showAlert((IS_ENGLISH ? 'Node test failed: ' : '노드 테스트 실패: ') + e.message, 'error');
        await loadProxmoxNodes();
    }
}

async function deleteProxmoxNode(nodeId) {
    const node = proxmoxNodes.find((n) => n.id === nodeId);
    const name = node?.name || nodeId;
    if (!await themedConfirm(
        (IS_ENGLISH ? 'Delete this PVE node? (' : '이 PVE 노드를 삭제하시겠습니까? (') + name + ')',
        IS_ENGLISH ? 'Delete Node' : '노드 삭제'
    )) return;

    try {
        await apiDeploy('DELETE', '/nodes/' + nodeId);
        showAlert((IS_ENGLISH ? 'Deleted PVE node: ' : 'PVE 노드를 삭제했습니다: ') + name, 'success');
        await loadProxmoxNodes();
    } catch (e) {
        showAlert((IS_ENGLISH ? 'Delete failed: ' : '노드 삭제 실패: ') + e.message, 'error');
    }
}

