async function saveMenuConfig() {
    try {
        const menuConfig = JSON.parse(document.getElementById('menuConfigEditor').value);
        const sectionLabels = JSON.parse(document.getElementById('sectionLabelsEditor').value);

        const menuRes = await api('PATCH', '/menu-config', menuConfig);
        if (!menuRes.ok) throw new Error('menu_config');

