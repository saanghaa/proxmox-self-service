function fmtDate(iso) {
    if (!iso) return '-';
    return new Date(iso).toLocaleString(IS_ENGLISH ? 'en-US' : 'ko-KR', { dateStyle: 'short', timeStyle: 'short' });
}

async function loadAutoRotatePolicy() {
    try {
        const data = await api('GET', '/auto-rotate-policy');
        const p = data.policy;
        document.getElementById('ar-enabled').checked = !!p.enabled;
        const _arDetailBody = document.getElementById('ar-detail-body');
        if (_arDetailBody) {
            if (p.enabled) { _arDetailBody.style.display = ''; _arDetailBody.classList.remove('collapsed'); }
            else { _arDetailBody.style.display = 'none'; _arDetailBody.classList.add('collapsed'); }
        }
        const linuxChecked = (p.targetTypes || []).includes('linux_key');
        const winChecked = (p.targetTypes || []).includes('windows_password');
        document.getElementById('ar-target-linux').checked = linuxChecked;
        document.getElementById('ar-target-win').checked = winChecked;
        document.getElementById('ar-tc-linux')?.classList.toggle('selected', linuxChecked);
        document.getElementById('ar-tc-win')?.classList.toggle('selected', winChecked);
        const modeRadio = document.querySelector(`input[name="arMode"][value="${p.scheduleMode || 'interval'}"]`);
        if (modeRadio) modeRadio.checked = true;
        document.getElementById('ar-intervalDays').value = p.intervalDays ?? 90;
        document.getElementById('ar-intervalMonths').value = p.intervalMonths ?? 3;
        document.getElementById('ar-dayOfMonth').value = p.dayOfMonth ?? 1;
        const hh = String(p.runAtHour ?? 0).padStart(2, '0');
        const mm = String(p.runAtMinute ?? 0).padStart(2, '0');
        document.getElementById('ar-runAt').value = `${hh}:${mm}`;
        document.getElementById('ar-lastRunAt').textContent = fmtDate(p.lastRunAt);
        document.getElementById('ar-nextRunAt').textContent = fmtDate(data.nextRunAt);
        toggleArMode();
    } catch (e) { /* ignore */ }
}

async function saveAutoRotatePolicy() {
    const targetTypes = [];
    if (document.getElementById('ar-target-linux').checked) targetTypes.push('linux_key');
    if (document.getElementById('ar-target-win').checked) targetTypes.push('windows_password');
    const payload = {
        enabled: document.getElementById('ar-enabled').checked,
        scheduleMode: document.querySelector('input[name="arMode"]:checked')?.value || 'interval',
        intervalDays: parseInt(document.getElementById('ar-intervalDays').value) || 90,
        intervalMonths: parseInt(document.getElementById('ar-intervalMonths').value) || 3,
        dayOfMonth: parseInt(document.getElementById('ar-dayOfMonth').value) || 1,
        runAtHour: parseInt((document.getElementById('ar-runAt').value || '00:00').split(':')[0]) || 0,
        runAtMinute: parseInt((document.getElementById('ar-runAt').value || '00:00').split(':')[1]) || 0,
        targetTypes,
    };
    try {
        const data = await api('PATCH', '/auto-rotate-policy', payload);
        document.getElementById('ar-nextRunAt').textContent = fmtDate(data.nextRunAt);
        showInlineSaveMsg('ar-msg', IS_ENGLISH ? 'Saved.' : '저장되었습니다.', 'success', 3000);
    } catch (e) {
        showInlineSaveMsg('ar-msg', (IS_ENGLISH ? 'Save failed: ' : '저장 실패: ') + e.message, 'error', 0);
    }
}

async function runAutoRotateNow() {
    const btn = document.getElementById('ar-run-now-btn');
    btn.disabled = true;
    btn.textContent = IS_ENGLISH ? 'Running...' : '실행 중...';
    try {
        const data = await api('POST', '/auto-rotate-policy/run-now');
        if (data.connError) {
            showArToast(data.connError, 'error', 6000);
        } else {
        const fc = data.failures?.length ?? 0;
        const ok = data.rotated ?? 0;
        const total = ok + fc;
        if (total === 0) {
            showArToast(IS_ENGLISH ? 'No VMs to rotate.' : '교체 대상 VM이 없습니다.', 'info');
        } else if (fc === 0) {
            showArToast(IS_ENGLISH ? `${ok} VM(s) rotated successfully.` : `${ok}대 교체 완료.`, 'success');
        } else if (ok === 0) {
            showArToast((IS_ENGLISH ? `All ${fc} VM(s) failed.\n` : `${fc}대 모두 실패.\n`) + data.failures.join('\n'), 'error', 6000);
        } else {
            showArToast((IS_ENGLISH ? `${ok} OK / ${fc} failed.\n` : `${ok}대 성공 / ${fc}대 실패.\n`) + data.failures.join('\n'), 'warning', 6000);
        }
        await loadAutoRotatePolicy();
        } // end connError else
    } catch (e) {
        showArToast((IS_ENGLISH ? 'Run failed: ' : '실행 실패: ') + e.message, 'error');
    } finally {
        btn.disabled = false;
        btn.textContent = IS_ENGLISH ? 'Run Now' : '지금 즉시 실행';
    }
}

