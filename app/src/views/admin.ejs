// Toggle switch handler for admin privileges (same UI as notification toggles)
async function toggleAdminSwitch(el) {
    const userId = el.dataset.userId;
    const email = el.dataset.userEmail;
    const turningOn = !!el.checked;

    const msg = turningOn
        ? (IS_ENGLISH
            ? 'Grant admin privileges to "' + email + '"?'
            : '"' + email + '" 사용자에게 관리자 권한을 부여하시겠습니까?')
        : (IS_ENGLISH
            ? 'Revoke admin privileges from "' + email + '"?'
            : '"' + email + '" 사용자에게서 관리자 권한을 제거하시겠습니까?');

    if (!await themedConfirm(msg)) {
        el.checked = !turningOn;
        return;
    }

    el.disabled = true;
    try {
        await api('PATCH', '/users/' + userId + '/toggle-admin');
        showAlert(
            turningOn
                ? (IS_ENGLISH ? 'Admin enabled: ' + email : '관리자 권한 부여 완료: ' + email)
                : (IS_ENGLISH ? 'Admin disabled: ' + email : '관리자 권한 제거 완료: ' + email),
            'success'
        );
        loadUsers();
    } catch (e) {
        el.checked = !turningOn;
        if (e.message === 'CANNOT_CHANGE_OWN_ADMIN_STATUS') {
            showAlert(IS_ENGLISH ? 'You cannot change your own admin status' : '본인 관리자 권한은 변경할 수 없습니다', 'error');
        } else {
            showAlert((IS_ENGLISH ? 'Failed: ' : '실패: ') + e.message, 'error');
        }
    } finally {
        el.disabled = false;
    }
}

// Segmented control handler for Admin/Member.
// Uses the same backend toggle endpoint, but only calls it when state actually changes.
async function setAdminRole(btn, desiredIsAdmin) {
    const wrap = btn.closest('.seg-toggle');
    if (!wrap) return;

    const userId = wrap.dataset.userId;
    const email = wrap.dataset.userEmail;
    const currentIsAdmin = wrap.dataset.currentAdmin === '1';
    const desired = !!desiredIsAdmin;

    if (currentIsAdmin === desired) return;

    const msg = desired
        ? (IS_ENGLISH
            ? 'Grant admin privileges to \"' + email + '\"?'
            : '\"' + email + '\" 사용자에게 관리자 권한을 부여하시겠습니까?')
        : (IS_ENGLISH
            ? 'Revoke admin privileges from \"' + email + '\"?'
            : '\"' + email + '\" 사용자에게서 관리자 권한을 제거하시겠습니까?');

    if (!await themedConfirm(msg)) return;

    const buttons = Array.from(wrap.querySelectorAll('button'));
    buttons.forEach(b => (b.disabled = true));
    try {
        await api('PATCH', '/users/' + userId + '/toggle-admin');
        showAlert(
            desired
                ? (IS_ENGLISH ? 'Admin enabled: ' + email : '관리자 권한 부여 완료: ' + email)
                : (IS_ENGLISH ? 'Admin disabled: ' + email : '관리자 권한 제거 완료: ' + email),
            'success'
        );
        loadUsers();
    } catch (e) {
        if (e.message === 'CANNOT_CHANGE_OWN_ADMIN_STATUS') {
            showAlert(IS_ENGLISH ? 'You cannot change your own admin status' : '본인 관리자 권한은 변경할 수 없습니다', 'error');
        } else {
            showAlert((IS_ENGLISH ? 'Failed: ' : '실패: ') + e.message, 'error');
        }
    } finally {
        buttons.forEach(b => (b.disabled = false));
    }
}

