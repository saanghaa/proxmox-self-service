async function loadVmRequests() {
    let res = null;
    try {
        res = await api('GET', '/vm-requests');
    } catch (e) {
        showAlert((IS_ENGLISH ? 'Failed to load requests: ' : '요청 목록 로드 실패: ') + (e.message || e), 'error');
        return;
    }
    if (!res || !res.ok) {
        return;
    }

    vmRequestsData = res.requests || [];
    const activeStatuses = ['REQUESTED', 'QUOTA_EXCEEDED', 'APPROVED', 'DEPLOYING', 'FAILED', 'PARTIAL'];

    const filter = document.getElementById('vmreq-filter').value;
    let filtered = vmRequestsData;
    if (filter === 'pending') filtered = vmRequestsData.filter(r => activeStatuses.includes(r.status));
    else if (filter === 'approved') filtered = vmRequestsData.filter(r => r.status === 'APPROVED');
    else if (filter === 'deploying') filtered = vmRequestsData.filter(r => r.status === 'DEPLOYING');
    else if (filter === 'completed') filtered = vmRequestsData.filter(r => r.status === 'COMPLETED');

    const pendingCount = vmRequestsData.filter(r => activeStatuses.includes(r.status)).length;
	    document.getElementById('vmreq-pending-count').textContent = pendingCount + ' ' + (IS_ENGLISH ? 'active' : '진행중');

    const tbody = document.getElementById('vmreq-tbody');
	    if (filtered.length === 0) {
	        tbody.innerHTML = '<tr><td colspan="9" class="loading-center">' + (IS_ENGLISH ? 'No requests match the current filter.' : '해당 조건의 요청이 없습니다.') + '</td></tr>';
	        return;
	    }

    tbody.innerHTML = filtered.map(r => {
        const st = STATUS_MAP[r.status] || { icon: 'ti ti-circle', label: r.status, className: 'vmreq-requested' };
        const spec = r.cpuCores + 'vCPU / ' + Math.round(r.memoryMb / 1024) + 'GB / ' + r.diskSizeGb + 'GB';
        const date = r.createdAt ? new Date(r.createdAt).toLocaleDateString() : '-';

	        let actions = '';
	        if (r.status === 'REQUESTED') {
	            actions = '<button class="btn btn-success btn-xs-alt" onclick="openReviewModal(\'' + r.id + '\')">' + (IS_ENGLISH ? 'Review' : '검토') + '</button>';
	        } else if (r.status === 'QUOTA_EXCEEDED') {
	            actions = '<button class="btn btn-warning btn-xs-alt" onclick="openQuotaModal(\'' + r.id + '\')">' + (IS_ENGLISH ? 'Quota' : '쿼터 처리') + '</button>';
	        } else if (r.status === 'APPROVED') {
	            actions =
	                '<button class="btn btn-info btn-xs-alt" onclick="deployApprovedRequest(\'' + r.id + '\')">' + (IS_ENGLISH ? 'Create' : '배포') + '</button> ' +
	                '<button class="btn btn-secondary btn-xs-alt" onclick="openDeployLogModal(\'' + r.id + '\')">' + (IS_ENGLISH ? 'Log' : '로그') + '</button>';
	        } else if (r.status === 'FAILED' || r.status === 'PARTIAL') {
	            actions =
	                '<button class="btn btn-warning btn-xs-alt" onclick="retryFailedRequest(\'' + r.id + '\')">' + (IS_ENGLISH ? 'Retry' : '재시도') + '</button> ' +
	                '<button class="btn btn-secondary btn-xs-alt" onclick="openDeployLogModal(\'' + r.id + '\')">' + (IS_ENGLISH ? 'Log' : '로그') + '</button>';
	        } else if (['DEPLOYING', 'COMPLETED'].includes(r.status)) {
	            actions = '<button class="btn btn-secondary btn-xs-alt" onclick="openDeployLogModal(\'' + r.id + '\')">' + (IS_ENGLISH ? 'Log' : '로그') + '</button>';
	        }

        return '<tr>' +
            '<td class="text-fs-082">' + date + '</td>' +
            '<td class="text-fs-082">' + (r.requestedByEmail || '-') + '</td>' +
            '<td><span class="badge badge-group">' + (r.group?.name || '-') + '</span></td>' +
            '<td>' + r.instanceType + (r.preferredOs ? '<br><span class="text-fs-08-muted">' + r.preferredOs + '</span>' : '') + '</td>' +
            '<td>' + r.vmCount + '</td>' +
            '<td class="text-fs-08-muted">' + spec + '</td>' +
            '<td class="text-ellipsis-120" title="' + (r.purpose || '') + '">' + (r.purpose || '-') + '</td>' +
            '<td><span class="vmreq-status ' + st.className + '"><i class="' + st.icon + '" aria-hidden="true"></i> ' + st.label + '</span></td>' +
            '<td class="text-center">' + actions + '</td>' +
            '</tr>';
    }).join('');

    // 할당량 관리 로드
    loadQuotaManagement();

    // DEPLOYING 항목이 있으면 5초마다 자동 갱신 (완료되면 목록에서 사라짐)
    const hasDeploying = vmRequestsData.some(r => r.status === 'DEPLOYING');
    if (hasDeploying && !_vmReqDeployPoller) {
        _vmReqDeployPoller = setInterval(() => {
            const tab = document.getElementById('tab-vm-requests');
            if (!tab || !tab.classList.contains('active')) {
                clearInterval(_vmReqDeployPoller);
                _vmReqDeployPoller = null;
                return;
            }
            loadVmRequests();
        }, 5000);
    } else if (!hasDeploying && _vmReqDeployPoller) {
        clearInterval(_vmReqDeployPoller);
        _vmReqDeployPoller = null;
    }
}

async function openReviewModal(requestId) {
    currentReviewRequest = vmRequestsData.find(r => r.id === requestId);
    if (!currentReviewRequest) return;

    const r = currentReviewRequest;
    const spec = r.cpuCores + ' vCPU / ' + Math.round(r.memoryMb / 1024) + ' GB RAM / ' + r.diskSizeGb + ' GB Disk';
    let extra = '';
    if (r.extraDiskCount > 0) {
        extra = '<br>+ ' + (r.extraDiskCount === 1
            ? (r.extraDiskGb + ' GB extra disk')
            : (r.extraDiskCount + ' x ' + r.extraDiskGb + ' GB extra disks'));
    }

    const osLabel = r.preferredOs ? (' | OS: <strong>' + r.preferredOs + '</strong>') : '';
    document.getElementById('vmreq-summary').innerHTML =
        '<strong>' + r.instanceType + '</strong> x ' + r.vmCount + ' VMs<br>' +
        '<span class="text-muted-inline">' + spec + extra + '</span><br>' +
        'Group: <strong>' + (r.group?.name || '-') + '</strong> | User: ' + (r.requestedByEmail || '-') + osLabel + '<br>' +
        'Hostname: <strong>' + r.hostnamePrefix + '</strong>' +
        (r.purpose ? '<br>Purpose: ' + r.purpose : '');

    // PVE Node 목록 로드
    const nodeRes = await apiDeploy('GET', '/nodes');
    const nodeSelect = document.getElementById('vmreq-node');
    nodeSelect.innerHTML = '<option value="">-- Select --</option>';
    const availableNodeIds = [];
    if (nodeRes.ok && nodeRes.nodes) {
        nodeRes.nodes.forEach(n => {
            nodeSelect.innerHTML += '<option value="' + n.id + '">' + n.name + ' (' + n.host + ')</option>';
            availableNodeIds.push(n.id);
        });
    }
    nodeSelect.onchange = function() {
        loadNodeDetails(this.value);
    };

    document.getElementById('vmreq-start-vmid').value = '';
    document.getElementById('vmreq-start-number').value = '1';
    document.getElementById('vmreq-start-ip').value = '';
    const gatewayInput = document.getElementById('vmreq-gateway');
    gatewayInput.value = '';
    gatewayInput.dataset.autofilled = '0';
    gatewayInput.oninput = function() {
        this.dataset.autofilled = '0';
    };
    const reqDnsPrimary = (r.dnsPrimary || '').trim();
    const reqDnsSecondary = (r.dnsSecondary || '').trim();
    if (reqDnsPrimary) {
        document.getElementById('vmreq-dns-preset').value = 'custom';
        document.getElementById('vmreq-dns-primary').value = reqDnsPrimary;
        document.getElementById('vmreq-dns-secondary').value = reqDnsSecondary;
    } else {
        document.getElementById('vmreq-dns-preset').value = 'google';
        applyDnsPreset('google');
    }
    document.getElementById('vmreq-review-note').value = '';
    document.getElementById('vmreq-approve-error').style.display = 'none';
    document.getElementById('vmreq-vmsource').value = 'cloud-image';
    document.getElementById('vmreq-template-row').style.display = 'none';
    document.getElementById('vmreq-cloud-image-row').style.display = '';
    document.getElementById('vmreq-cloud-image').innerHTML = '<option value="">-- Select Node first --</option>';
    document.getElementById('vmreq-bridge-hint').textContent = '브릿지를 선택하면 네트워크 대역 안내가 표시됩니다.';
    vmreqBridgeMeta = {};

    // Next VMID 자동 조회
    document.getElementById('vmreq-vmsource').onchange = function() {
        document.getElementById('vmreq-template-row').style.display = this.value === 'template-clone' ? '' : 'none';
        document.getElementById('vmreq-cloud-image-row').style.display = this.value === 'cloud-image' ? '' : 'none';
    };

    let initialNodeId = '';
    if (r.nodeId && availableNodeIds.includes(r.nodeId)) {
        initialNodeId = r.nodeId;
    } else if (availableNodeIds.length === 1) {
        initialNodeId = availableNodeIds[0];
    }
    if (initialNodeId) {
        nodeSelect.value = initialNodeId;
        await loadNodeDetails(initialNodeId);
    }

    document.getElementById('vmreqApproveModal').classList.add('active');
    initVmReqCustomSelects();
}

