async function deleteGroup(groupId, groupName) {
    const ok = await themedConfirm(
        IS_ENGLISH
            ? ('Delete group \"' + groupName + '\"?\\n\\nThis action cannot be undone.')
            : ('그룹 \"' + groupName + '\"을(를) 삭제하시겠습니까?\\n\\n이 작업은 되돌릴 수 없습니다.'),
        IS_ENGLISH ? 'Delete Group' : '그룹 삭제'
    );
    if (!ok) return;

    try {
        await api('DELETE', '/groups/' + groupId);
        showAlert((IS_ENGLISH ? 'Group deleted: ' : '그룹 삭제 완료: ') + groupName, 'success');
        loadGroups();
    } catch (e) {
        if (e.message === 'GROUP_HAS_MEMBERS') {
            showAlert(IS_ENGLISH ? 'Cannot delete a group with members. Remove all members first.' : '멤버가 있는 그룹은 삭제할 수 없습니다. 먼저 멤버를 모두 제거하세요.', 'error');
        } else if (e.message === 'GROUP_HAS_VMS') {
            showAlert(IS_ENGLISH ? 'Cannot delete a group with VMs. Remove or reassign all VMs first.' : 'VM이 있는 그룹은 삭제할 수 없습니다. VM을 제거하거나 다른 그룹으로 이동하세요.', 'error');
        } else if (e.message === 'GROUP_HAS_JOBS') {
            showAlert(IS_ENGLISH ? 'Cannot delete a group with jobs. Remove all jobs first.' : 'Job이 있는 그룹은 삭제할 수 없습니다. 먼저 Job을 모두 제거하세요.', 'error');
        } else {
            showAlert((IS_ENGLISH ? 'Failed: ' : '실패: ') + e.message, 'error');
        }
    }
}

