}

const DEFAULT_NOTIFY_EVENTS = new Set([
    'key_download', 'key_rotate', 'key_rotate_auto',
    'vm_delete', 'login_fail', 'user_create', 'user_delete'
]);

function renderNotificationEventCheckboxes(channel, selectedEvents) {
    const container = document.getElementById(channel + '-events');
    if (!container) return;
    // null/undefined = 미설정(기본값 적용) / [] = 사용자가 전체 해제
    const isNew = !Array.isArray(selectedEvents);
    const selected = isNew
        ? DEFAULT_NOTIFY_EVENTS
        : new Set(selectedEvents.map(v => String(v || '').trim().toLowerCase()));

    container.classList.add('notification-events');
    container.innerHTML = NOTIFICATION_EVENT_GROUPS.map((group) => {
        const groupTitle = IS_ENGLISH ? group.en : group.ko;
        const groupItems = group.events.map((evt) => {
            const id = channel + '-evt-' + evt.key;
            const label = IS_ENGLISH ? evt.en : evt.ko;
            const checked = selected.has(evt.key) ? 'checked' : '';
            return '<label class="check-label" for="' + id + '">' +
                '<input type="checkbox" id="' + id + '" value="' + evt.key + '" ' + checked + '> ' +
                label +
                '</label>';
        }).join('');

        return '<div class="notification-event-group">' +
            '<div class="notification-event-group-title">' + groupTitle + '</div>' +
            '<div class="notification-event-grid">' + groupItems + '</div>' +
            '</div>';
    }).join('');
}

function getSelectedNotificationEvents(channel) {
    return Array.from(document.querySelectorAll('#' + channel + '-events input[type=\"checkbox\"]:checked'))
        .map((el) => String(el.value || '').trim().toLowerCase())
        .filter(Boolean);
}

