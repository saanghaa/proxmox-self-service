function updateBridgeHint() {
    const bridgeSelect = document.getElementById('vmreq-bridge');
    const hintEl = document.getElementById('vmreq-bridge-hint');
    const gatewayInput = document.getElementById('vmreq-gateway');
    const selected = bridgeSelect.value;
    if (!selected || !vmreqBridgeMeta[selected]) {
        hintEl.textContent = '브릿지를 선택하면 네트워크 대역 안내가 표시됩니다.';
        return;
    }

    const meta = vmreqBridgeMeta[selected];
    if (meta.address && gatewayInput) {
        const shouldAutofill =
            !String(gatewayInput.value || '').trim() ||
            gatewayInput.dataset.autofilled === '1';
        if (shouldAutofill) {
            // Don't fill gateway with the bridge IP itself.
            const gw = meta.gateway || guessGatewayFromInterface(meta.address, meta.netmask);
            if (gw) {
                gatewayInput.value = gw;
                gatewayInput.dataset.autofilled = '1';
            }
        }
    }
    const parts = [(IS_ENGLISH ? 'Selected bridge: ' : '선택 브릿지: ') + selected];
    if (meta.address) {
        const prefix = meta.netmask ? netmaskToPrefix(meta.netmask) : null;
        parts.push('Address: ' + meta.address + (prefix ? '/' + prefix : ''));
    }
    if (meta.ports) parts.push('Ports: ' + meta.ports);
    parts.push(IS_ENGLISH ? 'Start IP and Gateway should be in the same subnet.' : 'Start IP/Gateway를 같은 대역으로 입력하세요.');
    hintEl.textContent = parts.join(' | ');
}

function ipv4ToInt(ip) {
    const parts = String(ip || '').trim().split('.');
    if (parts.length !== 4) return null;
    let n = 0;
    for (const p of parts) {
        const v = Number(p);
        if (!Number.isInteger(v) || v < 0 || v > 255) return null;
        n = (n << 8) | v;
    }
    return n >>> 0;
}

function intToIpv4(n) {
    if (typeof n !== 'number' || !Number.isFinite(n)) return null;
    return [
        (n >>> 24) & 255,
        (n >>> 16) & 255,
        (n >>> 8) & 255,
        n & 255,
    ].join('.');
}

function netmaskToPrefix(netmask) {
    const m = ipv4ToInt(netmask);
    if (m === null) return null;
    let bits = 0;
    for (let i = 31; i >= 0; i--) {
        if ((m & (1 << i)) !== 0) bits++;
        else break;
    }
    return bits;
}

function guessGatewayFromInterface(address, netmask) {
    const ip = ipv4ToInt(address);
    if (ip === null) return null;
    const mask = netmask ? ipv4ToInt(netmask) : null;
    // Assume /24 if netmask not available.
    const m = mask === null ? ipv4ToInt('255.255.255.0') : mask;
    if (m === null) return null;
    const network = (ip & m) >>> 0;
    const gw = (network + 1) >>> 0;
    if (gw === ip) return null;
    return intToIpv4(gw);
}

async function loadNodeDetails(nodeId) {
    if (!nodeId) return;
    const errEl = document.getElementById('vmreq-approve-error');
    errEl.style.display = 'none';

    const storageSelect = document.getElementById('vmreq-storage');
    const bridgeSelect = document.getElementById('vmreq-bridge');
    const tplSelect = document.getElementById('vmreq-template-vmid');
    const imageSelect = document.getElementById('vmreq-cloud-image');

    const loadingOpt = '<option value="">-- ' + (IS_ENGLISH ? 'Loading...' : '불러오는 중...') + ' --</option>';
    storageSelect.innerHTML = loadingOpt;
    bridgeSelect.innerHTML = loadingOpt;
    tplSelect.innerHTML = loadingOpt;
    imageSelect.innerHTML = loadingOpt;

    try {
        // Storage
        const storageRes = await apiDeploy('GET', '/nodes/' + nodeId + '/storage');
        storageSelect.innerHTML = '<option value="">-- Select --</option>';
        const storageList = storageRes.pools || storageRes.storages || [];
        if (storageRes.ok && storageList.length) {
            storageList.forEach(s => {
                const name = s.name || s.storage;
                storageSelect.innerHTML += '<option value="' + name + '">' + name + ' (' + s.type + ')</option>';
            });
        } else {
            storageSelect.innerHTML = '<option value="">-- Load failed --</option>';
        }

        // Bridges
        const bridgeRes = await apiDeploy('GET', '/nodes/' + nodeId + '/bridges');
        bridgeSelect.innerHTML = '<option value="">-- Select --</option>';
        vmreqBridgeMeta = {};
        if (bridgeRes.ok && bridgeRes.bridges) {
            bridgeRes.bridges.forEach(b => {
                const bridgeName = b.name || b.iface;
                vmreqBridgeMeta[bridgeName] = {
                    address: b.address || '',
                    netmask: b.netmask || '',
                    gateway: b.gateway || '',
                    ports: b.ports || '',
                };
                const labelParts = [bridgeName];
                if (b.address) labelParts.push('[' + b.address + ']');
                const option = document.createElement('option');
                option.value = bridgeName;
                option.textContent = labelParts.join(' ');
                bridgeSelect.appendChild(option);
            });
        } else {
            bridgeSelect.innerHTML = '<option value="">-- Load failed --</option>';
        }
        bridgeSelect.onchange = updateBridgeHint;
        updateBridgeHint();

        // Next VMID
        const vmidRes = await apiDeploy('GET', '/nodes/' + nodeId + '/next-vmid');
        if (vmidRes.ok && vmidRes.vmid) {
            document.getElementById('vmreq-start-vmid').value = vmidRes.vmid;
        } else {
            document.getElementById('vmreq-start-vmid').value = '';
        }

        // Templates (for clone mode)
        const tplRes = await apiDeploy('GET', '/nodes/' + nodeId + '/templates');
        tplSelect.innerHTML = '<option value="">-- Select --</option>';
        if (tplRes.ok && tplRes.templates) {
            tplRes.templates.forEach(t => {
                tplSelect.innerHTML += '<option value="' + t.vmid + '">' + t.vmid + ' - ' + t.name + '</option>';
            });
        } else {
            tplSelect.innerHTML = '<option value="">-- Load failed --</option>';
        }

        // Cloud images (for cloud-image mode)
        const imageRes = await apiDeploy('GET', '/nodes/' + nodeId + '/cloud-images');
        imageSelect.innerHTML = IS_ENGLISH
            ? '<option value="">-- Select Cloud Image --</option>'
            : '<option value="">-- Cloud Image 선택 --</option>';
        if (imageRes.ok && Array.isArray(imageRes.images)) {
            imageRes.images.forEach((img) => {
                const option = document.createElement('option');
                option.value = img.volid;
                option.textContent = img.file + ' [' + img.storage + ']';
                imageSelect.appendChild(option);
            });
            // preferredOs 패턴 매칭으로 자동 pre-select
            if (currentReviewRequest && currentReviewRequest.preferredOs) {
                const OS_PATTERNS = {
                    'ubuntu-24.04': 'ubuntu-24.04',
                    'rocky-10': 'rocky-10',
                };
                const pattern = OS_PATTERNS[currentReviewRequest.preferredOs];
                if (pattern) {
                    for (let i = 0; i < imageSelect.options.length; i++) {
                        if (imageSelect.options[i].textContent.toLowerCase().includes(pattern)) {
                            imageSelect.value = imageSelect.options[i].value;
                            break;
                        }
                    }
                }
            }
        } else {
            imageSelect.innerHTML = '<option value="">-- Load failed --</option>';
        }
    } catch (e) {
        storageSelect.innerHTML = '<option value="">-- Load failed --</option>';
        bridgeSelect.innerHTML = '<option value="">-- Load failed --</option>';
        tplSelect.innerHTML = '<option value="">-- Load failed --</option>';
        imageSelect.innerHTML = '<option value="">-- Load failed --</option>';
        errEl.textContent = '노드 상세 정보를 불러오지 못했습니다: ' + (e.message || e);
        errEl.style.display = 'block';
    }
    refreshVmReqDynamicCustomSelects();
}

