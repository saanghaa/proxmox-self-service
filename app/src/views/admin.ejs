	            <div class="section-header">
	                <span><%= isEnglish ? 'Group Quota Management' : '그룹 할당량 관리' %></span>
	                <button class="btn btn-info" onclick="loadQuotaManagement()"><i class="ti ti-refresh inline-ti" aria-hidden="true"></i><%= isEnglish ? 'Refresh' : '새로고침' %></button>
