function updateNotificationToggleStatus(key) {
    const checkbox = document.getElementById(key + '-enabled');
    const statusEl = document.getElementById(key + '-enabled-status');
    if (!checkbox || !statusEl) return;

    const enabled = checkbox.checked;
    statusEl.textContent = enabled
        ? (IS_ENGLISH ? 'Enabled' : '활성화')
        : (IS_ENGLISH ? 'Disabled' : '비활성화');
    statusEl.classList.toggle('on', enabled);
    statusEl.classList.toggle('off', !enabled);
}

function syncNotificationToggleStatuses() {
    notificationToggleKeys.forEach(updateNotificationToggleStatus);
}

function getNotificationAccordionItems() {
    const tab = document.getElementById('tab-notifications');
    if (!tab) return [];
    return Array.from(tab.querySelectorAll('.notification-accordion-item'));
}

function setNotificationAccordionItemOpen(item, isOpen) {
    if (!item) return;
    const header = item.querySelector('.section-header');
    item.classList.toggle('is-open', !!isOpen);
    if (header) header.setAttribute('aria-expanded', isOpen ? 'true' : 'false');
}

function syncNotificationAccordionFromToggles() {
    const items = getNotificationAccordionItems();
    if (!items.length) return;
    items.forEach((item) => {
        const cb = item.querySelector('.toggle-wrap input[type="checkbox"]');
        setNotificationAccordionItemOpen(item, !!(cb && cb.checked));
    });
}

function setInitialNotificationAccordionState() {
    // 최초 진입 시 ON=펼침, OFF=접힘
    syncNotificationAccordionFromToggles();
}

function initNotificationAccordion() {
    const items = getNotificationAccordionItems();
    if (!items.length) return;

    items.forEach((item) => {
        const header = item.querySelector('.section-header');
        if (!header || item.dataset.notifAccordionBound === '1') return;

        const toggleWrap = item.querySelector('.toggle-wrap');
        const toggleInput = item.querySelector('.toggle-wrap input[type="checkbox"]');

        item.dataset.notifAccordionBound = '1';
        header.setAttribute('aria-expanded', 'false');

        if (toggleWrap) {
            ['click', 'mousedown', 'mouseup', 'touchstart', 'touchend', 'keydown'].forEach((evt) => {
                toggleWrap.addEventListener(evt, (e) => e.stopPropagation());
            });
        }

        // 토글 ON=펼침, OFF=접힘 (헤더 클릭으로는 제어하지 않음)
        if (toggleInput) {
            toggleInput.addEventListener('change', () => {
                setNotificationAccordionItemOpen(item, toggleInput.checked);
            });
        }
    });
}

function bindNotificationToggleStatusHandlers() {
    notificationToggleKeys.forEach((key) => {
        const checkbox = document.getElementById(key + '-enabled');
        if (!checkbox || checkbox.dataset.toggleStatusBound === '1') return;
        checkbox.addEventListener('change', () => updateNotificationToggleStatus(key));
        checkbox.dataset.toggleStatusBound = '1';
    });
    syncNotificationToggleStatuses();
}

function isValidHttpUrl(value) {
    try {
        const url = new URL(value);
        return url.protocol === 'http:' || url.protocol === 'https:';
    } catch (_) {
        return false;
    }
}

