            color-scheme: dark;
            -webkit-text-fill-color: #e8f0fb;
        }
        #vmreqApproveModal select option,
        #vmreqQuotaModal select option,
        #vmreqRejectModal select option,
        #vmreqLogModal select option {
            background: #1a253c !important;
            color: #e8f0fb !important;
            -webkit-text-fill-color: #e8f0fb;
        }
        #vmreqApproveModal select option:checked,
        #vmreqQuotaModal select option:checked,
        #vmreqRejectModal select option:checked,
        #vmreqLogModal select option:checked {
            background: #2a3f63 !important;
            color: #ffffff !important;
            -webkit-text-fill-color: #ffffff;
