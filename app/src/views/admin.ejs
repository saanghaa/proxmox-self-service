        syncNotificationToggleStatuses();
        setInitialNotificationAccordionState();
    } catch (e) {
        showAlert((IS_ENGLISH ? 'Failed to load notification settings: ' : '알림 설정을 불러오지 못했습니다: ') + e.message, 'error');
