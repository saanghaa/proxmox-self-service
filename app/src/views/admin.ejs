var _statsCharts = {};
var _knownPveNodeNames = [];

function extractKnownPveNodeNames(results) {
    var names = {};
    if (!Array.isArray(results)) return [];
    for (var i = 0; i < results.length; i++) {
        var r = results[i] || {};
        if (Array.isArray(r.nodes)) {
            for (var j = 0; j < r.nodes.length; j++) {
                var n = r.nodes[j] || {};
                if (n.node) names[String(n.node)] = true;
            }
        }
        if (r.nodeDbName) names[String(r.nodeDbName)] = true;
    }
    return Object.keys(names).sort();
}

function _accordionOpen(el, onDone) {
    // display 값을 CSS에서 가져와 flex/grid/block 등 원래 값 유지
    el.style.display = '';
    el.classList.remove('collapsed');
    var computedDisplay = getComputedStyle(el).display;
    if (computedDisplay === 'none') computedDisplay = 'block';
    el.style.display = computedDisplay;
    el.style.overflow = 'hidden';
    el.style.height = '0';
    requestAnimationFrame(function() {
        var h = el.scrollHeight;
        el.style.transition = 'height 0.3s ease';
        el.style.height = h + 'px';
        el.addEventListener('transitionend', function handler() {
            el.style.height = '';
            el.style.overflow = '';
            el.style.transition = '';
            el.removeEventListener('transitionend', handler);
            if (onDone) onDone();
        }, { once: true });
    });
}

function _accordionClose(el, onDone) {
    el.style.height = el.scrollHeight + 'px';
    el.style.overflow = 'hidden';
    requestAnimationFrame(function() {
        el.style.transition = 'height 0.3s ease';
        el.style.height = '0';
        el.addEventListener('transitionend', function handler() {
            el.style.display = 'none';
            el.style.height = '';
            el.style.overflow = '';
            el.style.transition = '';
            el.classList.add('collapsed');
            el.removeEventListener('transitionend', handler);
            if (onDone) onDone();
        }, { once: true });
    });
}

