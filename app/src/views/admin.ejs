var _pendingRestoreFilename = null;

function openRestoreModal(filename) {
    _pendingRestoreFilename = filename;
    document.getElementById('backupRestoreFilename').textContent = filename;
    document.getElementById('modalRestoreType').value = 'config';
    document.getElementById('modalRestoreWarning').style.display = 'none';
    document.getElementById('backupRestoreStatus').textContent = '';
    document.getElementById('backupRestoreStatus').style.color = '';
    document.getElementById('confirmRestoreBtn').disabled = false;
    document.getElementById('backupRestoreModal').style.display = 'flex';
    document.getElementById('modalRestoreType').onchange = function() {
        document.getElementById('modalRestoreWarning').style.display =
            this.value === 'full' ? '' : 'none';
    };
}

function closeBackupRestoreModal() {
    document.getElementById('backupRestoreModal').style.display = 'none';
    _pendingRestoreFilename = null;
}

async function confirmRestoreFromList() {
    if (!_pendingRestoreFilename) return;
    const restoreType = document.getElementById('modalRestoreType').value;
    const statusEl = document.getElementById('backupRestoreStatus');
    const btn = document.getElementById('confirmRestoreBtn');

    if (restoreType === 'full') {
        const confirmMsg = IS_ENGLISH
            ? '⚠️ FULL DB RESTORE will DROP ALL DATA and restart the service.\n\nThis CANNOT be undone. Are you absolutely sure?'
            : '⚠️ 전체 DB 복구 시 모든 데이터가 삭제되고 서비스가 재시작됩니다.\n\n되돌릴 수 없습니다. 정말 진행하시겠습니까?';
        if (!await themedConfirm(confirmMsg, IS_ENGLISH ? 'Full DB Restore' : '전체 DB 복구')) return;
    }

    btn.disabled = true;
    statusEl.textContent = IS_ENGLISH ? 'Restoring...' : '복구 중...';
    statusEl.style.color = '#64748b';

    try {
        const res = await api('POST', '/backup/' + encodeURIComponent(_pendingRestoreFilename) + '/restore', { type: restoreType });
        if (res.ok) {
            statusEl.textContent = res.message || (IS_ENGLISH ? 'Restore successful' : '복구 완료');
            statusEl.style.color = '#166534';
            if (restoreType === 'full') {
                setTimeout(() => { window.location.reload(); }, 5000);
            } else {
                setTimeout(() => closeBackupRestoreModal(), 2000);
            }
        } else {
            statusEl.textContent = (IS_ENGLISH ? 'Failed: ' : '실패: ') + (res.error || '');
            statusEl.style.color = '#991b1b';
            btn.disabled = false;
        }
    } catch(e) {
        statusEl.textContent = IS_ENGLISH ? 'Network error' : '네트워크 오류';
        statusEl.style.color = '#991b1b';
        btn.disabled = false;
    }
}

async function deleteBackupFile(filename) {
