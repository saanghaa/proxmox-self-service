function measureSelectTextWidth(select) {
    const option = select?.options?.[select.selectedIndex] || select?.options?.[0];
    const text = (option?.textContent || '').trim();
    const probe = document.createElement('span');
    const cs = window.getComputedStyle(select);
    probe.style.position = 'fixed';
    probe.style.left = '-9999px';
    probe.style.top = '-9999px';
    probe.style.visibility = 'hidden';
    probe.style.whiteSpace = 'nowrap';
    probe.style.font = cs.font || '500 14px Segoe UI, sans-serif';
    probe.textContent = text;
    document.body.appendChild(probe);
    const width = probe.getBoundingClientRect().width;
    document.body.removeChild(probe);
    return Math.ceil(width);
}

function measureMaxOptionTextWidth(select) {
    if (!select || !select.options || !select.options.length) return 0;
    const probe = document.createElement('span');
    const cs = window.getComputedStyle(select);
    probe.style.position = 'fixed';
    probe.style.left = '-9999px';
    probe.style.top = '-9999px';
    probe.style.visibility = 'hidden';
    probe.style.whiteSpace = 'nowrap';
    probe.style.font = cs.font || '500 14px Segoe UI, sans-serif';
    document.body.appendChild(probe);
    let maxWidth = 0;
    Array.from(select.options).forEach(opt => {
        probe.textContent = (opt?.textContent || '').trim();
        maxWidth = Math.max(maxWidth, probe.getBoundingClientRect().width);
    });
    document.body.removeChild(probe);
    return Math.ceil(maxWidth);
}

function destroyCustomSelect(selectId) {
    const select = document.getElementById(selectId);
    if (!select || !select.__customDd) return;
    select.__customDd.remove();
    select.__customDd = null;
    select.style.display = '';
}

function enhanceCustomSelect(selectId, options = {}) {
    const select = document.getElementById(selectId);
    if (!select || select.__customDd) return;
    const fullWidth = !!options.fullWidth;
    const textWidth = measureSelectTextWidth(select);
    const minWidthById = (selectId === 'backupScheduleType') ? 183
        : (selectId === 'restoreType') ? 220
        : (selectId === 'backupRetention') ? 76
        : 76;
    const maxWidthById = (selectId === 'restoreType') ? 420 : 300;
    const widthPx = fullWidth
        ? Math.ceil(select.getBoundingClientRect().width || select.offsetWidth || 240)
        : ((selectId === 'restoreType')
            ? Math.max(minWidthById, Math.min(maxWidthById, measureMaxOptionTextWidth(select) + 42))
            : Math.max(minWidthById, Math.min(maxWidthById, textWidth + 42)));

    const dd = document.createElement('div');
    dd.className = 'filter-dd backup-custom-dd js-custom-select-dd' + (fullWidth ? ' vmreq-custom-dd' : '');
    dd.style.width = widthPx + 'px';
    dd.dataset.selectId = selectId;

    const btn = document.createElement('button');
    btn.type = 'button';
    btn.className = 'select-compact filter-dd-btn js-custom-select-btn';
    btn.innerHTML = '<span class="js-custom-select-label"></span><i class="ti ti-chevron-down" aria-hidden="true"></i>';
    btn.addEventListener('click', function(e) {
        e.stopPropagation();
        const willOpen = !dd.classList.contains('open');
        if (willOpen) closeOtherSelectMenus(dd);
        dd.classList.toggle('open', willOpen);
        if (willOpen) {
            const menu = dd.querySelector('.js-custom-select-menu');
            positionFixedDropdown(menu, btn);
        }
    });

    const menu = document.createElement('div');
    menu.className = 'filter-dd-menu js-custom-select-menu';
    Array.from(select.options).forEach(opt => {
        const item = document.createElement('button');
        item.type = 'button';
        item.className = 'filter-dd-item';
        item.dataset.value = opt.value;
        item.textContent = opt.textContent || '';
        item.addEventListener('click', function(ev) {
            ev.stopPropagation();
            select.value = opt.value;
            dd.classList.remove('open');
            syncCustomSelectUi(selectId);
            select.dispatchEvent(new Event('change', { bubbles: true }));
        });
        menu.appendChild(item);
    });

    dd.appendChild(btn);
    dd.appendChild(menu);
    select.style.display = 'none';
    select.insertAdjacentElement('afterend', dd);
    select.__customDd = dd;
    syncCustomSelectUi(selectId);
}

function reEnhanceCustomSelect(selectId, options = {}) {
    destroyCustomSelect(selectId);
    enhanceCustomSelect(selectId, options);
}

function initBackupCustomSelects() {
    ['backupScheduleType', 'backupHour', 'backupRetention', 'restoreType'].forEach(enhanceCustomSelect);
}

function initVmReqCustomSelects() {
    [
