// 할당량 관리 - 단위 변환 헬퍼
function _fmtMemInput(mb) {
    if (mb < 0) return String(mb);
    if (mb === 0) return '0';
    if (mb % 1024 === 0) return (mb / 1024) + ' GB';
    return mb + ' MB';
}
function _fmtDiskInput(gb) {
    if (gb < 0) return String(gb);
    if (gb === 0) return '0';
    if (gb >= 1024 && gb % 1024 === 0) return (gb / 1024) + ' TB';
    return gb + ' GB';
}
function parseMemoryInput(str) {
    str = String(str).trim();
    if (str === '-1') return -1;
    if (!str) return NaN;
    const m = str.match(/^(\d+(?:\.\d+)?)\s*(tb|gb|mb|kb|t|g|m)?$/i);
    if (!m) return NaN;
    const num = parseFloat(m[1]);
    const u = (m[2] || 'gb').toLowerCase(); // 단위 없으면 GB 기본
    if (u === 'tb' || u === 't') return Math.round(num * 1024 * 1024);
    if (u === 'gb' || u === 'g') return Math.round(num * 1024);
    if (u === 'mb' || u === 'm') return Math.round(num);
    if (u === 'kb' || u === 'k') return Math.round(num / 1024);
    return Math.round(num * 1024);
}
function parseDiskInput(str) {
    str = String(str).trim();
    if (str === '-1') return -1;
    if (!str) return NaN;
    const m = str.match(/^(\d+(?:\.\d+)?)\s*(tb|gb|mb|t|g|m)?$/i);
    if (!m) return NaN;
    const num = parseFloat(m[1]);
    const u = (m[2] || 'gb').toLowerCase(); // 단위 없으면 GB 기본
    if (u === 'tb' || u === 't') return Math.round(num * 1024);
    if (u === 'mb' || u === 'm') return Math.round(num / 1024);
    return Math.round(num);
}
function _quotaMemHint(str) {
    str = String(str).trim();
    if (str === '-1') return IS_ENGLISH ? 'unlimited' : '무제한';
    if (!str) return '';
    const mb = parseMemoryInput(str);
    if (isNaN(mb)) return '?';
    if (mb < 0) return IS_ENGLISH ? 'unlimited' : '무제한';
    return '= ' + mb + ' MB';
}
function _quotaDiskHint(str) {
    str = String(str).trim();
    if (str === '-1') return IS_ENGLISH ? 'unlimited' : '무제한';
    if (!str) return '';
    const gb = parseDiskInput(str);
    if (isNaN(gb)) return '?';
    if (gb < 0) return IS_ENGLISH ? 'unlimited' : '무제한';
    if (/^[\d.]+\s*(t(?:b)?)\s*$/i.test(str)) return '= ' + gb + ' GB';
    return '';
}

async function loadQuotaManagement() {
    try {
        const res = await api('GET', '/group-quotas');
        const container = document.getElementById('quota-mgmt');
        if (!res.ok || !res.quotas?.length) {
            container.innerHTML = '<p class="text-muted-sm">' + (IS_ENGLISH ? 'No group quotas' : '그룹 할당량 없음') + '</p>';
            return;
        }

    let html = '<table class="data-table text-fs-082"><thead><tr>' +
        '<th>Group</th><th>CPU (used/max)</th><th>Memory (used/max)</th><th>Disk (used/max)</th><th>VMs (used/max)</th><th>Actions</th>' +
        '</tr></thead><tbody>';

    res.quotas.forEach(q => {
        const cpuUsed = q.used.cpuCores + q.pending.cpuCores;
        const memUsed = Math.round((q.used.memoryMb + q.pending.memoryMb) / 1024);
        const diskUsed = q.used.diskGb + q.pending.diskGb;
        const vmUsed = q.used.vmCount + q.pending.vmCount;

        html += '<tr>' +
            '<td><strong>' + q.groupName + '</strong></td>' +
            '<td>' + cpuUsed + ' / <input type="number" value="' + q.quota.maxCpuCores + '" class="quota-input-sm" data-group="' + q.groupId + '" data-field="maxCpuCores"></td>' +
            '<td>' + memUsed + 'GB / <input type="text" value="' + _fmtMemInput(q.quota.maxMemoryMb) + '" class="quota-input-md" data-group="' + q.groupId + '" data-field="maxMemoryMb" placeholder="e.g. 16 GB"><span class="quota-hint"></span></td>' +
            '<td>' + diskUsed + 'GB / <input type="text" value="' + _fmtDiskInput(q.quota.maxDiskGb) + '" class="quota-input-md" data-group="' + q.groupId + '" data-field="maxDiskGb" placeholder="e.g. 100 GB"><span class="quota-hint"></span></td>' +
            '<td>' + vmUsed + ' / <input type="number" value="' + q.quota.maxVmCount + '" class="quota-input-sm" data-group="' + q.groupId + '" data-field="maxVmCount"></td>' +
            '<td><button class="btn btn-info btn-xs" onclick="saveGroupQuota(\'' + q.groupId + '\')">' + (IS_ENGLISH ? 'Save' : '저장') + '</button></td>' +
            '</tr>';
    });

    html += '</tbody></table>';
    html += '<p class="footnote">' + (IS_ENGLISH
        ? '-1 = unlimited &nbsp;|&nbsp; Memory/Disk: enter with unit (e.g. <b>16 GB</b>, <b>512 MB</b>, <b>1 TB</b>) or just a number (treated as GB)'
        : '-1 = 무제한 &nbsp;|&nbsp; Memory/Disk: 단위 포함 입력 (예: <b>16 GB</b>, <b>512 MB</b>, <b>1 TB</b>) 또는 숫자만 입력 시 GB로 처리') + '</p>';
    container.innerHTML = html;

    container.querySelectorAll('input[data-field="maxMemoryMb"]').forEach(inp => {
        const hint = inp.nextElementSibling;
        if (hint) hint.textContent = _quotaMemHint(inp.value);
        inp.addEventListener('input', function() { if (hint) hint.textContent = _quotaMemHint(this.value); });
    });
    container.querySelectorAll('input[data-field="maxDiskGb"]').forEach(inp => {
        const hint = inp.nextElementSibling;
        if (hint) hint.textContent = _quotaDiskHint(inp.value);
        inp.addEventListener('input', function() { if (hint) hint.textContent = _quotaDiskHint(this.value); });
    });
    } catch (e) {
        const container = document.getElementById('quota-mgmt');
        container.innerHTML = '<p class="text-danger-sm"><i class="ti ti-alert-circle inline-ti" aria-hidden="true"></i>' + (IS_ENGLISH ? 'Load failed: ' : '불러오기 실패: ') + e.message + '</p>';
    }
}

async function saveGroupQuota(groupId) {
    const inputs = document.querySelectorAll('input[data-group="' + groupId + '"]');
    const data = {};
    inputs.forEach(inp => {
        if (inp.dataset.field === 'maxMemoryMb') data[inp.dataset.field] = parseMemoryInput(inp.value);
        else if (inp.dataset.field === 'maxDiskGb') data[inp.dataset.field] = parseDiskInput(inp.value);
        else data[inp.dataset.field] = parseInt(inp.value);
    });
    if (Object.values(data).some(v => isNaN(v))) {
        showArToast(IS_ENGLISH ? 'Invalid input value.' : '입력값이 올바르지 않습니다.', 'error');
        return;
    }

    try {
        const res = await api('PUT', '/group-quotas/' + groupId, data);
        if (!res.ok) throw new Error(res.error || 'Failed');
        showAlert(IS_ENGLISH ? 'Quota saved.' : '할당량이 저장되었습니다.', 'success');
        loadQuotaManagement();
    } catch (e) {
        showAlert((IS_ENGLISH ? 'Save failed: ' : '저장 실패: ') + e.message, 'error');
    }
}

function initAuditDatePickers() {
    if (typeof flatpickr !== 'function') return;
    const pickerCommon = {
        enableTime: true,
        time_24hr: true,
        dateFormat: 'Y-m-d\\TH:i',
        altInput: true,
        altFormat: 'Y-m-d H:i',
    };
    if (typeof confirmDatePlugin === 'function') {
        pickerCommon.plugins = [new confirmDatePlugin({ confirmText: '확인', showAlways: false })];
    }

    flatpickr('#audit-filter-from', {
        ...pickerCommon
    });
    flatpickr('#audit-filter-to', {
        ...pickerCommon
    });
}

function initAuditFilterEnterHandlers() {
    if (window.__auditEnterBound) return;
    window.__auditEnterBound = true;

    document.addEventListener('keydown', (e) => {
        if (e.isComposing) return;
        if (e.key !== 'Enter' && e.code !== 'NumpadEnter') return;

        const target = e.target;
        if (!target || !target.closest || !target.closest('#tab-audit')) return;

        const id = target.id || '';
        const directMatch = (
            id === 'audit-filter-from' ||
            id === 'audit-filter-to' ||
            id === 'audit-filter-user' ||
            id === 'audit-filter-action' ||
            id === 'audit-filter-result' ||
            id === 'auditResultBtn' ||
            id === 'audit-filter-ip'
        );

        const fpInputId = target._flatpickr?.input?.id || '';
        const flatpickrMatch = (fpInputId === 'audit-filter-from' || fpInputId === 'audit-filter-to');

        if (!directMatch && !flatpickrMatch) return;

        e.preventDefault();
        applyAuditFilters();
    });
}

