            color: var(--tpl-muted, #64748b); margin-bottom: 0.4rem; letter-spacing: 0.02em;
        }
        .ptm-otp-input {
            width: 100%; font-size: 1.6rem; text-align: center; letter-spacing: 0.4em;
            font-family: 'Courier New', monospace; padding: 0.55rem 0.75rem;
            border-radius: 8px; border: 1px solid var(--tpl-border, #e2e8f0);
            background: var(--tpl-surface-soft, #f8fafc); color: var(--tpl-text, #1e293b);
            box-sizing: border-box; transition: border-color 0.2s, box-shadow 0.2s; outline: none;
        }
        .ptm-otp-input:focus {
            border-color: var(--tpl-accent, #3b82f6);
            box-shadow: 0 0 0 3px rgba(var(--tpl-accent-rgb, 59,130,246), 0.14);
        }
        .ptm-error { font-size: 0.8rem; color: #dc2626; min-height: 1.3em; margin: 0.45rem 0 0; }
        .ptm-btn-row { display: flex; gap: 0.5rem; margin-top: 1rem; }
        .ptm-btn-primary {
            flex: 1; padding: 0.55rem 1rem; border: none; border-radius: 8px;
            font-size: 0.875rem; font-weight: 600; cursor: pointer;
            background: var(--tpl-accent, #3b82f6); color: #fff; transition: opacity 0.2s;
        }
        .ptm-btn-primary:disabled { opacity: 0.5; cursor: not-allowed; }
        .ptm-btn-cancel {
            padding: 0.55rem 1rem; border-radius: 8px; font-size: 0.875rem; font-weight: 500;
            cursor: pointer; background: none; transition: color 0.2s, border-color 0.2s;
            border: 1px solid var(--tpl-border, #e2e8f0); color: var(--tpl-muted, #64748b);
        }
        .ptm-btn-cancel:hover { color: var(--tpl-text, #1e293b); border-color: var(--tpl-accent, #3b82f6); }
        .ptm-field { margin-bottom: 0.75rem; }
        .ptm-field-value {
            display: flex; align-items: center; gap: 0.5rem; padding: 0.5rem 0.75rem;
            border-radius: 8px; background: var(--tpl-accent-soft, #eff6ff);
            border: 1px solid var(--tpl-border, #bfdbfe);
            font-size: 0.8rem; font-family: 'Courier New', monospace;
            color: var(--tpl-accent, #3b82f6); word-break: break-all;
        }
        .ptm-field-value span { flex: 1; }
        .ptm-copy-btn {
            flex-shrink: 0; background: none; border: none; cursor: pointer;
            padding: 0.15rem 0.4rem; border-radius: 4px; font-size: 0.82rem;
            color: var(--tpl-muted, #64748b); transition: color 0.2s, background 0.2s;
        }
        .ptm-copy-btn:hover { color: var(--tpl-accent, #3b82f6); background: var(--tpl-accent-soft, #eff6ff); }
        .ptm-timer-wrap { margin-top: 1rem; }
        .ptm-timer-label { font-size: 0.75rem; color: var(--tpl-muted, #64748b); margin-bottom: 0.35rem; }
        .ptm-timer-bar { height: 4px; background: var(--tpl-border, #e2e8f0); border-radius: 99px; overflow: hidden; }
        .ptm-timer-fill { height: 100%; background: #dc2626; border-radius: 99px; transition: width 1s linear; }
        .modal.modal-wide {
            width: min(92vw, 960px);
            max-height: 92vh;
            text-align: left;
        }
        .modal h3 { margin-bottom: 1rem; font-size: 1.1rem; }
        .modal .form-group { margin-bottom: 0.8rem; }
        .confirm-message {
            margin-bottom: 1rem;
            color: #475569;
            font-size: 0.9rem;
            line-height: 1.5;
            white-space: pre-line;
        }
        body.theme-template-proxmox #themeConfirmModal .confirm-message {
            color: #7b6656;
        }
        body.theme-template-proxmox #themeConfirmModal .modal {
            background: #fffaf4;
            border: 1px solid #e6ddd1;
            color: #2a1b11;
        }
        body.theme-template-proxmox #themeConfirmModal {
            background: rgba(42, 27, 17, 0.28);
        }
        body.theme-template-indigo #themeConfirmModal .modal {
            background: #eef2ff;
            border: 1px solid #c7d2fe;
            color: #312e81;
        }
        body.theme-template-indigo #themeConfirmModal .confirm-message {
            color: #4338ca;
        }
        /* Modal inputs: full width for text-like fields, but not for checkboxes/radios. */
        .modal .form-group input:not([type="checkbox"]):not([type="radio"]),
        .modal .form-group select,
        .modal .form-group textarea { width: 100%; min-width: 0; max-width: 100%; }
        .modal .form-group input[type="checkbox"],
        .modal .form-group input[type="radio"] { width: auto; max-width: none; }
        .modal .btn-row { display: flex; gap: 0.5rem; justify-content: flex-end; margin-top: 1.5rem; }

        .mono { font-family: 'Consolas', 'Monaco', monospace; }

        .password-generate {
            display: inline-block;
            margin-left: 0.5rem;
            padding: 0.3rem 0.6rem;
            background: #f1f5f9;
            color: #475569;
            border: 1px solid #cbd5e1;
