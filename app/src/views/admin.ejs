function filterUIStrings(searchTerm) {
    // Simple filter implementation: highlight matching lines
    const editor = document.getElementById('uiStringsEditor');
    const content = editor.value;

    if (!searchTerm.trim()) {
        // No search term, just reload without filter
        return;
    }

    try {
        const parsed = JSON.parse(content);
        const searchLower = searchTerm.toLowerCase();

        // Find matching paths
        const matches = [];
        function search(obj, path = []) {
            for (const key in obj) {
                const value = obj[key];
                const currentPath = [...path, key];

                if (typeof value === 'string') {
                    if (key.toLowerCase().includes(searchLower) ||
                        value.toLowerCase().includes(searchLower)) {
                        matches.push({
                            path: currentPath.join('.'),
                            value: value
                        });
                    }
                } else if (typeof value === 'object' && value !== null) {
                    search(value, currentPath);
                }
            }
        }

        search(parsed);

        if (matches.length > 0) {
            console.log(`[UI Strings Filter] Found ${matches.length} matches for "${searchTerm}":`, matches);
            showAlert(`"${searchTerm}"과 일치하는 항목 ${matches.length}개를 찾았습니다 (콘솔 참조)`, 'info');
        } else {
            showAlert(`"${searchTerm}"과 일치하는 항목이 없습니다`, 'info');
        }
    } catch (e) {
        // JSON parse error, ignore
    }
}

