        .quota-input-md::-webkit-inner-spin-button,
        .ar-modern-input[type="number"]::-webkit-outer-spin-button,
        .ar-modern-input[type="number"]::-webkit-inner-spin-button {
            -webkit-appearance: none !important;
            appearance: none !important;
            margin: 0 !important;
        }
        /* Inline form-group variants (must come after `.form-group` to override direction) */
        .form-group.form-group-inline { flex-direction: row; align-items: center; gap: 0.5rem; }
        .form-group.form-group-inline-tight { flex-direction: row; align-items: center; gap: 0.5rem; justify-content: flex-start; flex-wrap: nowrap; }
        .form-group.form-group-inline-tight .label-sm { white-space: nowrap; }

        /* Group cards */
        .group-card { padding: 1rem 1.5rem; border-bottom: 1px solid #f1f5f9; }
        .group-card:last-child { border-bottom: none; }
        .group-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 0.5rem; }
        .group-header strong { font-size: 0.95rem; }
        .group-stats { display: flex; gap: 0.5rem; font-size: 0.8rem; color: #64748b; }
        .member-list { display: flex; flex-wrap: wrap; gap: 0.4rem; margin-top: 0.5rem; }
        .member-chip {
            display: inline-flex; align-items: center; gap: 0.3rem;
            padding: 0.2rem 0.6rem; background: #f1f5f9; border-radius: 999px;
            font-size: 0.8rem; color: #334155;
        }
        .member-chip .remove { cursor: pointer; color: #94a3b8; font-weight: bold; margin-left: 0.2rem; }
        .member-chip .remove:hover { color: #ef4444; }

        /* Pagination */
        .pagination { display: flex; justify-content: center; gap: 0.5rem; padding: 1rem; }
        .pagination button { min-width: 36px; }

        /* Alert */
        .alert { padding: 0.8rem 1.5rem; font-size: 0.85rem; border-radius: 6px; margin-bottom: 1rem; display: none; }
        .alert-success { background: #dcfce7; color: #166534; border: 1px solid #bbf7d0; }
        .alert-error { background: #fee2e2; color: #991b1b; border: 1px solid #fecaca; }

        /* Toast */
        #ar-toast-container { position: fixed; bottom: 1.5rem; right: 1.5rem; z-index: 9999; display: flex; flex-direction: column-reverse; gap: 0.6rem; pointer-events: none; }
        .ar-toast {
            display: flex; align-items: flex-start; gap: 0.7rem;
            min-width: 260px; max-width: 380px;
            padding: 0.85rem 1rem; border-radius: 10px;
            box-shadow: 0 8px 24px rgba(15,23,42,0.14), 0 2px 6px rgba(15,23,42,0.08);
            font-size: 0.875rem; line-height: 1.45; font-weight: 500;
            pointer-events: auto;
            backdrop-filter: blur(14px) saturate(150%);
            -webkit-backdrop-filter: blur(14px) saturate(150%);
            animation: ar-toast-in 0.22s cubic-bezier(0.34,1.56,0.64,1) both;
        }
        .ar-toast.hiding { animation: ar-toast-out 0.2s ease-in both; }
        .ar-toast-icon { font-size: 1.15rem; flex-shrink: 0; margin-top: 0.05rem; }
        .ar-toast-body { flex: 1; }
        .ar-toast-title { font-weight: 700; margin-bottom: 0.1rem; }
        .ar-toast-msg { font-weight: 400; font-size: 0.82rem; opacity: 0.85; }
        .ar-toast.emphasis .ar-toast-title { display: none; }
        .ar-toast.emphasis .ar-toast-msg { font-weight: 700; font-size: 0.96rem; opacity: 1; }
        .ar-toast.success { background: var(--ar-toast-success-bg); border: 1px solid var(--ar-toast-success-border); color: var(--ar-toast-success-text); }
        .ar-toast.success .ar-toast-icon { color: var(--ar-toast-success-icon); }
        .ar-toast.error   { background: var(--ar-toast-error-bg); border: 1px solid var(--ar-toast-error-border); color: var(--ar-toast-error-text); }
        .ar-toast.error   .ar-toast-icon { color: var(--ar-toast-error-icon); }
        .ar-toast.warning { background: var(--ar-toast-warning-bg); border: 1px solid var(--ar-toast-warning-border); color: var(--ar-toast-warning-text); }
        .ar-toast.warning .ar-toast-icon { color: var(--ar-toast-warning-icon); }
        .ar-toast.info    { background: var(--ar-toast-info-bg); border: 1px solid var(--ar-toast-info-border); color: var(--ar-toast-info-text); }
        .ar-toast.info    .ar-toast-icon { color: var(--ar-toast-info-icon); }
        body.theme-template-proxmox .ar-toast,
        body.theme-template-dark .ar-toast,
        body.theme-template-indigo .ar-toast {
            backdrop-filter: blur(12px);
        }
        @keyframes ar-toast-in  { from { opacity:0; transform:translateY(12px) scale(0.95); } to { opacity:1; transform:none; } }
        @keyframes ar-toast-out { from { opacity:1; transform:none; } to { opacity:0; transform:translateY(8px) scale(0.96); } }

        /* Modal */
        .modal-overlay {
            display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%;
            background: rgba(15,23,42,0.6); z-index: 1000; justify-content: center; align-items: center;
        }
        .modal-overlay.active { display: flex; }
        .modal {
            background: white; border-radius: 12px; padding: 2rem; width: min(92vw, 400px);
            max-height: 90vh; overflow-y: auto; overflow-x: hidden;
            box-shadow: 0 20px 60px rgba(0,0,0,0.3);
        }
        /* PVE 토큰 모달 */
        .pve-token-modal { width: min(92vw, 400px); padding: 0; }
        .pve-token-modal .ptm-header {
            display: flex; align-items: center; justify-content: space-between;
            padding: 0.9rem 1.25rem; border-bottom: 1px solid var(--tpl-border, #e2e8f0);
        }
        .pve-token-modal .ptm-header h3 {
            margin: 0; font-size: 0.92rem; font-weight: 600;
            color: var(--tpl-text, #1e293b);
        }
        .ptm-close {
            background: none; border: none; cursor: pointer; font-size: 1rem; line-height: 1;
            color: var(--tpl-muted, #64748b); padding: 0.25rem 0.4rem; border-radius: 4px; transition: color 0.2s;
        }
        .ptm-close:hover { color: var(--tpl-text, #1e293b); }
        .ptm-body { padding: 1.25rem; }
        .ptm-info-box {
            display: flex; align-items: flex-start; gap: 0.6rem;
            padding: 0.7rem 0.9rem; border-radius: 8px; margin-bottom: 1rem;
            font-size: 0.82rem; line-height: 1.55; color: var(--tpl-muted, #64748b);
            background: var(--tpl-surface-soft, #f8fafc); border: 1px solid var(--tpl-border, #e2e8f0);
        }
        .ptm-info-box.ptm-warn {
            background: rgba(220,38,38,0.06); border-color: rgba(220,38,38,0.22); color: #dc2626;
        }
        .ptm-info-box svg { flex-shrink: 0; margin-top: 0.15rem; }
        .ptm-label {
