        }
        .form-group { display: flex; flex-direction: column; gap: 0.3rem; }
        .form-group label { font-size: 0.78rem; font-weight: 500; color: #64748b; }
        .form-group input, .form-group select {
            padding: 0.5rem 0.7rem; border: 1px solid #e2e8f0; border-radius: 4px;
            font-size: 0.85rem; outline: none; min-width: 180px;
        }
        /* Do not apply "text input" sizing to checkboxes/radios (breaks inline layouts). */
        .form-group input[type="checkbox"],
        .form-group input[type="radio"] {
            min-width: auto;
            width: auto;
            height: auto;
            padding: 0;
            border-radius: 0;
        }
        .form-group input:focus, .form-group select:focus { border-color: var(--tpl-accent); }
        /* VM 요청 승인/쿼터/로그 모달: 네이티브 셀렉트/넘버 컨트롤 스킨 통일 */
        #vmreqApproveModal select,
        #vmreqQuotaModal select,
        #vmreqRejectModal select,
        #vmreqLogModal select {
            background: rgba(12, 20, 40, 0.92);
            border-color: rgba(148, 163, 184, 0.36);
