let _rejectReasonResolver = null;

function openRejectReasonModal() {
    const modal = document.getElementById('vmreqRejectModal');
    const input = document.getElementById('vmreq-reject-note');
    const errEl = document.getElementById('vmreq-reject-error');
    if (!modal || !input || !errEl) {
        showAlert(IS_ENGLISH ? 'Reject modal is unavailable.' : '반려 모달을 불러오지 못했습니다.', 'error');
        return Promise.resolve(null);
    }
    input.value = '';
    errEl.style.display = 'none';
    errEl.textContent = '';
    modal.classList.add('active');
    setTimeout(() => input.focus(), 0);
    return new Promise((resolve) => {
        _rejectReasonResolver = resolve;
    });
}

function closeRejectReasonModal(result) {
    const modal = document.getElementById('vmreqRejectModal');
    if (modal) modal.classList.remove('active');
    if (_rejectReasonResolver) {
        const resolve = _rejectReasonResolver;
        _rejectReasonResolver = null;
        resolve(result);
    }
}

function submitRejectReasonModal() {
    const input = document.getElementById('vmreq-reject-note');
    const errEl = document.getElementById('vmreq-reject-error');
    const note = (input?.value || '').trim();
    if (!note) {
        if (errEl) {
            errEl.textContent = IS_ENGLISH ? 'Please enter a rejection reason.' : '반려 사유를 입력하세요.';
            errEl.style.display = 'block';
        }
        input?.focus();
        return;
    }
    closeRejectReasonModal(note);
}

document.addEventListener('click', function(e) {
