                        <label><%= uuidLabels?.notifications?.['ntf-006'] || 'Webhook URL' %></label>
                        <input type="url" id="teams-webhookUrl" placeholder="https://outlook.office.com/webhook/...">
                        <small class="text-note"><%= uuidLabels?.notifications?.['ntf-008'] || 'Enter your Teams Incoming Webhook URL' %></small>
                    </div>
                    <div class="form-group mb-1">
                        <label><%= isEnglish ? 'Notification Events' : '알림 이벤트' %></label>
                        <div id="teams-events" class="stack-sm"></div>
                        <small class="text-note"><%= isEnglish ? 'Select events to deliver to Teams.' : 'Teams로 받을 이벤트를 선택하세요.' %></small>
                    </div>
                    <div class="form-actions">
                        <% if (saveTeamsBtn) { %>
                            <button type="submit" class="<%= saveTeamsBtn.css_class || 'btn btn-primary' %>"><%= stripLeadingIconText(saveTeamsBtn.display_name) %></button>
                        <% } else { %>
                            <button type="submit" class="btn btn-primary"><%= uuidLabels?.buttonCommon?.['btn-cmn-004'] || 'Save' %></button>
                        <% } %>
                        <button type="button" id="testTeamsBtn" class="<%= testTeamsBtn?.css_class || 'btn btn-secondary' %>"><%= stripLeadingIconText(testTeamsBtn?.display_name || 'Test') %></button>
                        <span id="teams-msg" class="inline-save-msg"></span>
                    </div>
                </form>
            </div>
        </div>

        <!-- Email -->
        <div class="section notification-accordion-item">
            <div class="section-header">
                <span><%= uuidLabels?.notifications?.['ntf-003'] || 'Email Notifications' %></span>
                <div class="toggle-wrap">
                    <span class="toggle-state off" id="email-enabled-status"><%= isEnglish ? 'Disabled' : '비활성화' %></span>
                    <label class="toggle-switch">
                        <span class="sr-only"><%= uuidLabels?.notifications?.['ntf-005'] || 'Enable Notifications' %></span>
                        <input type="checkbox" id="email-enabled">
                        <span class="toggle-slider" aria-hidden="true"></span>
                    </label>
                </div>
            </div>
            <div class="section-body">
                <form id="emailForm">
                    <div class="form-group mb-1">
                        <label><%= isEnglish ? 'SMTP Presets' : 'SMTP 프리셋' %></label>
                        <input type="hidden" id="email-provider" value="custom">
                        <div class="btn-row wrap" id="email-smtp-presets">
                            <button type="button" class="btn btn-secondary btn-sm" data-provider="gmail" data-smtp-host="smtp.gmail.com" data-smtp-port="587">Gmail</button>
                            <button type="button" class="btn btn-secondary btn-sm" data-provider="naver" data-smtp-host="smtp.naver.com" data-smtp-port="465">Naver</button>
                            <button type="button" class="btn btn-secondary btn-sm" data-provider="kakao" data-smtp-host="smtp.kakao.com" data-smtp-port="465">Kakao</button>
                            <button type="button" class="btn btn-secondary btn-sm" data-provider="daum" data-smtp-host="smtp.daum.net" data-smtp-port="465">Daum</button>
                            <button type="button" class="btn btn-secondary btn-sm" data-provider="custom"><%= isEnglish ? 'Custom' : '직접 입력' %></button>
                        </div>
                        <small class="text-note"><%= isEnglish ? 'Click a provider to fill SMTP host and port automatically. For Office365, use Custom with smtp.office365.com / 587.' : '메일 서비스 버튼을 누르면 SMTP 호스트와 포트가 자동 입력됩니다. Office365는 직접 입력에서 smtp.office365.com / 587 을 사용하세요.' %></small>
                    </div>
                    <div class="form-group mb-1" id="email-smtpHost-wrap">
                        <label><%= uuidLabels?.formLabels?.['lbl-016'] || 'SMTP Host' %></label>
                        <input type="text" id="email-smtpHost" placeholder="<%= uuidLabels?.placeholders?.['ph-010'] || 'smtp.example.com' %>">
                    </div>
                    <div class="form-group mb-1" id="email-smtpPort-wrap">
                        <label><%= uuidLabels?.formLabels?.['lbl-017'] || 'SMTP Port' %></label>
                        <input type="number" id="email-smtpPort" placeholder="<%= uuidLabels?.placeholders?.['ph-011'] || '465 or 587' %>">
                    </div>
                    <div class="form-group mb-1">
                        <label><%= uuidLabels?.formLabels?.['lbl-018'] || 'SMTP User' %></label>
                        <input type="text" id="email-smtpUser" placeholder="<%= uuidLabels?.placeholders?.['ph-012'] || 'your-email@example.com' %>">
                    </div>
                    <div class="form-group mb-1">
                        <label><%= uuidLabels?.formLabels?.['lbl-019'] || 'SMTP Password' %></label>
                        <input type="password" id="email-smtpPassword" placeholder="<%= uuidLabels?.placeholders?.['ph-013'] || '????????' %>">
                    </div>
                    <div class="form-group mb-1">
                        <label><%= uuidLabels?.formLabels?.['lbl-020'] || 'From Address' %></label>
                        <input type="email" id="email-from" placeholder="<%= uuidLabels?.placeholders?.['ph-014'] || 'noreply@example.com' %>">
                    </div>
                    <div class="form-group mb-1">
                        <label><%= uuidLabels?.formLabels?.['lbl-021'] || 'To Addresses' %></label>
                        <input type="text" id="email-to" placeholder="<%= uuidLabels?.placeholders?.['ph-015'] || 'admin1@example.com, admin2@example.com' %>">
                        <small class="text-note"><%= uuidLabels?.notifications?.['ntf-010'] || 'Separate multiple addresses with commas' %></small>
                    </div>
                    <div class="form-group mb-1">
                        <label><%= isEnglish ? 'Notification Events' : '알림 이벤트' %></label>
                        <div id="email-events" class="stack-sm"></div>
                        <small class="text-note"><%= isEnglish ? 'Select events to deliver via Email.' : '이메일로 받을 이벤트를 선택하세요.' %></small>
                    </div>
                    <div class="form-actions">
                        <% if (saveEmailBtn) { %>
                            <button type="submit" class="<%= saveEmailBtn.css_class || 'btn btn-primary' %>"><%= stripLeadingIconText(saveEmailBtn.display_name) %></button>
                        <% } else { %>
                            <button type="submit" class="btn btn-primary"><%= uuidLabels?.buttonCommon?.['btn-cmn-004'] || 'Save' %></button>
                        <% } %>
                        <button type="button" id="testEmailBtn" class="<%= testEmailBtn?.css_class || 'btn btn-secondary' %>"><%= stripLeadingIconText(testEmailBtn?.display_name || 'Test') %></button>
                        <span id="email-msg" class="inline-save-msg"></span>
                    </div>
                </form>
            </div>
        </div>

        <!-- Custom Webhook -->
        <div class="section notification-accordion-item">
            <div class="section-header">
                <span><%= uuidLabels?.notifications?.['ntf-004'] || 'Custom Webhook' %></span>
                <div class="toggle-wrap">
                    <span class="toggle-state off" id="webhook-enabled-status"><%= isEnglish ? 'Disabled' : '비활성화' %></span>
                    <label class="toggle-switch">
                        <span class="sr-only"><%= uuidLabels?.notifications?.['ntf-005'] || 'Enable Notifications' %></span>
                        <input type="checkbox" id="webhook-enabled">
                        <span class="toggle-slider" aria-hidden="true"></span>
                    </label>
                </div>
            </div>
            <div class="section-body">
                <form id="webhookForm">
                    <div class="form-group mb-1">
                        <label><%= uuidLabels?.formLabels?.['lbl-022'] || 'Webhook URL' %></label>
                        <input type="url" id="webhook-url" placeholder="<%= uuidLabels?.placeholders?.['ph-009'] || 'https://your-server.com/webhook' %>">
                    </div>
                    <div class="form-group mb-1">
                        <label><%= uuidLabels?.formLabels?.['lbl-023'] || 'Custom Headers (JSON)' %></label>
                        <textarea id="webhook-headers" rows="3" class="text-note" placeholder="<%= uuidLabels?.placeholders?.['ph-016'] || '{&quot;Authorization&quot;: &quot;Bearer token&quot;}' %>"></textarea>
                        <small class="text-note"><%= uuidLabels?.notifications?.['ntf-009'] || 'Optional: Custom HTTP headers as JSON object' %></small>
                    </div>
                    <div class="form-group mb-1">
                        <label><%= isEnglish ? 'Notification Events' : '알림 이벤트' %></label>
                        <div id="webhook-events" class="stack-sm"></div>
                        <small class="text-note"><%= isEnglish ? 'Select events to deliver to custom webhook.' : 'Webhook으로 받을 이벤트를 선택하세요.' %></small>
                    </div>
                    <div class="form-actions">
                        <% if (saveWebhookBtn) { %>
                            <button type="submit" class="<%= saveWebhookBtn.css_class || 'btn btn-primary' %>"><%= stripLeadingIconText(saveWebhookBtn.display_name) %></button>
                        <% } else { %>
                            <button type="submit" class="btn btn-primary"><%= uuidLabels?.buttonCommon?.['btn-cmn-004'] || 'Save' %></button>
                        <% } %>
                        <button type="button" id="testWebhookBtn" class="<%= testWebhookBtn?.css_class || 'btn btn-secondary' %>"><%= stripLeadingIconText(testWebhookBtn?.display_name || 'Test') %></button>
                        <span id="webhook-msg" class="inline-save-msg"></span>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <!-- ========== SECURITY POLICY TAB ========== -->
    <div id="tab-password-policy" class="tab-content" data-menu-key="PASSWORD_POLICY">
        <div class="section">
            <div class="section-header"><span><%= sectionLabels?.admin?.password_policy?.title || (isEnglish ? 'Security Policy' : '보안 정책') %></span></div>
            <div class="section-body">
                <div class="security-policy-grid">
                <div class="security-policy-card">
                    <div class="security-policy-card-header" onclick="toggleSecurityPolicyCard(this)">
                        <h3 class="security-policy-card-title">
                            <i class="ti ti-shield-lock"></i>
                            <%= isEnglish ? 'Proxmox Horizon Security Policy' : 'Proxmox Horizon 보안 정책' %>
                        </h3>
                        <i class="ti ti-chevron-down security-policy-card-toggle-icon" aria-hidden="true"></i>
                    </div>
                    <div class="security-policy-card-body">
                <div class="security-policy-forms-grid">
                <div class="ar-vr-card">
                    <div class="ar-card-section-title">
                        <i class="ti ti-lock-password"></i>
                        <%= isEnglish ? 'Password Policy' : '비밀번호 보안 정책' %>
                    </div>
                    <form id="passwordPolicyForm">
                    <div style="display:grid; grid-template-columns:1fr 1fr; gap:1rem; align-items:start;">
                        <div>
                            <div class="form-group mb-1">
                                <label><%= uuidLabels?.formLabels?.['lbl-024'] || 'Password Expiry (days)' %></label>
                                <input type="number" id="policy-expiryDays" min="0" required>
                                <small class="text-note"><%= uuidLabels?.notifications?.['ntf-011'] || 'Set to 0 to disable expiry' %></small>
                            </div>
                            <div class="form-group mb-1">
                                <label><%= uuidLabels?.formLabels?.['lbl-025'] || 'Warning Period (days)' %></label>
                                <input type="number" id="policy-warningDays" min="0" required>
                                <small class="text-note"><%= uuidLabels?.notifications?.['ntf-012'] || 'Days before expiry to show warning' %></small>
                            </div>
                            <div class="form-group mb-1">
                                <label><%= uuidLabels?.formLabels?.['lbl-026'] || 'Minimum Length' %></label>
                                <input type="number" id="policy-minLength" min="1" max="32" required>
                            </div>
                        </div>
                        <div>
                            <div class="stack-sm" style="margin-top:0.2rem;">
                                <label class="check-label">
                                    <input type="checkbox" id="policy-requireUppercase">
                                    <%= uuidLabels?.formLabels?.['lbl-027'] || 'Require uppercase letters' %>
                                </label>
                                <label class="check-label">
                                    <input type="checkbox" id="policy-requireLowercase">
                                    <%= uuidLabels?.formLabels?.['lbl-028'] || 'Require lowercase letters' %>
                                </label>
                                <label class="check-label">
                                    <input type="checkbox" id="policy-requireNumbers">
                                    <%= uuidLabels?.formLabels?.['lbl-029'] || 'Require numbers' %>
                                </label>
                                <label class="check-label">
                                    <input type="checkbox" id="policy-requireSpecialChars">
                                    <%= uuidLabels?.formLabels?.['lbl-030'] || 'Require special characters (!@#$%^&* etc.)' %>
                                </label>
                            </div>
                        </div>
                    </div>
                    <%
                    const policyButtons = sectionLabels?.admin?.password_policy?.buttons || [];
                    const savePolicyBtn = policyButtons.find(b => b.button_key === 'SAVE_POLICY' && b.is_visible);
                    %>
                    <div style="display:flex; align-items:center; gap:0.7rem; flex-wrap:wrap; margin-top:1rem;">
                        <% if (savePolicyBtn) { %>
                            <button type="submit" class="<%= savePolicyBtn.css_class || 'btn btn-primary' %>"><%= stripLeadingIconText(savePolicyBtn.display_name) %></button>
                        <% } else { %>
                            <button type="submit" class="btn btn-primary"><%= uuidLabels?.buttonCommon?.['btn-cmn-004'] || 'Save' %></button>
                        <% } %>
                        <span id="policy-msg" class="inline-save-msg"></span>
                    </div>
                    </form>
                </div>

                <div class="ar-vr-card">
                    <div class="ar-card-section-title">
                        <i class="ti ti-clock-shield"></i>
                        <%= isEnglish ? 'Session Policy' : '세션 보안 정책' %>
                    </div>
                    <form id="sessionPolicyForm">
                        <div class="form-group mb-1">
                            <label><%= isEnglish ? 'Session Max Lifetime (hours)' : '세션 최대 유지시간 (시간)' %></label>
                            <input type="number" id="session-maxHours" min="1" max="24" required>
                            <small class="text-note"><%= isEnglish ? 'Applied to newly issued sessions after save.' : '저장 후 신규 발급 세션부터 적용됩니다.' %></small>
                        </div>
                        <div class="form-group mb-1">
                            <label><%= isEnglish ? 'Idle Timeout (minutes)' : '유휴 타임아웃 (분)' %></label>
                            <input type="number" id="session-idleMinutes" min="5" max="240" required>
                            <small class="text-note"><%= isEnglish ? 'Auto logout if no activity for this period.' : '해당 시간 동안 활동이 없으면 자동 로그아웃됩니다.' %></small>
                        </div>
                        <div style="display:flex; align-items:center; gap:0.7rem; flex-wrap:wrap; margin-top:1rem;">
                            <button type="submit" class="btn btn-primary"><%= isEnglish ? 'Save Session Policy' : '세션 정책 저장' %></button>
                            <span id="session-policy-msg" class="inline-save-msg"></span>
                        </div>
                    </form>
                </div>
                </div><!-- /.security-policy-forms-grid -->
                </div>
                </div>

                <div class="security-policy-card">
                    <div class="security-policy-card-header" onclick="toggleSecurityPolicyCard(this)">
                        <h3 class="security-policy-card-title">
                            <i class="ti ti-key"></i>
                            <%= isEnglish ? 'VM Security Policy' : 'VM 보안 정책' %>
                        </h3>
                        <i class="ti ti-chevron-down security-policy-card-toggle-icon" aria-hidden="true"></i>
                    </div>
                    <div class="security-policy-card-body">
                <!-- 키 교체 권한 정책 -->
                <div style="margin-top:0; padding-top:0; border-top:0;">
                    <h3 class="security-subsection-title" style="font-size:1rem; font-weight:600; margin-bottom:0.75rem;">
                        <%= isEnglish ? 'Key / Password Rotation Permission' : '키·비밀번호 교체 권한' %>
                    </h3>
                    <p style="font-size:0.85rem; color:var(--text-muted,#6b7280); margin-bottom:1rem;">
                        <%= isEnglish
                            ? 'Choose who can rotate SSH keys and Windows passwords.'
                            : 'SSH 키 및 Windows 비밀번호 교체를 허용할 대상을 설정합니다.' %>
                    </p>
                    <div style="display:flex; gap:1rem; align-items:center; flex-wrap:wrap; margin-bottom:0.85rem;">
                        <label style="display:flex; align-items:center; gap:0.5rem; cursor:pointer;">
                            <input type="radio" name="keyRotateMode" value="admin_only" id="krm-admin-only">
                            <span>
                                <strong><%= isEnglish ? 'Admins only' : '관리자' %></strong>
                                <span style="font-size:0.8rem; color:var(--text-muted,#6b7280); margin-left:0.25rem;">
                                    (<%= isEnglish ? 'default' : '기본값' %>)
                                </span>
                            </span>
                        </label>
                        <label style="display:flex; align-items:center; gap:0.5rem; cursor:pointer;">
                            <input type="radio" name="keyRotateMode" value="group_member" id="krm-group-member">
                            <span>
                                <strong><%= isEnglish ? 'Group members allowed' : '일반사용자 허용' %></strong>
                                <span style="font-size:0.8rem; color:var(--text-muted,#6b7280); margin-left:0.25rem;">
                                    (<%= isEnglish ? 'members can rotate their own team\'s VMs' : '일반사용자의 SSH-KEY 교체 버튼 활성화' %>)
                                </span>
                            </span>
                        </label>
                    </div>
                    <div style="display:flex; align-items:center; gap:0.7rem; flex-wrap:wrap;">
                        <button type="button" class="btn btn-primary" onclick="saveKeyRotatePolicy()">
                            <%= isEnglish ? 'Save Permissions' : '권한 저장' %>
                        </button>
                        <span id="krm-msg" class="inline-save-msg"></span>
                    </div>
                </div>

                <!-- 자동 교체 스케줄 -->
                <div style="margin-top:2rem; padding-top:1.5rem; border-top:1px solid var(--border-color,#e5e7eb);">
                    <div style="display:flex; align-items:center; gap:0.5rem; margin-bottom:0.4rem;">
                        <i class="ti ti-refresh-alert" style="font-size:1.1rem; color:var(--tpl-accent);"></i>
                        <span class="security-subsection-title" style="font-size:1rem; font-weight:700; color:#1e293b;"><%= isEnglish ? 'Auto-Rotation Schedule' : '자동 교체 스케줄' %></span>
                    </div>
                    <p style="font-size:0.82rem; color:#64748b; margin:0 0 1.1rem; line-height:1.5;">
                        <%= isEnglish ? 'Automatically rotate SSH keys and Windows passwords on a schedule.' : 'SSH 키·Windows 비밀번호를 일정에 따라 자동으로 교체합니다.' %>
                    </p>

                    <!-- 단일 카드 레이아웃 -->
                    <div class="ar-vr-card" id="ar-schedule-card">

                        <!-- 활성화 row (항상 표시) -->
                        <div class="ar-card-section-title" style="margin-bottom:0.65rem;">
                            <i class="ti ti-toggle-right"></i>
                            <%= isEnglish ? 'Enable' : '활성화' %>
                        </div>
                        <label style="display:flex; align-items:center; gap:0.75rem; cursor:pointer; padding-bottom:0.75rem;">
                            <span style="font-size:0.875rem; color:#374151; font-weight:500;"><%= isEnglish ? 'Auto Rotation' : '자동 교체 사용' %></span>
                            <span class="ar-switch" style="margin-left:auto;">
                                <input type="checkbox" id="ar-enabled" onchange="toggleArEnabled()" style="display:none;">
                                <span class="ar-switch-track"><span class="ar-switch-thumb"></span></span>
                            </span>
                        </label>

                        <!-- 슬라이드 상세 영역 (토글 ON 시 펼쳐짐) -->
                        <div id="ar-detail-body" class="collapsed" style="display:none; border-top:1px solid var(--border-color, #e2e8f0);">

                            <!-- 교체 대상 -->
                            <div style="padding-top:0.9rem;">
                                <div class="ar-card-section-title">
                                    <i class="ti ti-target"></i>
                                    <%= isEnglish ? 'Target' : '교체 대상' %>
                                </div>
                                <div style="display:flex; gap:0.65rem; margin-top:-0.25rem;">
                                    <div class="ar-target-card" id="ar-tc-linux" onclick="toggleArTarget('linux')" style="flex:1; justify-content:center;">
                                        <input type="checkbox" id="ar-target-linux" value="linux_key" style="display:none;">
                                        <i class="ti ti-brand-ubuntu" style="font-size:1.1rem; color:#e95420;"></i>
                                        <span><%= isEnglish ? 'Linux SSH Key' : 'Linux SSH 키' %></span>
                                    </div>
                                    <div class="ar-target-card" id="ar-tc-win" onclick="toggleArTarget('win')" style="flex:1; justify-content:center;">
                                        <input type="checkbox" id="ar-target-win" value="windows_password" style="display:none;">
                                        <i class="ti ti-brand-windows" style="font-size:1.1rem; color:#0078d4;"></i>
                                        <span><%= isEnglish ? 'Windows Password' : 'Windows 비밀번호' %></span>
                                    </div>
                                </div>
                            </div>

                            <!-- 교체 주기 -->
                            <div style="padding-top:0.9rem;">
                                <div class="ar-card-section-title">
                                    <i class="ti ti-calendar-stats"></i>
                                    <%= isEnglish ? 'Rotation Cycle' : '교체 주기' %>
                                </div>
                                <div style="display:flex; gap:0.65rem; margin-top:-0.25rem;">
                                    <div class="ar-mode-card selected" id="ar-mc-interval" onclick="setArMode('interval')">
                                        <i class="ti ti-calendar-repeat"></i>
                                        <span class="ar-mode-label"><%= isEnglish ? 'Every N Days' : 'N일 간격' %></span>
                                    </div>
                                    <div class="ar-mode-card" id="ar-mc-monthly" onclick="setArMode('monthly')">
                                        <i class="ti ti-calendar-event"></i>
                                        <span class="ar-mode-label"><%= isEnglish ? 'Monthly' : '매월 특정일' %></span>
                                    </div>
                                </div>
                                <!-- hidden radio -->
                                <input type="radio" name="arMode" value="interval" id="ar-mode-interval" style="display:none;" checked>
                                <input type="radio" name="arMode" value="monthly" id="ar-mode-monthly" style="display:none;">
                            </div>

                            <!-- 상세 설정 -->
                            <div style="padding-top:0.9rem;">
                                <div class="ar-card-section-title">
                                    <i class="ti ti-settings"></i>
                                    <%= isEnglish ? 'Settings' : '상세 설정' %>
                                </div>
                                <!-- interval 상세 -->
                                <div id="ar-interval-row" style="display:flex; align-items:center; gap:0.6rem; flex-wrap:wrap; margin-top:-0.25rem;">
                                    <input type="number" id="ar-intervalDays" min="1" max="3650" class="ar-modern-input" style="width:85px;">
                                    <span style="font-size:0.875rem; color:#374151;"><%= isEnglish ? 'days per cycle' : '일마다 교체' %></span>
                                </div>
                                <!-- monthly 상세 -->
                                <div id="ar-monthly-row" style="display:none; flex-direction:column; gap:0.4rem; margin-top:-0.25rem;">
                                    <div style="display:flex; align-items:center; gap:0.5rem; flex-wrap:wrap;">
                                        <span style="font-size:0.875rem; color:#374151;"><%= isEnglish ? 'Every' : '매' %></span>
                                        <input type="number" id="ar-intervalMonths" min="1" max="24" class="ar-modern-input" style="width:58px;">
                                        <span style="font-size:0.875rem; color:#374151;"><%= isEnglish ? 'month(s), on day' : '개월마다,' %></span>
                                        <input type="number" id="ar-dayOfMonth" min="1" max="31" class="ar-modern-input" style="width:58px;">
                                        <span style="font-size:0.875rem; color:#374151;"><%= isEnglish ? 'th' : '일에 실행' %></span>
