async function approveVmRequest() {
    if (!currentReviewRequest) return;
    const errEl = document.getElementById('vmreq-approve-error');

    const nodeId = document.getElementById('vmreq-node').value;
    const vmSource = document.getElementById('vmreq-vmsource').value;
    const rawCloudImageVolid = (document.getElementById('vmreq-cloud-image').value || '').trim();
    let cloudImageVolid = null;
    if (vmSource === 'cloud-image') {
        if (!rawCloudImageVolid) {
            errEl.textContent = IS_ENGLISH
                ? 'Cloud Image is required. Select an import image from the list.'
                : 'Cloud Image는 필수입니다. 목록에서 import 이미지를 선택하세요.';
            errEl.style.display = 'block';
            return;
        }
        cloudImageVolid = rawCloudImageVolid;
        // 클라이언트 선검증: storage prefix 없는 쓰레기 값 방지
        if (cloudImageVolid && !cloudImageVolid.includes(':') && !cloudImageVolid.startsWith('import/')) {
            errEl.textContent = IS_ENGLISH
                ? 'Invalid Cloud Image value. Select a valid import image.'
                : 'Cloud Image 값이 올바르지 않습니다. 유효한 import 이미지를 선택하세요.';
            errEl.style.display = 'block';
            return;
        }
    }
    const startVmid = document.getElementById('vmreq-start-vmid').value;
    const startIp = document.getElementById('vmreq-start-ip').value;
    const gatewayIp = document.getElementById('vmreq-gateway').value;
    const dnsPrimary = document.getElementById('vmreq-dns-primary').value.trim();
    const dnsSecondary = document.getElementById('vmreq-dns-secondary').value.trim();
    const storagePool = document.getElementById('vmreq-storage').value;
    const networkBridge = document.getElementById('vmreq-bridge').value;

    if (!nodeId || !startIp || !gatewayIp || !dnsPrimary || !storagePool || !networkBridge) {
        errEl.textContent = '모든 인프라 필드를 입력하세요.';
        errEl.style.display = 'block';
        return;
    }

    const btn = document.getElementById('vmreq-approve-btn');
    btn.disabled = true;
    const originalText = btn.textContent;
    btn.textContent = '처리중...';

    try {
        const res = await api('PATCH', '/vm-requests/' + currentReviewRequest.id + '/approve', {
            nodeId,
            vmSource,
            sourceTemplateVmid: document.getElementById('vmreq-template-vmid').value || null,
            cloudImageVolid,
            startVmid: startVmid ? parseInt(startVmid) : null,
            startNumber: parseInt(document.getElementById('vmreq-start-number').value) || 1,
            startIp,
            gatewayIp,
            dnsPrimary,
            dnsSecondary: dnsSecondary || null,
            storagePool,
            networkBridge,
            reviewNote: document.getElementById('vmreq-review-note').value || null,
        });

        if (!res.ok) throw new Error(res.error || 'Failed');

        // 승인 직후 배포까지 자동 실행 (기존 Deploy 수동 단계 제거)
        const deployRes = await api('POST', '/vm-requests/' + currentReviewRequest.id + '/deploy');
        if (!deployRes.ok) {
            throw new Error(deployRes.error || 'Deploy failed');
        }

        closeVmReqModal();
        showArToast(
            (IS_ENGLISH ? 'Request approved and deployment started. Task ID: ' : '요청 승인 및 배포가 시작되었습니다. Task ID: ')
            + (deployRes.taskId || '-'),
            'success',
            3200,
            { emphasis: true }
        );
        loadVmRequests();
    } catch (e) {
        errEl.textContent = e.message;
        errEl.style.display = 'block';
    } finally {
        btn.disabled = false;
        btn.textContent = originalText;
    }
}

