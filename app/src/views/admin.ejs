    <div id="settingsSubTabs" class="settings-subtabs">
        <% settingsTabsForRender.forEach(function(tab, index) { %>
            <button type="button"
                    class="settings-subtab <%= index === 0 ? 'active' : '' %>"
                    data-tab-uuid="<%= tab.uuid %>"
                    data-tab-id="<%= tab.tab_id %>"
                    data-menu-key="<%= tab.menu_key %>"
                    onclick="switchSettingsSubTab('<%= tab.uuid %>', '<%= tab.tab_id %>', '<%= tab.menu_key %>', this)">
                <i class="menu-icon <%= getMenuIconClass(tab.menu_key) %>" aria-hidden="true"></i><%= adminLabel(tab.menu_key, tab.display_name) %>
            </button>
        <% }); %>
