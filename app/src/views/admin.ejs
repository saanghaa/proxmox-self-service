            <div class="section-header">
                <span><i class="ti ti-database-export"></i> <%= isEnglish ? 'Backup & Restore' : '백업 & 복구' %></span>
            </div>
            <div class="section-body">

                <!-- 자동 백업 스케줄 -->
                <div class="backup-card">
                    <h3 class="backup-card-title"><%= isEnglish ? 'Auto Backup Schedule' : '자동 백업 스케줄' %></h3>
                    <div class="backup-schedule-form">
                        <label class="backup-toggle-label">
                            <span class="ar-switch">
                                <input type="checkbox" id="backupEnabled" onchange="toggleBackupScheduleForm()" style="display:none;">
                                <span class="ar-switch-track"><span class="ar-switch-thumb"></span></span>
                            </span>
                            <span><%= isEnglish ? 'Enable auto backup' : '자동 백업 활성화' %></span>
                        </label>
                        <div class="backup-schedule-options" id="backupScheduleOptions">
                            <!-- 스케줄 유형 -->
                            <div class="backup-form-row">
                                <label><%= isEnglish ? 'Schedule Type' : '스케줄 유형' %></label>
                                <select id="backupScheduleType" onchange="onBackupScheduleTypeChange()">
                                    <option value="daily"><%= isEnglish ? 'Daily (every day at set time)' : '일 단위 (매일 지정 시각)' %></option>
                                    <option value="weekly"><%= isEnglish ? 'Weekly (set days + time)' : '주 단위 (요일 + 시각)' %></option>
                                </select>
                            </div>
                            <!-- 요일 선택 (주 단위 전용) -->
                            <div class="backup-form-row" id="backupWeekdaysRow" style="display:none;">
                                <label><%= isEnglish ? 'Days' : '요일' %></label>
                                <div class="backup-weekdays">
                                    <label class="backup-wd-label"><input type="checkbox" name="bwd" value="0"> <%= isEnglish ? 'Sun' : '일' %></label>
                                    <label class="backup-wd-label"><input type="checkbox" name="bwd" value="1" checked> <%= isEnglish ? 'Mon' : '월' %></label>
                                    <label class="backup-wd-label"><input type="checkbox" name="bwd" value="2"> <%= isEnglish ? 'Tue' : '화' %></label>
                                    <label class="backup-wd-label"><input type="checkbox" name="bwd" value="3"> <%= isEnglish ? 'Wed' : '수' %></label>
                                    <label class="backup-wd-label"><input type="checkbox" name="bwd" value="4"> <%= isEnglish ? 'Thu' : '목' %></label>
                                    <label class="backup-wd-label"><input type="checkbox" name="bwd" value="5"> <%= isEnglish ? 'Fri' : '금' %></label>
                                    <label class="backup-wd-label"><input type="checkbox" name="bwd" value="6"> <%= isEnglish ? 'Sat' : '토' %></label>
                                </div>
                            </div>
                            <!-- 실행 시각 -->
                            <div class="backup-form-row">
                                <label><%= isEnglish ? 'Time' : '실행 시각' %></label>
                                <select id="backupHour">
                                    <% for(let h = 0; h < 24; h++) { %>
                                    <option value="<%= h %>" <%= h === 2 ? 'selected' : '' %>><%= String(h).padStart(2,'0') %>:00</option>
                                    <% } %>
                                </select>
                            </div>
                            <!-- 보존 기간 -->
                            <div class="backup-form-row">
                                <label><%= isEnglish ? 'Retention' : '보존 기간' %></label>
                                <select id="backupRetention">
                                    <option value="7" selected><%= isEnglish ? '7 days' : '7일' %></option>
                                    <option value="14"><%= isEnglish ? '14 days' : '14일' %></option>
                                    <option value="30"><%= isEnglish ? '30 days' : '30일' %></option>
                                </select>
                            </div>
                        </div>
                        <div class="backup-form-actions">
                            <button class="btn btn-primary" onclick="saveBackupSchedule()"><%= isEnglish ? 'Save Schedule' : '스케줄 저장' %></button>
