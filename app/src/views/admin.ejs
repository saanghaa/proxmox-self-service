        if (_wdRow) _wdRow.style.display = (s.scheduleType === 'weekly') ? '' : 'none';

        const lastRun = document.getElementById('backupLastRun');
        if (s.lastRunAt) {
            lastRun.textContent = (IS_ENGLISH ? 'Last backup: ' : '마지막 백업: ') + new Date(s.lastRunAt).toLocaleString();
        } else {
            lastRun.textContent = IS_ENGLISH ? 'No backup run yet' : '아직 실행된 백업 없음';
