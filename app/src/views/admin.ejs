        const s = res.schedule;

        document.getElementById('backupEnabled').checked = !!s.enabled;
        document.getElementById('backupScheduleType').value = s.scheduleType || 'daily';
        document.getElementById('backupHour').value = String(s.hour ?? 2);
        document.getElementById('backupRetention').value = String(s.retentionDays || 7);
