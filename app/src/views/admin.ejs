        }
        #vmreqApproveModal input[type="number"]::-webkit-outer-spin-button,
        #vmreqApproveModal input[type="number"]::-webkit-inner-spin-button,
        #vmreqQuotaModal input[type="number"]::-webkit-outer-spin-button,
        #vmreqQuotaModal input[type="number"]::-webkit-inner-spin-button,
        #vmreqRejectModal input[type="number"]::-webkit-outer-spin-button,
        #vmreqRejectModal input[type="number"]::-webkit-inner-spin-button,
        #vmreqLogModal input[type="number"]::-webkit-outer-spin-button,
        #vmreqLogModal input[type="number"]::-webkit-inner-spin-button {
            -webkit-appearance: none;
            appearance: none;
            margin: 0;
        }
        /* Number spinner skin (Chrome/Edge/Safari + Firefox) */
        input[type="number"],
        #tab-password-policy input[type="number"],
        #tab-notifications input[type="number"],
        .quota-input-sm,
        .quota-input-md,
        .ar-modern-input[type="number"] {
            color-scheme: var(--num-ui-scheme);
            -moz-appearance: textfield;
        }
        input[type="number"]::-webkit-outer-spin-button,
        input[type="number"]::-webkit-inner-spin-button,
        #tab-password-policy input[type="number"]::-webkit-outer-spin-button,
        #tab-password-policy input[type="number"]::-webkit-inner-spin-button,
        #tab-notifications input[type="number"]::-webkit-outer-spin-button,
        #tab-notifications input[type="number"]::-webkit-inner-spin-button,
