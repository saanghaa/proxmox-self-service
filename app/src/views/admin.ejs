            <div class="tab" data-legacy="users" onclick="switchTabLegacy('users')"><i class="menu-icon ti ti-users" aria-hidden="true"></i><%= isEnglish ? 'Users' : '사용자' %></div>
            <div class="tab" data-legacy="groups" onclick="switchTabLegacy('groups')"><i class="menu-icon ti ti-users-group" aria-hidden="true"></i><%= isEnglish ? 'Groups' : '사용자 그룹' %></div>
            <div class="tab" data-legacy="audit" onclick="switchTabLegacy('audit')"><i class="menu-icon ti ti-file-text" aria-hidden="true"></i><%= isEnglish ? 'Audit Logs' : '감사 로그' %></div>
            <div id="tab-settings-hub-btn" class="tab" data-legacy="settings" onclick="switchTabLegacy('settings')"><i class="menu-icon ti ti-adjustments" aria-hidden="true"></i><%= isEnglish ? 'Settings' : '설정' %></div>
        <% } %>
