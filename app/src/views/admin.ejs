        }

        @media (max-width: 980px) {
            .proxmox-grid { grid-template-columns: 1fr; }
        }
        @media (max-width: 1100px) {
            .vmreq-grid-4 { grid-template-columns: repeat(2, minmax(0,1fr)); }
            .vmreq-grid-3 { grid-template-columns: repeat(2, minmax(0,1fr)); }
            .vmreq-col-span-2,
            .vmreq-col-span-3,
            .vmreq-col-span-4,
            .vmreq-col-2-3 { grid-column: span 2; }
            .notification-event-grid { grid-template-columns: repeat(2, minmax(0,1fr)); }
        }
        @media (max-width: 760px) {
            .modal { padding: 1rem; }
            .two-col-grid { grid-template-columns: 1fr; }
