function renderVms() {
    const tbody = document.getElementById('vmsBody');

    // Show only deleted VMs
    const deletedVms = allVms.filter(vm => vm.deletedAt);

    if (deletedVms.length === 0) {
        tbody.innerHTML = '<tr><td colspan="8" class="loading-center">' + (IS_ENGLISH ? 'No deleted VMs' : '삭제 예정 VM이 없습니다') + '</td></tr>';
        return;
    }

    tbody.innerHTML = deletedVms.map(vm => {
        const created = vm.createdAt ? vm.createdAt.split('T')[0] : '-';
        const deletedDate = vm.deletedAt ? new Date(vm.deletedAt).toLocaleDateString() : '-';
        const jobIdShort = vm.job?.jobId ? vm.job.jobId.substring(0, 8) + '...' : '-';

        return '<tr>' +
            '<td>' + (vm.vmid || '-') + '</td>' +
            '<td>' + (vm.hostname || '-') + '</td>' +
            '<td class="mono mono-fs-08">' + (vm.ip || '-') + '</td>' +
            '<td><span class="badge badge-group">' + vm.group.name + '</span></td>' +
            '<td class="mono mono-fs-075" title="' + (vm.job?.jobId || '') + '">' + jobIdShort + '</td>' +
            '<td><span class="badge badge-red">' + (IS_ENGLISH ? ('Deleted ' + deletedDate) : ('삭제됨 ' + deletedDate)) + '</span></td>' +
            '<td>' + created + '</td>' +
            '<td>' +
                '<button class="btn btn-primary btn-sm mr-05" onclick="restoreVm(\'' + vm.id + '\', \'' + (vm.hostname || 'VM-' + vm.vmid) + '\')">' + (IS_ENGLISH ? 'Restore' : '복원') + '</button>' +
                '<button class="btn btn-warning btn-sm mr-05" onclick="deleteVmDbOnly(\'' + vm.id + '\', \'' + (vm.hostname || 'VM-' + vm.vmid) + '\', this)">' + (IS_ENGLISH ? 'DB only' : 'DB 삭제') + '</button>' +
                '<button class="btn btn-danger btn-sm" onclick="deleteVmPermanently(\'' + vm.id + '\', \'' + (vm.hostname || 'VM-' + vm.vmid) + '\', this)">' + (IS_ENGLISH ? 'Delete permanently' : '영구 삭제') + '</button>' +
            '</td>' +
        '</tr>';
    }).join('');
}


