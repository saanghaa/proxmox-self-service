async function loadPveNodeResources() {
    var container = document.getElementById('pveNodeResourcesContent');
    if (!container) return;
    container.innerHTML = '<div class="loading-center">' + (IS_ENGLISH ? 'Loading...' : '불러오는 중...') + '</div>';
    try {
        var data = await api('GET', '/pve-node-resources');
        if (!data.ok) { container.innerHTML = '<div class="loading-center" style="color:#ef4444;">Error</div>'; return; }
        _knownPveNodeNames = extractKnownPveNodeNames(data.results);
        container.innerHTML = renderPveNodeResourcesHtml(data.results, data.vmDiskByNode || {}, data.vmDiskTotalBytes || 0);
        // 카드마다 순서대로 페이드인
        container.querySelectorAll('.pve-node-card').forEach(function(card, i) {
            card.style.animationDelay = (i * 0.08) + 's';
        });
    } catch(e) {
        _knownPveNodeNames = [];
        container.innerHTML = '<div class="loading-center" style="color:#ef4444;">' + e.message + '</div>';
    }
}

function renderPveNodeResourcesHtml(results, vmDiskByNode, vmDiskTotalBytes) {
    if (!results || results.length === 0) {
        return '<div class="loading-center" style="color:#94a3b8;">' + (IS_ENGLISH ? 'No Proxmox nodes registered.' : '등록된 Proxmox 노드가 없습니다.') + '</div>';
    }
    vmDiskByNode = vmDiskByNode || {};
    vmDiskTotalBytes = vmDiskTotalBytes || 0;

    function fmtUptime(secs) {
        if (!secs) return '-';
        var d = Math.floor(secs / 86400);
        var h = Math.floor((secs % 86400) / 3600);
        var m = Math.floor((secs % 3600) / 60);
        if (d > 0) return d + 'd ' + h + 'h ' + m + 'm';
        if (h > 0) return h + 'h ' + m + 'm';
        return m + 'm';
    }

    function fmtGB(bytes) {
        if (!bytes || bytes === 0) return '0 GB';
        var gb = bytes / (1024 * 1024 * 1024);
        if (gb < 1) return (bytes / (1024 * 1024)).toFixed(0) + ' MB';
        return gb.toFixed(1) + ' GB';
    }

    // ZFS(thin) 등 used=0 반환 케이스: DB의 VM 디스크 할당량 합산으로 보정
    // nodeName: 해당 물리 노드명 (zfspool만 사용), 나머지는 null
    function calcUsed(s, nodeName) {
        if (s.used && s.used > 0) return s.used;
        if (s.type === 'zfspool' && nodeName && vmDiskByNode[nodeName]) {
            return vmDiskByNode[nodeName];
        }
        if (s.total > 0 && s.avail >= 0) return Math.max(0, s.total - s.avail);
        return 0;
    }

    function barColor(pct, type) {
        if (pct >= 90) return 'critical';
        if (pct >= 75) return 'high';
        return type;
    }

    // 스토리지 타입 분류
    var LOCAL_TYPES  = { dir: 1, lvm: 1, lvmthin: 1, zfspool: 1, btrfs: 1 };
    var CEPH_TYPES   = { rbd: 1, cephfs: 1 };
    // 나머지 (nfs, cifs, glusterfs, pbs 등) → 외부 공유

    // 클러스터 구성 시 여러 DB 엔트리가 같은 물리 노드를 반환할 수 있으므로 노드명 기준 중복 제거
    var uniqueNodes = {}; // nodeName → node data
    var unreachableDbEntries = [];

    for (var ri = 0; ri < results.length; ri++) {
        var r = results[ri];
        if (r.nodes && r.nodes.length > 0) {
            for (var ni = 0; ni < r.nodes.length; ni++) {
                var n = r.nodes[ni];
                if (!uniqueNodes[n.node]) {
                    uniqueNodes[n.node] = n;
                }
            }
        } else {
            unreachableDbEntries.push(r);
        }
    }

    var sortedNodes = Object.keys(uniqueNodes).sort().map(function(k) { return uniqueNodes[k]; });

    // 공유 스토리지 수집 (노드 중복 제거 — storage 이름 기준 첫 번째만 유지)
    var cephPools   = {}; // storageName → pool data
    var externalPools = {};
    sortedNodes.forEach(function(n) {
        if (!n.storage) return;
        n.storage.forEach(function(s) {
            if (CEPH_TYPES[s.type] && !cephPools[s.storage]) {
                cephPools[s.storage] = s;
            } else if (!LOCAL_TYPES[s.type] && !CEPH_TYPES[s.type] && !externalPools[s.storage]) {
                externalPools[s.storage] = s;
            }
        });
    });

    // ── 노드 카드 렌더링 ──
    var html = '<div class="pve-nodes-grid">';

    for (var si = 0; si < sortedNodes.length; si++) {
        var nd = sortedNodes[si];
        var isOnline = nd.status === 'online';
        var cpuPct = nd.cpu ? Math.round(nd.cpu * 100) : 0;
        var memPct = nd.maxmem ? Math.round(nd.mem / nd.maxmem * 100) : 0;

        html += '<div class="pve-node-card' + (isOnline ? '' : ' offline') + '" style="animation-delay:' + (si * 0.25) + 's">';
        html += '<div class="pve-node-card-header" onclick="togglePveNodeCard(this)">';
        html += '<div class="pve-node-card-name"><span class="pve-node-dot ' + (isOnline ? 'online' : 'offline') + '"></span>' + escHtml(nd.node) + '</div>';
        html += '<span class="pve-node-card-right"><span class="pve-node-uptime">' + (IS_ENGLISH ? 'Up: ' : '가동: ') + fmtUptime(nd.uptime) + '</span><i class="ti ti-chevron-down pve-node-card-toggle-icon" aria-hidden="true"></i></span>';
        html += '</div>';
        html += '<div class="pve-node-card-body">';

        // CPU
        html += '<div class="pve-res-row">';
        html += '<div class="pve-res-label"><span>CPU</span><span>' + cpuPct + '% / ' + (nd.maxcpu || '-') + ' vCPU</span></div>';
        html += '<div class="pve-res-bar"><div class="pve-res-bar-fill ' + barColor(cpuPct, 'cpu') + '" style="width:' + cpuPct + '%"></div></div>';
        html += '</div>';

        // RAM
        html += '<div class="pve-res-row">';
        html += '<div class="pve-res-label"><span>RAM</span><span>' + fmtGB(nd.mem) + ' / ' + fmtGB(nd.maxmem) + ' (' + memPct + '%)</span></div>';
        html += '<div class="pve-res-bar"><div class="pve-res-bar-fill ' + barColor(memPct, 'mem') + '" style="width:' + memPct + '%"></div></div>';
        html += '</div>';

        // 로컬 스토리지
        if (nd.storage && nd.storage.length > 0) {
            var localPools = nd.storage.filter(function(s) { return LOCAL_TYPES[s.type] && s.total > 0 && s.active; });
            if (localPools.length > 0) {
                html += '<hr class="pve-res-divider">';
                html += '<div class="pve-res-sub-label">' + (IS_ENGLISH ? 'LOCAL STORAGE' : '로컬 스토리지') + '</div>';
                localPools.forEach(function(s) {
                    var used = calcUsed(s, nd.node);
                    var usedPct = s.total > 0 ? Math.round((used / s.total) * 100) : 0;
                    var isThinEst = s.type === 'zfspool' && (!s.used || s.used === 0) && vmDiskByNode[nd.node];
                    html += '<div class="pve-res-row">';
                    html += '<div class="pve-res-label"><span>' + escHtml(s.storage) + ' <span style="color:#cbd5e1;font-weight:400;">(' + escHtml(s.type) + (isThinEst ? ', 할당량 기준' : '') + ')</span></span>';
                    html += '<span>' + fmtGB(used) + ' / ' + fmtGB(s.total) + ' (' + usedPct + '%)</span></div>';
                    html += '<div class="pve-res-bar"><div class="pve-res-bar-fill ' + barColor(usedPct, 'disk') + '" style="width:' + usedPct + '%"></div></div>';
                    html += '</div>';
                });
            }
        }

        html += '</div>'; // pve-node-card-body
        html += '</div>'; // pve-node-card
    }

    // 연결 실패한 DB 엔트리 중 이미 표시되지 않은 것만 표시
    for (var ui = 0; ui < unreachableDbEntries.length; ui++) {
        var ur = unreachableDbEntries[ui];
        if (uniqueNodes[ur.nodeDbName]) continue;
        html += '<div class="pve-node-card offline" style="animation-delay:' + ((sortedNodes.length + ui) * 0.25) + 's">';
        html += '<div class="pve-node-card-header" onclick="togglePveNodeCard(this)">';
        html += '<div class="pve-node-card-name"><span class="pve-node-dot offline"></span>' + escHtml(ur.nodeDbName) + '</div>';
        html += '<span class="pve-node-card-right"><span style="font-size:0.72rem;color:#ef4444;">' + (IS_ENGLISH ? 'Unreachable' : '연결 불가') + '</span><i class="ti ti-chevron-down pve-node-card-toggle-icon" aria-hidden="true"></i></span>';
        html += '</div>';
        html += '<div class="pve-node-card-body">';
        if (ur.error) html += '<div style="font-size:0.75rem;color:#94a3b8;margin-top:0.4rem;">' + escHtml(ur.error) + '</div>';
        html += '</div>'; // pve-node-card-body
        html += '</div>';
    }

    html += '</div>'; // pve-nodes-grid

    // ── Ceph 클러스터 스토리지 섹션 ──
    var cephKeys = Object.keys(cephPools).sort();
    if (cephKeys.length > 0) {
        html += '<div class="pve-shared-section">';
        html += '<div class="pve-shared-section-title"><i class="ti ti-database"></i>' + (IS_ENGLISH ? 'Ceph Cluster Storage' : 'Ceph 클러스터 스토리지') + '</div>';
        html += '<div class="pve-shared-grid">';
        // Ceph 풀이 여러 개일 경우 vmDiskTotalBytes를 첫 번째 풀에만 적용 (단일 풀 구성 일반적)
        var cephPoolCount = cephKeys.length;
        cephKeys.forEach(function(key, idx) {
            var s = cephPools[key];
            var stored = s.used || 0; // 실제 쓰여진 데이터 (STORED)
            var maxAvail = s.total;   // 사용 가능 용량 (MAX AVAIL, replication 제외)
            // VM 디스크 할당량: 풀이 1개면 전체, 여러 개면 각각 균등 분배 (추정)
            var allocBytes = cephPoolCount > 0 ? Math.round(vmDiskTotalBytes / cephPoolCount) : 0;
            var allocPct  = maxAvail > 0 ? Math.min(100, Math.round((allocBytes / maxAvail) * 100)) : 0;
            var storedPct = maxAvail > 0 ? Math.round((stored / maxAvail) * 100) : 0;

            html += '<div class="pve-storage-pool-card" style="animation-delay:' + (idx * 0.08) + 's">';
            html += '<div class="pve-storage-pool-name">' + escHtml(s.storage) + '</div>';
            html += '<div class="pve-storage-pool-type">' + escHtml(s.type) + '</div>';

            // 할당량 바 (VM 디스크 합산 기준)
            if (allocBytes > 0) {
                html += '<div class="pve-res-label" style="margin-top:0.4rem;"><span style="color:var(--tpl-accent);font-weight:600;">' + (IS_ENGLISH ? '▸ Allocated' : '▸ 할당') + '</span><span>' + fmtGB(allocBytes) + ' / ' + fmtGB(maxAvail) + ' (' + allocPct + '%)</span></div>';
                html += '<div class="pve-res-bar" style="margin-top:0.2rem;"><div class="pve-res-bar-fill ' + barColor(allocPct, 'disk') + '" style="width:' + allocPct + '%"></div></div>';
            }
            // 실제 저장 데이터 (STORED)
            html += '<div class="pve-res-label" style="margin-top:0.5rem;"><span style="color:#94a3b8;">' + (IS_ENGLISH ? '▸ Stored' : '▸ 저장') + '</span><span style="color:#94a3b8;">' + fmtGB(stored) + ' (' + storedPct + '%)</span></div>';
            html += '<div class="pve-res-bar" style="margin-top:0.2rem;"><div class="pve-res-bar-fill mem" style="width:' + storedPct + '%;opacity:0.5;"></div></div>';

            html += '</div>';
        });
        html += '</div></div>'; // pve-shared-grid + pve-shared-section
    }

    // ── 외부 공유 스토리지 섹션 (NFS, PBS, CIFS 등) ──
    var extKeys = Object.keys(externalPools).sort();
    if (extKeys.length > 0) {
        html += '<div class="pve-shared-section">';
        html += '<div class="pve-shared-section-title"><i class="ti ti-network"></i>' + (IS_ENGLISH ? 'External Shared Storage' : '외부 공유 스토리지') + '</div>';
        html += '<div class="pve-shared-grid">';
        extKeys.forEach(function(key) {
            var s = externalPools[key];
            var used = calcUsed(s);
            var usedPct = s.total > 0 ? Math.round((used / s.total) * 100) : 0;
            html += '<div class="pve-storage-pool-card">';
            html += '<div class="pve-storage-pool-name">' + escHtml(s.storage) + '</div>';
            html += '<div class="pve-storage-pool-type">' + escHtml(s.type) + '</div>';
            if (s.total > 0) {
                html += '<div class="pve-res-label"><span>' + fmtGB(used) + ' / ' + fmtGB(s.total) + '</span><span>' + usedPct + '%</span></div>';
                html += '<div class="pve-res-bar" style="margin-top:0.25rem;"><div class="pve-res-bar-fill ' + barColor(usedPct, 'disk') + '" style="width:' + usedPct + '%"></div></div>';
            } else {
                html += '<div style="font-size:0.75rem;color:#94a3b8;">' + (IS_ENGLISH ? 'Size not reported' : '용량 정보 없음') + '</div>';
            }
            html += '</div>';
        });
        html += '</div></div>';
    }

    return html;
}

async function loadVmInventory() {
    var container = document.getElementById('vmInventoryContent');
    if (!container) return;
    container.innerHTML = '<div class="loading-center">' + (IS_ENGLISH ? 'Loading...' : '불러오는 중...') + '</div>';
    try {
        var data = await api('GET', '/vm-inventory');
        if (!data.ok) { container.innerHTML = '<div class="loading-center" style="color:#ef4444;">Error</div>'; return; }
        container.innerHTML = renderVmInventoryHtml(data);
    } catch(e) {
        container.innerHTML = '<div class="loading-center" style="color:#ef4444;">' + e.message + '</div>';
    }
}

function renderVmInventoryHtml(data) {
    var isDarkTheme = document.body.classList.contains('theme-template-dark');
    var STATUS_BADGE = {
        running:  isDarkTheme
            ? '<span style="display:inline-flex;align-items:center;gap:0.28rem;padding:2px 10px;border-radius:999px;background:rgba(61,242,183,0.18);border:1px solid rgba(61,242,183,0.42);color:#c8ffed;font-size:0.75rem;font-weight:700;line-height:1.15;"><i class="ti ti-player-play" style="font-size:0.72rem;line-height:1;color:#bdfbe8;"></i>' + (IS_ENGLISH ? 'running' : '실행중') + '</span>'
            : '<span style="background:#dcfce7;color:#16a34a;padding:2px 8px;border-radius:4px;font-size:0.75rem;font-weight:600;">' + (IS_ENGLISH ? 'running' : '실행중') + '</span>',
        stopped:  '<span style="background:#f1f5f9;color:#64748b;padding:2px 8px;border-radius:4px;font-size:0.75rem;font-weight:600;">' + (IS_ENGLISH ? 'stopped' : '정지') + '</span>',
        paused:   '<span style="background:#fef9c3;color:#ca8a04;padding:2px 8px;border-radius:4px;font-size:0.75rem;font-weight:600;">' + (IS_ENGLISH ? 'paused' : '일시정지') + '</span>',
        unknown:  '<span style="' + (
            isDarkTheme
                ? 'background:rgba(100,116,139,0.2);border:1px solid rgba(148,163,184,0.3);color:#cbd5e1;'
                : 'background:#fee2e2;color:#dc2626;'
        ) + 'padding:2px 8px;border-radius:4px;font-size:0.75rem;font-weight:600;">' + (IS_ENGLISH ? 'unknown' : '알 수 없음') + '</span>',
    };

    function statusBadge(s) { return STATUS_BADGE[s] || STATUS_BADGE['unknown']; }

    function vmTable(vms) {
        if (!vms || vms.length === 0) {
            return '<table class="data-table table-compact" style="margin:0;table-layout:fixed;width:100%;">' +
                '<colgroup>' +
                    '<col style="width:8%;">' +
                    '<col style="width:17%;">' +
                    '<col style="width:12%;">' +
                    '<col style="width:11%;">' +
                    '<col style="width:14%;">' +
                    '<col style="width:24%;">' +
                    '<col style="width:7%;">' +
                    '<col style="width:7%;">' +
                '</colgroup>' +
                '<thead><tr>' +
                    '<th>VMID</th>' +
                    '<th>' + (IS_ENGLISH ? 'Hostname' : '호스트명') + '</th>' +
                    '<th>' + (IS_ENGLISH ? 'Status' : '상태') + '</th>' +
                    '<th>' + (IS_ENGLISH ? 'Group' : '그룹') + '</th>' +
                    '<th>IP</th>' +
                    '<th>' + (IS_ENGLISH ? 'Spec' : '스펙') + '</th>' +
                    '<th>OS</th>' +
                    '<th>' + (IS_ENGLISH ? 'Last Sync' : '동기화') + '</th>' +
                '</tr></thead>' +
                '<tbody><tr><td colspan="8" style="color:#94a3b8;font-size:0.83rem;padding:0.9rem 1rem;line-height:1.4;text-align:center;">' + (IS_ENGLISH ? 'No VMs' : 'VM 없음') + '</td></tr></tbody>' +
            '</table>';
        }
        var rows = vms.map(function(vm) {
            var syncedAgo = vm.lastSyncedAt ? relativeTime(vm.lastSyncedAt) : '-';
            var mem = vm.memoryMb ? Math.round(vm.memoryMb / 1024) + ' GB' : '-';
            return '<tr>' +
                '<td class="mono">' + (vm.vmid || '-') + '</td>' +
                '<td style="font-weight:600;">' + escapeHtml(vm.hostname || '-') + '</td>' +
                '<td>' + statusBadge(vm.status || 'unknown') + '</td>' +
                '<td><span class="badge badge-blue">' + escapeHtml(vm.group.name) + '</span></td>' +
                '<td class="mono mono-fs-08">' + escapeHtml(vm.ip || '-') + '</td>' +
                '<td style="font-size:0.8rem;">' + (vm.cpuCores || '-') + ' vCPU / ' + mem + ' / ' + (function() {
                    if (!vm.disks || vm.disks.length === 0) return (vm.diskSizeGb ? vm.diskSizeGb + ' GB' : '-');
                    var sorted = vm.disks.slice().sort(function(a, b) { return a.slot.localeCompare(b.slot); });
                    return sorted.map(function(d) { return d.sizeGb + ' GB'; }).join(' + ');
                })() + '</td>' +
                '<td style="font-size:0.75rem;color:#94a3b8;">' + (vm.osType === 'windows' ? '🪟 Win' : '🐧 Linux') + '</td>' +
                '<td style="font-size:0.75rem;color:#94a3b8;">' + syncedAgo + '</td>' +
            '</tr>';
        }).join('');
        return '<table class="data-table table-compact" style="margin:0;table-layout:fixed;width:100%;">' +
            '<colgroup>' +
                '<col style="width:8%;">' +
                '<col style="width:17%;">' +
                '<col style="width:12%;">' +
                '<col style="width:11%;">' +
                '<col style="width:14%;">' +
                '<col style="width:24%;">' +
                '<col style="width:7%;">' +
                '<col style="width:7%;">' +
            '</colgroup>' +
            '<thead><tr>' +
                '<th>VMID</th>' +
                '<th>' + (IS_ENGLISH ? 'Hostname' : '호스트명') + '</th>' +
                '<th>' + (IS_ENGLISH ? 'Status' : '상태') + '</th>' +
                '<th>' + (IS_ENGLISH ? 'Group' : '그룹') + '</th>' +
                '<th>IP</th>' +
                '<th>' + (IS_ENGLISH ? 'Spec' : '스펙') + '</th>' +
                '<th>OS</th>' +
                '<th>' + (IS_ENGLISH ? 'Last Sync' : '동기화') + '</th>' +
            '</tr></thead>' +
            '<tbody>' + rows + '</tbody>' +
        '</table>';
    }

    var inventoryNodes = Array.isArray(data.nodes) ? data.nodes.slice() : [];
    var unassigned = Array.isArray(data.unassigned) ? data.unassigned : [];
    var inventoryNodeMap = {};
    inventoryNodes.forEach(function(nodeGroup) {
        if (nodeGroup && nodeGroup.node) inventoryNodeMap[String(nodeGroup.node)] = true;
    });
    _knownPveNodeNames.forEach(function(nodeName) {
        if (inventoryNodeMap[nodeName]) return;
        inventoryNodes.push({ node: nodeName, vmCount: 0, vms: [] });
    });
    inventoryNodes.sort(function(a, b) {
        return String(a.node || '').localeCompare(String(b.node || ''));
    });

    var totalLabel = IS_ENGLISH ? 'Total VMs: ' + data.total : '전체 VM: ' + data.total + '개';
    var html = '<div style="font-size:0.8rem;color:#64748b;margin-bottom:1rem;">' + totalLabel + '</div>';

    if (inventoryNodes.length === 0 && unassigned.length === 0) {
        return html + '<div class="loading-center" style="color:#94a3b8;">' + (IS_ENGLISH ? 'No VMs found' : 'VM이 없습니다') + '</div>';
    }

    var nodeHeaderStyle = isDarkTheme
        ? 'display:flex;align-items:center;gap:0.75rem;padding:0.6rem 0.75rem;background:rgba(148,163,184,0.2);border-radius:6px 6px 0 0;border:1px solid rgba(148,163,184,0.34);border-bottom:none;'
        : 'display:flex;align-items:center;gap:0.75rem;padding:0.6rem 0.75rem;background:#f1f5f9;border-radius:6px 6px 0 0;border:1px solid #e2e8f0;border-bottom:none;';
    var nodeHeaderTitleStyle = isDarkTheme
        ? 'font-weight:700;font-size:0.9rem;color:#deebf9;'
        : 'font-weight:700;font-size:0.9rem;color:#0b2545;';
    var nodeHeaderBadgeStyle = isDarkTheme
        ? 'font-size:0.75rem;font-weight:700;color:#deebf9;background:rgba(148,163,184,0.26);border:1px solid rgba(148,163,184,0.4);padding:2px 8px;border-radius:10px;'
        : 'font-size:0.75rem;font-weight:700;color:#0b2545;background:#dbeafe;padding:2px 8px;border-radius:10px;';
    var nodeBodyStyle = isDarkTheme
        ? 'border:1px solid rgba(148,163,184,0.34);border-radius:0 0 6px 6px;overflow:hidden;'
        : 'border:1px solid #e2e8f0;border-radius:0 0 6px 6px;overflow:hidden;';
    var unassignedHeaderStyle = isDarkTheme
        ? 'display:flex;align-items:center;gap:0.75rem;padding:0.6rem 0.75rem;background:rgba(245,158,11,0.18);border-radius:6px 6px 0 0;border:1px solid rgba(250,204,21,0.38);border-bottom:none;'
        : 'display:flex;align-items:center;gap:0.75rem;padding:0.6rem 0.75rem;background:#fef9c3;border-radius:6px 6px 0 0;border:1px solid #fde68a;border-bottom:none;';
    var unassignedIconStyle = isDarkTheme
        ? 'color:rgba(250,204,21,0.88);font-size:1rem;'
        : 'color:#ca8a04;font-size:1rem;';
    var unassignedTitleStyle = isDarkTheme
        ? 'font-weight:700;font-size:0.9rem;color:#fde68a;'
        : 'font-weight:700;font-size:0.9rem;color:#0b2545;';
    var unassignedBadgeStyle = isDarkTheme
        ? 'font-size:0.75rem;font-weight:700;color:#fde68a;background:rgba(245,158,11,0.24);border:1px solid rgba(250,204,21,0.42);padding:2px 8px;border-radius:10px;'
        : 'font-size:0.75rem;font-weight:700;color:#0b2545;background:#fde68a;padding:2px 8px;border-radius:10px;';
    var unassignedBodyStyle = isDarkTheme
        ? 'border:1px solid rgba(250,204,21,0.36);border-radius:0 0 6px 6px;overflow:hidden;'
        : 'border:1px solid #fde68a;border-radius:0 0 6px 6px;overflow:hidden;';

    inventoryNodes.forEach(function(nodeGroup, idx) {
        var bodyId = 'vm-inv-node-body-' + idx;
        var nodeHeaderInteractiveStyle = nodeHeaderStyle + 'cursor:pointer;justify-content:space-between;';
        var nodeHeaderLeftStyle = 'display:inline-flex;align-items:center;gap:0.75rem;';
        var nodeHeaderRightStyle = 'display:inline-flex;align-items:center;gap:0.5rem;';
        html += '<div style="margin-bottom:1.5rem;">' +
            '<div style="' + nodeHeaderInteractiveStyle + '" onclick="toggleVmInventoryNode(\'' + bodyId + '\', this.querySelector(\'.vm-inv-node-toggle\'))">' +
                '<span style="' + nodeHeaderLeftStyle + '">' +
                    '<i class="ti ti-server" style="color:var(--tpl-accent);font-size:1rem;"></i>' +
                    '<span style="' + nodeHeaderTitleStyle + '">' + escapeHtml(nodeGroup.node) + '</span>' +
                    '<span style="' + nodeHeaderBadgeStyle + '">' + nodeGroup.vmCount + ' VMs</span>' +
                '</span>' +
                '<span style="' + nodeHeaderRightStyle + '"><i class="ti ti-chevron-down vm-inv-node-toggle" aria-hidden="true"></i></span>' +
            '</div>' +
            '<div id="' + bodyId + '" class="vm-inv-node-body" style="' + nodeBodyStyle + '">' +
                vmTable(nodeGroup.vms) +
            '</div>' +
        '</div>';
    });

    if (unassigned.length > 0) {
        html += '<div style="margin-bottom:1.5rem;">' +
            '<div style="' + unassignedHeaderStyle + '">' +
                '<i class="ti ti-server-off" style="' + unassignedIconStyle + '"></i>' +
                '<span style="' + unassignedTitleStyle + '">' + (IS_ENGLISH ? 'Unassigned (no node info)' : '노드 미확인') + '</span>' +
                '<span style="' + unassignedBadgeStyle + '">' + unassigned.length + ' VMs</span>' +
            '</div>' +
            '<div style="' + unassignedBodyStyle + '">' +
                vmTable(unassigned) +
            '</div>' +
        '</div>';
    }

    return html;
}

function renderStatsCharts(data) {
    Object.values(_statsCharts).forEach(function(c) { c.destroy(); });
    _statsCharts = {};

    function withAlpha(color, alpha) {
        var c = String(color || '').trim();
        if (c.startsWith('#')) {
            var hex = c.slice(1);
            if (hex.length === 3) hex = hex.split('').map(function(ch) { return ch + ch; }).join('');
            if (hex.length === 6) {
                var r = parseInt(hex.slice(0, 2), 16);
                var g = parseInt(hex.slice(2, 4), 16);
                var b = parseInt(hex.slice(4, 6), 16);
                return 'rgba(' + r + ',' + g + ',' + b + ',' + alpha + ')';
            }
        }
        return c;
    }

    const tplAccent = (getComputedStyle(document.body).getPropertyValue('--tpl-accent') || '#3b82f6').trim() || '#3b82f6';
    const isDarkTheme = document.body.classList.contains('theme-template-dark');
    const PALETTE = isDarkTheme
        ? [tplAccent, '#22c55e', '#f59e0b', '#ef4444', '#a78bfa', '#f472b6', '#2dd4bf', '#fb923c', '#818cf8', '#a3e635']
        : [tplAccent,'#10b981','#f59e0b','#ef4444','#8b5cf6','#ec4899','#14b8a6','#f97316','#6366f1','#84cc16'];
    const STATUS_COLORS = isDarkTheme
        ? { COMPLETED: '#22c55e', APPROVED: '#f59e0b', DEPLOYING: '#a78bfa', REQUESTED: tplAccent, FAILED: '#ef4444', REJECTED: '#fb7185', CANCELLED: '#94a3b8', QUOTA_EXCEEDED: '#f472b6' }
        : { COMPLETED: '#10b981', APPROVED: '#f59e0b', DEPLOYING: '#8b5cf6', REQUESTED: tplAccent, FAILED: '#ef4444', REJECTED: '#f43f5e', CANCELLED: '#94a3b8', QUOTA_EXCEEDED: '#ec4899' };
    const quotaLimitColor = isDarkTheme ? '#64748b' : '#e2e8f0';
    const fillA = isDarkTheme ? 0.78 : 1;
    const commonBar = { responsive: true, plugins: { legend: { display: false } } };

    // ── VM 현황 ────────────────────────────────────────────────────────────────

    // 1. 그룹별 VM 수 (Bar)
    const vmByGroupEl = document.getElementById('chart-vm-by-group');
    if (vmByGroupEl && data.vmsByGroup && data.vmsByGroup.length > 0) {
        _statsCharts['vmByGroup'] = new Chart(vmByGroupEl, {
            type: 'bar',
            data: {
                labels: data.vmsByGroup.map(function(d) { return d.groupName; }),
                datasets: [{ label: IS_ENGLISH ? 'VM Count' : 'VM 수', data: data.vmsByGroup.map(function(d) { return d.count; }), backgroundColor: withAlpha(PALETTE[0], fillA) }]
            },
            options: Object.assign({}, commonBar, { scales: { y: { beginAtZero: true, ticks: { stepSize: 1 } } } })
        });
    }

    // 2. 그룹별 쿼터 사용률 (Bar, VM 수 한도가 있는 그룹만)
    const quotaUsageEl = document.getElementById('chart-quota-usage');
    if (quotaUsageEl && data.quotaUsage) {
        const quotaGroups = data.quotaUsage.filter(function(q) { return q.maxVmCount > 0; });
        if (quotaGroups.length > 0) {
            _statsCharts['quotaUsage'] = new Chart(quotaUsageEl, {
                type: 'bar',
                data: {
                    labels: quotaGroups.map(function(q) { return q.groupName; }),
                    datasets: [
                        { label: IS_ENGLISH ? 'Used' : '사용 중', data: quotaGroups.map(function(q) { return q.vmCount; }), backgroundColor: withAlpha(PALETTE[0], fillA) },
                        { label: IS_ENGLISH ? 'Limit' : '한도', data: quotaGroups.map(function(q) { return q.maxVmCount; }), backgroundColor: withAlpha(quotaLimitColor, isDarkTheme ? 0.66 : 1) }
                    ]
                },
                options: { responsive: true, scales: { y: { beginAtZero: true, ticks: { stepSize: 1 } } } }
            });
        }
    }

    // 3. VM 상태 분포 (Doughnut)
    const vmStatusEl = document.getElementById('chart-vm-status');
    if (vmStatusEl && data.vmStatusCounts && data.vmStatusCounts.length > 0) {
        const statusColorMap = isDarkTheme
            ? { running: '#22c55e', stopped: '#94a3b8', paused: '#f59e0b', unknown: '#64748b' }
            : { running: '#10b981', stopped: '#94a3b8', paused: '#f59e0b', unknown: '#e2e8f0' };
        _statsCharts['vmStatus'] = new Chart(vmStatusEl, {
            type: 'doughnut',
            data: {
                labels: data.vmStatusCounts.map(function(d) { return d.status; }),
                datasets: [{ data: data.vmStatusCounts.map(function(d) { return d.count; }), backgroundColor: data.vmStatusCounts.map(function(d) { return withAlpha(statusColorMap[d.status] || '#cbd5e1', isDarkTheme ? 0.84 : 1); }), borderWidth: 2 }]
            },
            options: { responsive: true, plugins: { legend: { position: 'bottom' } } }
        });
    }

    // 4. OS 타입 비율 (Doughnut)
    const osTypeEl = document.getElementById('chart-vm-ostype');
    if (osTypeEl && data.vmOsTypeCounts && data.vmOsTypeCounts.length > 0) {
        _statsCharts['osType'] = new Chart(osTypeEl, {
            type: 'doughnut',
            data: {
                labels: data.vmOsTypeCounts.map(function(d) { return d.osType; }),
                datasets: [{ data: data.vmOsTypeCounts.map(function(d) { return d.count; }), backgroundColor: [tplAccent, PALETTE[7], PALETTE[4], PALETTE[1]].map(function(c) { return withAlpha(c, isDarkTheme ? 0.84 : 1); }), borderWidth: 2 }]
            },
            options: { responsive: true, plugins: { legend: { position: 'bottom' } } }
        });
    }

    // 5. 노드별 VM 분포 (Pie)
    const nodeVmsEl = document.getElementById('chart-node-vms');
    if (nodeVmsEl && data.nodeVmCounts && data.nodeVmCounts.length > 0) {
        _statsCharts['nodeVms'] = new Chart(nodeVmsEl, {
            type: 'pie',
            data: {
                labels: data.nodeVmCounts.map(function(d) { return d.node; }),
                datasets: [{ data: data.nodeVmCounts.map(function(d) { return d.count; }), backgroundColor: PALETTE.map(function(c) { return withAlpha(c, fillA); }), borderWidth: 2 }]
            },
            options: { responsive: true, plugins: { legend: { position: 'bottom' } } }
        });
    }

    // 6. 그룹별 리소스 사용량 (Stacked Horizontal Bar: CPU cores / Disk GB)
    const groupResEl = document.getElementById('chart-group-resources');
    if (groupResEl && data.quotaUsage && data.quotaUsage.length > 0) {
        _statsCharts['groupResources'] = new Chart(groupResEl, {
            type: 'bar',
            data: {
                labels: data.quotaUsage.map(function(q) { return q.groupName; }),
                datasets: [
                    { label: IS_ENGLISH ? 'CPU Cores' : 'CPU 코어', data: data.quotaUsage.map(function(q) { return q.usedCpu; }), backgroundColor: withAlpha(PALETTE[0], fillA) },
                    { label: IS_ENGLISH ? 'Disk (GB)' : '디스크 (GB)', data: data.quotaUsage.map(function(q) { return q.usedDisk; }), backgroundColor: withAlpha(PALETTE[2], fillA) },
                    { label: IS_ENGLISH ? 'Mem (GB)' : '메모리 (GB)', data: data.quotaUsage.map(function(q) { return Math.round(q.usedMem / 1024); }), backgroundColor: withAlpha(PALETTE[1], fillA) }
                ]
            },
            options: { indexAxis: 'y', responsive: true, scales: { x: { beginAtZero: true, stacked: true }, y: { stacked: true } } }
        });
    }

    // 7. 그룹별 리소스 사용률 (Radar, 쿼터가 설정된 그룹만)
    const radarEl = document.getElementById('chart-group-radar');
    if (radarEl && data.quotaUsage) {
        const radarGroups = data.quotaUsage.filter(function(q) { return q.maxCpu > 0 || q.maxMem > 0 || q.maxDisk > 0; });
        if (radarGroups.length > 0) {
            _statsCharts['groupRadar'] = new Chart(radarEl, {
                type: 'radar',
                data: {
                    labels: [IS_ENGLISH ? 'CPU %' : 'CPU %', IS_ENGLISH ? 'Memory %' : '메모리 %', IS_ENGLISH ? 'Disk %' : '디스크 %', IS_ENGLISH ? 'VM Count %' : 'VM 수 %'],
                    datasets: radarGroups.map(function(q, i) {
                        return {
                            label: q.groupName,
                            data: [
                                q.maxCpu > 0 ? Math.round(q.usedCpu / q.maxCpu * 100) : 0,
                                q.maxMem > 0 ? Math.round(q.usedMem / q.maxMem * 100) : 0,
                                q.maxDisk > 0 ? Math.round(q.usedDisk / q.maxDisk * 100) : 0,
                                q.maxVmCount > 0 ? Math.round(q.vmCount / q.maxVmCount * 100) : 0
                            ],
                            borderColor: PALETTE[i % PALETTE.length],
                            backgroundColor: withAlpha(PALETTE[i % PALETTE.length], isDarkTheme ? 0.32 : 0.2),
                            pointBackgroundColor: PALETTE[i % PALETTE.length]
                        };
                    })
                },
                options: { responsive: true, scales: { r: { beginAtZero: true, max: 100, ticks: { stepSize: 25 } } } }
            });
        }
    }

    // 8. TOP 10 요청자 (Horizontal bar)
    const topReqEl = document.getElementById('chart-top-requesters');
    if (topReqEl && data.topRequesters && data.topRequesters.length > 0) {
        _statsCharts['topRequesters'] = new Chart(topReqEl, {
            type: 'bar',
            data: {
                labels: data.topRequesters.map(function(r) { return r.email; }),
                datasets: [{ label: IS_ENGLISH ? 'Requests' : '요청 수', data: data.topRequesters.map(function(r) { return r.count; }), backgroundColor: withAlpha(PALETTE[2], fillA) }]
            },
            options: { indexAxis: 'y', responsive: true, plugins: { legend: { display: false } }, scales: { x: { beginAtZero: true, ticks: { stepSize: 1 } } } }
        });
    }

    // ── 요청/승인 흐름 ─────────────────────────────────────────────────────────

    // 9. 전체 요청 현황 (Doughnut)
    const reqStatusEl = document.getElementById('chart-request-status');
    if (reqStatusEl && data.allRequestStatusCounts && data.allRequestStatusCounts.length > 0) {
        _statsCharts['reqStatus'] = new Chart(reqStatusEl, {
            type: 'doughnut',
            data: {
                labels: data.allRequestStatusCounts.map(function(d) { return d.status; }),
                datasets: [{ data: data.allRequestStatusCounts.map(function(d) { return d.count; }), backgroundColor: data.allRequestStatusCounts.map(function(d) { return withAlpha(STATUS_COLORS[d.status] || '#cbd5e1', isDarkTheme ? 0.84 : 1); }), borderWidth: 2 }]
            },
            options: { responsive: true, plugins: { legend: { position: 'bottom' } } }
        });
    }

    // 10. KPI 카드 - 평균 처리 시간
    const avgEl = document.getElementById('kpi-avg-approval');
    if (avgEl) {
        avgEl.textContent = data.avgApprovalHours != null
            ? data.avgApprovalHours + (IS_ENGLISH ? ' hrs' : ' 시간')
            : (IS_ENGLISH ? 'No data' : '데이터 없음');
    }

    // 11. 월별 요청 추이 (Line)
    const monthlyEl = document.getElementById('chart-monthly-requests');
    if (monthlyEl && data.monthlyData && data.monthlyData.length > 0) {
        _statsCharts['monthly'] = new Chart(monthlyEl, {
            type: 'line',
            data: {
                labels: data.monthlyData.map(function(d) { return d.month; }),
                datasets: [
                    { label: IS_ENGLISH ? 'Total' : '전체', data: data.monthlyData.map(function(d) { return d.total; }), borderColor: PALETTE[0], backgroundColor: PALETTE[0]+'22', fill: true, tension: 0.3 },
                    { label: IS_ENGLISH ? 'Completed' : '완료', data: data.monthlyData.map(function(d) { return d.completed; }), borderColor: PALETTE[1], backgroundColor: PALETTE[1]+'22', fill: true, tension: 0.3 }
                ]
            },
            options: { responsive: true, scales: { y: { beginAtZero: true, ticks: { stepSize: 1 } } } }
        });
    }

    // 12. 그룹별 요청 결과 비율 (Stacked bar)
    const groupRatioEl = document.getElementById('chart-group-request-ratio');
    if (groupRatioEl && data.groupRequestMap) {
        const groupNames = Object.keys(data.groupRequestMap);
        if (groupNames.length > 0) {
            const statuses = ['COMPLETED','APPROVED','DEPLOYING','REQUESTED','FAILED','REJECTED','CANCELLED','QUOTA_EXCEEDED'];
            const datasets = statuses.map(function(s) {
                return { label: s, data: groupNames.map(function(g) { return data.groupRequestMap[g][s] || 0; }), backgroundColor: STATUS_COLORS[s] || '#cbd5e1' };
            }).filter(function(ds) { return ds.data.some(function(v) { return v > 0; }); });
            if (datasets.length > 0) {
                _statsCharts['groupRatio'] = new Chart(groupRatioEl, {
                    type: 'bar',
                    data: { labels: groupNames, datasets: datasets },
                    options: { responsive: true, scales: { x: { stacked: true }, y: { stacked: true, beginAtZero: true, ticks: { stepSize: 1 } } } }
                });
            }
        }
    }

    // ── 활동 패턴 ─────────────────────────────────────────────────────────────

    // 13. 일별 VM 등록 추이 (Area, 최근 30일)
    const dailyVmEl = document.getElementById('chart-daily-vms');
    if (dailyVmEl && data.dailyVmData && data.dailyVmData.length > 0) {
        _statsCharts['dailyVms'] = new Chart(dailyVmEl, {
            type: 'line',
            data: {
                labels: data.dailyVmData.map(function(d) { return d.date; }),
                datasets: [{ label: IS_ENGLISH ? 'New VMs' : '신규 VM', data: data.dailyVmData.map(function(d) { return d.count; }), borderColor: PALETTE[6], backgroundColor: withAlpha(PALETTE[6], isDarkTheme ? 0.34 : 0.2), fill: true, tension: 0.2, pointRadius: 4 }]
            },
            options: Object.assign({}, commonBar, { scales: { y: { beginAtZero: true, ticks: { stepSize: 1 } } } })
        });
    }

    // 14. 시간대별 로그인 분포 (Bar, 0~23)
    const loginHourEl = document.getElementById('chart-login-by-hour');
    if (loginHourEl && data.loginByHour) {
        _statsCharts['loginByHour'] = new Chart(loginHourEl, {
            type: 'bar',
            data: {
                labels: Array.from({length: 24}, function(_, i) { return i + (IS_ENGLISH ? ':00' : '시'); }),
                datasets: [{ label: IS_ENGLISH ? 'Logins' : '로그인', data: data.loginByHour, backgroundColor: withAlpha(PALETTE[5], fillA) }]
            },
            options: Object.assign({}, commonBar, { scales: { y: { beginAtZero: true, ticks: { stepSize: 1 } } } })
        });
    }

    // 15. 이벤트 빈도 TOP 10 (Horizontal bar)
    const topEventsEl = document.getElementById('chart-top-events');
    if (topEventsEl && data.topEvents && data.topEvents.length > 0) {
        _statsCharts['topEvents'] = new Chart(topEventsEl, {
            type: 'bar',
            data: {
                labels: data.topEvents.map(function(e) { return e.action; }),
                datasets: [{ label: IS_ENGLISH ? 'Count' : '건수', data: data.topEvents.map(function(e) { return e.count; }), backgroundColor: withAlpha(PALETTE[6], fillA) }]
            },
            options: { indexAxis: 'y', responsive: true, plugins: { legend: { display: false } }, scales: { x: { beginAtZero: true, ticks: { stepSize: 1 } } } }
        });
    }
}
</script>

</body>
</html>
