function positionFixedDropdown(menu, btn) {
    if (!menu || !btn) return;
    const r = btn.getBoundingClientRect();
    const ownerDd = menu.closest('.backup-custom-dd');
    const baseWidth = ownerDd ? ownerDd.getBoundingClientRect().width : r.width;
    const width = Math.max(80, Math.min(window.innerWidth - 24, baseWidth));
    menu.style.position = 'fixed';
    menu.style.width = width + 'px';
    menu.style.minWidth = width + 'px';
    menu.style.maxWidth = width + 'px';
    menu.style.left = Math.max(12, Math.min(window.innerWidth - width - 12, r.left)) + 'px';
    menu.style.top = Math.min(window.innerHeight - 12, r.bottom + 6) + 'px';
    menu.style.zIndex = '9999';
}

window.addEventListener('resize', function() {
