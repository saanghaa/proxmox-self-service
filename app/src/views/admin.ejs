var _pveNameDiscoverTimer = null;
var _lastPveDiscoveryKey = '';

function normalizePveHostInput(value) {
    let input = String(value || '').trim();
    if (!input) return input;
    if (!/^https?:\/\//i.test(input)) input = 'https://' + input;
    try {
        const u = new URL(input);
        if (!u.port) u.port = '8006';
        u.pathname = '';
        u.search = '';
        u.hash = '';
        return u.toString().replace(/\/+$/, '');
    } catch {
        return input.replace(/\/+$/, '');
    }
}

function clearProxmoxForm(keepMessage) {
    const ids = ['pve-name', 'pve-host', 'pve-token-id', 'pve-token-secret'];
    ids.forEach((id) => {
        const el = document.getElementById(id);
        if (el) el.value = '';
    });
