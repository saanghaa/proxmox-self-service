async function deleteVmPermanently(id, hostname, triggerBtn) {
    // Step 1: pre-delete check against Proxmox
    let proxmoxName = null;
    let nameMismatch = false;
    let notInProxmox = false;
    try {
        const chk = await fetch('/api/admin/vms/' + id + '/pre-delete-check', { method: 'POST', headers: { 'Content-Type': 'application/json' } });
        const chkData = await chk.json();
        if (chk.ok) {
            if (chkData.proxmox && chkData.proxmox.name) {
                proxmoxName = chkData.proxmox.name;
                nameMismatch = chkData.db.hostname !== proxmoxName;
            } else if (!chkData.proxmox) {
                notInProxmox = true;
            }
        }
    } catch (e) { /* Proxmox check failed - proceed with confirmation */ }

    // Step 2: Build confirmation message with Proxmox info
    let confirmMsg;
    if (notInProxmox) {
        confirmMsg = IS_ENGLISH
            ? 'VM "' + hostname + '" was NOT FOUND in Proxmox.\n' +
              'It may have already been deleted from Proxmox.\n\n' +
              'Proceed to remove the DB record only?'
            : 'VM "' + hostname + '"\uC774 Proxmox\uC5D0\uC11C \uD655\uC778\uB418\uC9C0 \uC54A\uC2B5\uB2C8\uB2E4.\n' +
              'Proxmox\uC5D0\uC11C \uC774\uBBF8 \uC0AD\uC81C\uB418\uC5C8\uC744 \uC218 \uC788\uC2B5\uB2C8\uB2E4.\n\n' +
              'DB \uB808\uCF54\uB4DC\uB9CC \uC0AD\uC81C\uD558\uC2DC\uACA0\uC2B5\uB2C8\uAE4C?';
    } else if (nameMismatch) {
        confirmMsg = IS_ENGLISH
            ? '\u26A0\uFE0F NAME MISMATCH!\n\n' +
              'DB hostname : ' + hostname + '\n' +
              'Proxmox name: ' + proxmoxName + '\n\n' +
              'These are DIFFERENT VMs with the same VMID!\n' +
              'Proxmox will delete "' + proxmoxName + '"\n\n' +
              'Are you SURE you want to delete the Proxmox VM?'
            : '\u26A0\uFE0F \uC774\uB984 \uBD88\uC77C\uCE58!\n\n' +
              'DB \uD638\uC2A4\uD2B8\uBA85 : ' + hostname + '\n' +
              'Proxmox \uC2E4\uC81C \uC774\uB984: ' + proxmoxName + '\n\n' +
              '\uB3D9\uC77C VMID\uC5D0 \uB2E4\uB978 VM\uC774 \uC874\uC7AC\uD569\uB2C8\uB2E4!\n' +
              'Proxmox\uC5D0\uC11C\uB294 "' + proxmoxName + '"\uC774 \uC0AD\uC81C\uB429\uB2C8\uB2E4.\n\n' +
              '\uC815\uB9D0 Proxmox VM\uC744 \uC0AD\uC81C\uD558\uC2DC\uACA0\uC2B5\uB2C8\uAE4C?';
    } else {
        const pxInfo = proxmoxName ? '\nProxmox: ' + proxmoxName + ' \u2713' : '';
        confirmMsg = IS_ENGLISH
            ? 'Permanently delete VM "' + hostname + '"?' + pxInfo + '\n\nThis cannot be undone.'
            : 'VM "' + hostname + '"\uC744(\uB97C) \uC601\uAD6C \uC0AD\uC81C\uD558\uC2DC\uACA0\uC2B5\uB2C8\uAE4C?' + pxInfo + '\n\n\uB418\uB3CC\uB9B4 \uC218 \uC5C6\uC2B5\uB2C8\uB2E4!';
    }

    const confirmed = await themedConfirm(
        confirmMsg,
        IS_ENGLISH ? 'Permanent Delete' : '영구 삭제'
    );
    if (!confirmed) return;

    // Step 3: If name mismatch, second confirmation to proceed
    if (nameMismatch) {
        const secondConfirm = await themedConfirm(
            IS_ENGLISH
                ? ('Last warning: Proxmox VM "' + proxmoxName + '" will be PERMANENTLY DELETED.\nProceed?')
                : ('최종 경고: Proxmox VM "' + proxmoxName + '"이 영구 삭제됩니다.\n계속하시겠습니까?'),
            IS_ENGLISH ? 'Final Warning' : '최종 경고'
        );
        if (!secondConfirm) return;
    }

    const originalText = triggerBtn ? triggerBtn.textContent : '';
    if (triggerBtn) {
        triggerBtn.disabled = true;
        triggerBtn.textContent = IS_ENGLISH ? 'Deleting...' : '삭제 중...';
    }
    showArToast(
        IS_ENGLISH ? 'Permanent deletion in progress...' : '영구 삭제 진행 중...',
        'info',
        2200,
        { x: window.innerWidth / 2, y: (window.innerHeight / 2) + 120 },
        { emphasis: true }
    );

    try {
        const forceParam = nameMismatch ? '?force=true' : '';
        const result = await api('DELETE', '/vms/' + id + '/permanent' + forceParam);
        const proxmoxMsg = result.proxmoxDeleted
            ? (IS_ENGLISH ? ' (Proxmox deleted)' : ' (Proxmox \uC0AD\uC81C \uC644\uB8CC)')
            : (IS_ENGLISH ? ' (DB record removed only)' : ' (DB \uB808\uCF54\uB4DC\uB9CC \uC0AD\uC81C)');
        showArToast(
            (IS_ENGLISH ? 'VM permanently deleted: ' : 'VM 영구 삭제 완료: ') + hostname + proxmoxMsg,
            'success',
            3200,
            { emphasis: true }
        );
        loadVms();
    } catch (e) {
        showArToast(
            (IS_ENGLISH ? 'Permanent delete failed: ' : '영구 삭제 실패: ') + e.message,
            'error',
            3200,
            { emphasis: true }
        );
    } finally {
        if (triggerBtn && document.body.contains(triggerBtn)) {
            triggerBtn.disabled = false;
            triggerBtn.textContent = originalText;
        }
    }
}


// === AUDIT LOGS ===
async function loadAuditLogs(page) {
    auditPage = page;
    try {
        const params = new URLSearchParams({
            page: String(page),
            limit: '30',
        });
        if (auditFilters.from) params.set('from', auditFilters.from);
        if (auditFilters.to) params.set('to', auditFilters.to);
        if (auditFilters.user) params.set('user', auditFilters.user);
        if (auditFilters.action) params.set('action', auditFilters.action);
        if (auditFilters.result) params.set('result', auditFilters.result);
        if (auditFilters.ip) params.set('ip', auditFilters.ip);
        const data = await api('GET', '/audit-logs?' + params.toString());
        renderAuditLogs(data.logs, data.total, data.page, data.limit);
    } catch (e) { showAlert((IS_ENGLISH ? 'Failed to load audit logs: ' : '감사 로그를 불러오지 못했습니다: ') + e.message, 'error'); }
}

function applyAuditFilters() {
    const fromValue = getAuditDateValue('audit-filter-from');
    const toValue = getAuditDateValue('audit-filter-to');
    if (fromValue && toValue) {
	        const fromDate = new Date(fromValue);
	        const toDate = new Date(toValue);
	        if (!isNaN(fromDate.getTime()) && !isNaN(toDate.getTime()) && fromDate > toDate) {
	            showAlert((typeof IS_ENGLISH !== 'undefined' && IS_ENGLISH)
	                ? 'Start time must be earlier than end time.'
	                : '시작일시는 종료일시보다 이전이어야 합니다.', 'error');
	            return;
	        }
	    }

    auditFilters = {
        from: fromValue,
        to: toValue,
        user: (document.getElementById('audit-filter-user').value || '').trim(),
        action: (document.getElementById('audit-filter-action').value || '').trim(),
        result: (document.getElementById('audit-filter-result').value || '').trim(),
        ip: (document.getElementById('audit-filter-ip').value || '').trim(),
    };
    loadAuditLogs(1);
}

function resetAuditFilters() {
    const fromEl = document.getElementById('audit-filter-from');
    const toEl = document.getElementById('audit-filter-to');
    if (fromEl?._flatpickr) fromEl._flatpickr.clear();
    else fromEl.value = '';
    if (toEl?._flatpickr) toEl._flatpickr.clear();
    else toEl.value = '';
    document.getElementById('audit-filter-user').value = '';
    document.getElementById('audit-filter-action').value = '';
    document.getElementById('audit-filter-result').value = '';
    document.getElementById('audit-filter-ip').value = '';
    syncAuditResultFilterUi();
    auditFilters = { from: '', to: '', user: '', action: '', result: '', ip: '' };
    loadAuditLogs(1);
}

function renderAuditLogs(logs, total, page, limit) {
    const tbody = document.getElementById('auditBody');
    const pagination = document.getElementById('auditPagination');
    if (logs.length === 0) {
        tbody.innerHTML = '<tr><td colspan="6" class="loading-center">' + (IS_ENGLISH ? 'No audit logs' : '감사 로그가 없습니다') + '</td></tr>';
        pagination.innerHTML = '';
        return;
    }

    tbody.innerHTML = logs.map(l => {
        const time = l.createdAt
            ? new Date(l.createdAt).toLocaleString(IS_ENGLISH ? 'en-US' : 'ko-KR')
            : '-';
        const resultBadge = l.result === 'SUCCESS'
            ? '<span class="audit-result-badge success">OK</span>'
            : '<span class="audit-result-badge fail">FAIL</span>';
        const rawReason = l.reason || '';
        const reason = IS_ENGLISH ? rawReason : localizeAuditReason(rawReason);
        const detail = [l.fingerprint ? 'key:' + l.fingerprint.substring(0, 12) + '...' : '', reason].filter(Boolean).join(' ') || '-';
        return '<tr>' +
            '<td class="mono mono-nowrap">' + time + '</td>' +
            '<td>' + (l.user ? l.user.email : '-') + '</td>' +
            '<td><span class="badge badge-gray">' + l.action + '</span></td>' +
            '<td>' + resultBadge + '</td>' +
            '<td class="text-ellipsis-200">' + detail + '</td>' +
            '<td class="mono mono-fs-08">' + (l.requestIp || '-') + '</td>' +
        '</tr>';
    }).join('');

    // Pagination
    const totalPages = Math.ceil(total / limit);
    if (totalPages <= 1) { pagination.innerHTML = ''; return; }

    let html = '';
    if (page > 1) html += '<button class="btn btn-primary btn-sm" onclick="loadAuditLogs(' + (page - 1) + ')">' + (IS_ENGLISH ? 'Prev' : '이전') + '</button>';
    html += '<span class="pagination-text">' + page + ' / ' + totalPages + '</span>';
    if (page < totalPages) html += '<button class="btn btn-primary btn-sm" onclick="loadAuditLogs(' + (page + 1) + ')">' + (IS_ENGLISH ? 'Next' : '다음') + '</button>';
    pagination.innerHTML = html;
}

function localizeAuditReason(reason) {
    const r = (reason || '').trim();
    if (!r) return '';

    // Keep delete-related audit details technical (do not translate "delete/deleted")
    // to avoid confusion when searching/log-reviewing by action keywords/codes.
    if (/\bdelete(?:d)?\b/i.test(r)) {
        return r;
    }

    // OTP flows
    if (r === 'Recovery code accepted; OTP reset for re-enrollment') {
        return '복구 코드 확인됨: OTP가 초기화되어 재등록이 필요합니다';
    }
    if (r.startsWith('Reset OTP for user: ')) {
        return '사용자 OTP 초기화: ' + r.substring('Reset OTP for user: '.length);
    }

    // User management
    if (r.startsWith('Created user: ')) {
        return '사용자 생성: ' + r.substring('Created user: '.length);
    }

    return r;
}

function getAuditDateValue(inputId) {
    const el = document.getElementById(inputId);
    if (!el) return '';
    const fp = el._flatpickr;
    if (fp && Array.isArray(fp.selectedDates) && fp.selectedDates.length > 0) {
        return fp.selectedDates[0].toISOString();
    }
    const raw = (el.value || '').trim();
    if (!raw) return '';
    const parsed = new Date(raw);
    return isNaN(parsed.getTime()) ? '' : parsed.toISOString();
}

