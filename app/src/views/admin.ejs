                <a href="/auth/change-password?voluntary=true" class="personal-link">
                    <i class="ti ti-key" aria-hidden="true"></i>
                    <span><%= isEnglish ? 'Change Password' : '비밀번호 변경' %></span>
                </a>
                <div class="personal-divider"></div>
                <div class="personal-section-title"><%= isEnglish ? 'Theme' : '테마' %></div>
                <% themeOptions.forEach(function(opt) { %>
                    <button type="button"
                            class="theme-item <%= (currentThemeTemplate === opt.id) ? 'current' : '' %>"
                            role="menuitem"
                            data-theme-template="<%= opt.id %>"
                            onclick="changeThemeTemplate('<%= opt.id %>')">
                        <span class="theme-dot theme-dot-<%= opt.id %>"></span>
                        <span><%= isEnglish ? opt.labelEn : opt.label %></span>
                        <span class="theme-label-en"><%= opt.labelEn %></span>
                    </button>
                <% }); %>
            </div>
        </div>
        <!-- Language menu -->
        <div class="lang-menu" id="langMenu">
            <button type="button"
                    class="lang-button"
                    id="langButton"
                    aria-haspopup="menu"
                    aria-expanded="false"
                    onclick="toggleLangMenu(event)">
                <i class="ti ti-world" aria-hidden="true"></i>
                <span class="lang-label"><%= isEnglish ? 'English' : '한국어' %></span>
                <i class="ti ti-chevron-down" aria-hidden="true"></i>
            </button>
            <div class="lang-dropdown" id="langDropdown" role="menu" aria-label="Language">
                <button type="button"
                        class="lang-item <%= (locals.currentLang === 'ko') ? 'current' : '' %>"
                        role="menuitem"
                        onclick="changeLanguage('ko')">
                    <i class="ti ti-language-katakana" aria-hidden="true"></i>
                    <span>한국어</span>
                    <span class="lang-hint">KO</span>
                </button>
                <button type="button"
                        class="lang-item <%= (locals.currentLang === 'en') ? 'current' : '' %>"
                        role="menuitem"
                        onclick="changeLanguage('en')">
                    <i class="ti ti-language" aria-hidden="true"></i>
                    <span>English</span>
                    <span class="lang-hint">EN</span>
                </button>
            </div>
        </div>
    </div>
</div>

<div class="container">

    <%
    const SETTINGS_MENU_KEYS = ['NOTIFICATION_SETTINGS', 'PASSWORD_POLICY', 'MENU_SETTINGS', 'UI_SETTINGS', 'PROXMOX_CONNECTION', 'BACKUP_MANAGEMENT'];
    const dynamicAdminTabs = adminTabs || [];
    const primaryAdminTabs = dynamicAdminTabs.filter(tab => !SETTINGS_MENU_KEYS.includes(tab.menu_key));
	    const groupedSettingsTabs = dynamicAdminTabs.filter(tab => SETTINGS_MENU_KEYS.includes(tab.menu_key));
	    const fallbackSettingsTabs = [
	        { uuid: 'legacy-notifications', menu_key: 'NOTIFICATION_SETTINGS', tab_id: 'tab-notifications', display_name: isEnglish ? 'Notifications' : '알림' },
	        { uuid: 'legacy-password-policy', menu_key: 'PASSWORD_POLICY', tab_id: 'tab-password-policy', display_name: isEnglish ? 'Security Policy' : '보안 정책' },
	        { uuid: 'legacy-menu-settings', menu_key: 'MENU_SETTINGS', tab_id: 'tab-menu-settings', display_name: isEnglish ? 'Menu Settings' : '메뉴 설정' },
	        { uuid: 'legacy-ui-settings', menu_key: 'UI_SETTINGS', tab_id: 'tab-ui-settings', display_name: isEnglish ? 'UI Text Settings' : 'UI 텍스트 설정' },
	        { uuid: 'legacy-proxmox', menu_key: 'PROXMOX_CONNECTION', tab_id: 'tab-proxmox', display_name: isEnglish ? 'Proxmox Connection' : 'PROXMOX 서버 연결' },
	        { uuid: 'legacy-backup', menu_key: 'BACKUP_MANAGEMENT', tab_id: 'tab-backup', display_name: isEnglish ? 'Backup & Restore' : '백업 & 복구' }
	    ];
	    const settingsTabsForRender = groupedSettingsTabs.length > 0 ? groupedSettingsTabs : fallbackSettingsTabs;
	    %>

    <!-- Toast container -->
    <div id="ar-toast-container"></div>

    <!-- Tabs (Dynamic - UUID based) -->
    <div class="tabs">
        <% if (dynamicAdminTabs.length > 0) { %>
            <% primaryAdminTabs.forEach(function(tab, index) { %>
                <div class="tab <%= index === 0 ? 'active' : '' %>"
                     data-tab-uuid="<%= tab.uuid %>"
                     data-tab-id="<%= tab.tab_id %>"
                     data-menu-key="<%= tab.menu_key %>"
                     onclick="switchTab('<%= tab.uuid %>', '<%= tab.tab_id %>', '<%= tab.menu_key %>')">
                    <i class="menu-icon <%= getMenuIconClass(tab.menu_key) %>" aria-hidden="true"></i><%= adminLabel(tab.menu_key, tab.display_name) %>
                </div>
            <% }); %>
            <% if (settingsTabsForRender.length > 0) { %>
                <div id="tab-settings-hub-btn"
                     class="tab <%= primaryAdminTabs.length === 0 ? 'active' : '' %>"
                     data-tab-uuid="settings-hub"
                     data-menu-key="SETTINGS_HUB"
                     onclick="openSettingsHub()">
                    <i class="menu-icon ti ti-adjustments" aria-hidden="true"></i><%= isEnglish ? 'Settings' : '설정' %>
                </div>
            <% } %>
        <% } else { %>
            <!-- Fallback: 기본 탭 (UUID 구조 없을 시) -->
            <div class="tab active" data-legacy="vm-requests" onclick="switchTabLegacy('vm-requests')"><i class="menu-icon ti ti-list-check" aria-hidden="true"></i><%= isEnglish ? 'VM Create Requests' : 'VM 생성 요청 확인' %></div>
