            border: 1px dashed var(--vr-border);
        }
        .custom-fields.show {
            display: grid;
            grid-template-columns: 1fr 1fr 1fr;
        }

        /* Modern Form Inputs */
        .modern-input {
            width: 100%;
            padding: 0.6rem 0.85rem;
            border: 1px solid var(--vr-border);
            border-radius: 6px;
            font-size: 0.85rem;
            outline: none;
            transition: all 0.2s ease;
            font-family: inherit;
            min-height: 40px;
        }
        /* Keep VM request group select height aligned with neighboring controls */
        #req-group.modern-input {
            min-height: 38px;
            height: 38px;
            padding-top: 0.5rem;
            padding-bottom: 0.5rem;
            line-height: 1.2;
        }
        .req-group-dd {
            position: relative;
            display: block;
            width: 100%;
        }
        .req-group-dd-btn {
            display: inline-flex;
            align-items: center;
            justify-content: space-between;
            gap: 0.5rem;
            cursor: pointer;
            width: 100%;
            min-width: 0;
            text-align: left;
        }
        .req-group-dd-btn .req-group-label {
            overflow: hidden;
            text-overflow: ellipsis;
            white-space: nowrap;
