        .req-group-dd.open .req-group-dd-menu { display: block; }
        .req-group-dd-item {
            width: 100%;
            text-align: left;
            background: transparent;
            border: 0;
            color: #1e293b;
            padding: 0.34rem 0.46rem;
            border-radius: 6px;
            font-size: 0.85rem;
            cursor: pointer;
