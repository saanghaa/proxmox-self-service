<body class="theme-template-<%= locals.activeThemeTemplate || 'proxmox' %>">
<%
const dashMenuIconClassMap = {
    DASHBOARD: 'ti ti-layout-dashboard',
    ADMIN_PANEL: 'ti ti-shield-lock',
    CHANGE_PASSWORD: 'ti ti-key',
    LOGOUT: 'ti ti-logout'
};
function getDashMenuIconClass(menuKey) {
    return dashMenuIconClassMap[menuKey] || 'ti ti-circle';
}
function stripLeadingIconText(text) {
    return String(text || '').replace(/^[^\p{L}\p{N}\(\[]+/u, '').trim();
}
	function localeLabel(value, koFallback, enFallback) {
	    const v = String(value || '').trim();
	    if (v) {
	        if (isEnglish && /[가-힣]/.test(v)) return enFallback;
	        if (!isEnglish && !/[가-힣]/.test(v) && /[A-Za-z]/.test(v)) return koFallback;
	        return v;
	    }
	    return isEnglish ? enFallback : koFallback;
	}
function vmCreateLabel(value) {
    const v = String(value || '').trim();
    if (isEnglish) {
        if (v && !/[가-힣]/.test(v)) return v;
        return 'VM Create';
    }
    if (v && /[가-힣]/.test(v)) return v;
    return 'VM 생성 요청';
}
const themeOptions = locals.themeTemplateOptions || [];
const currentThemeTemplate = locals.activeThemeTemplate || 'proxmox';
const currentThemeOption = themeOptions.find(t => t.id === currentThemeTemplate) || themeOptions[0];
%>

<div class="header">
    <h1 class="header-brand">
        <img src="<%= dashboardLogoSrc %>" alt="<%= dashboardLogoAlt %>">
        <span>Horizon</span>
    </h1>
    <div class="header-right">
        <span><%= user.email %></span>
        <% if (headerMenus && headerMenus.length > 0) { %>
            <% headerMenus.forEach(function(menu) { %>
                <% if (menu.menu_key === 'CHANGE_PASSWORD') { return; } %>
                <a href="<%= menu.path %>"
                   class="<%= menu.css_class || '' %>"
                   data-menu-uuid="<%= menu.uuid %>"
                   data-menu-key="<%= menu.menu_key %>">
                    <i class="menu-icon <%= getDashMenuIconClass(menu.menu_key) %>" aria-hidden="true"></i><%= stripLeadingIconText(menu.display_name) %>
                </a>
            <% }); %>
        <% } else { %>
            <!-- Fallback: 기본 메뉴 -->
            <% if (isAdmin) { %>
                <a href="/admin" class="btn-admin"><i class="menu-icon ti ti-shield-lock" aria-hidden="true"></i><%= isEnglish ? 'Admin' : '관리자' %></a>
            <% } %>
            <a href="/auth/logout"><i class="menu-icon ti ti-logout" aria-hidden="true"></i><%= isEnglish ? 'Logout' : '로그아웃' %></a>
        <% } %>
        <!-- Personal settings menu -->
        <div class="personal-menu" id="personalMenu">
            <button type="button"
                    class="personal-button"
                    id="personalButton"
                    aria-haspopup="menu"
                    aria-expanded="false">
                <i class="ti ti-user-cog" aria-hidden="true"></i>
                <span class="personal-label"><%= isEnglish ? 'Personal' : '개인설정' %></span>
                <i class="ti ti-chevron-down" aria-hidden="true"></i>
            </button>
            <div class="personal-dropdown" id="personalDropdown" role="menu" aria-label="Personal settings">
                <div class="personal-section-title"><%= isEnglish ? 'Account' : '계정' %></div>
                <a href="/auth/change-password?voluntary=true" class="personal-link">
                    <i class="ti ti-key" aria-hidden="true"></i>
                    <span><%= isEnglish ? 'Change Password' : '비밀번호 변경' %></span>
                </a>
                <div class="personal-divider"></div>
                <div class="personal-section-title"><%= isEnglish ? 'Theme' : '테마' %></div>
                <% themeOptions.forEach(function(opt) { %>
            <button type="button"
                            class="theme-item <%= (currentThemeTemplate === opt.id) ? 'current' : '' %>"
                            role="menuitem"
                            data-theme-template="<%= opt.id %>">
                        <span class="theme-dot theme-dot-<%= opt.id %>"></span>
                        <span><%= isEnglish ? opt.labelEn : opt.label %></span>
                        <span class="theme-label-en"><%= opt.labelEn %></span>
                    </button>
                <% }); %>
            </div>
        </div>
	        <!-- Language menu -->
	        <div class="lang-menu" id="langMenu">
	            <button type="button"
	                    class="lang-button"
	                    id="langButton"
	                    aria-haspopup="menu"
	                    aria-expanded="false">
	                <i class="ti ti-world" aria-hidden="true"></i>
	                <span class="lang-label"><%= isEnglish ? 'English' : '한국어' %></span>
	                <i class="ti ti-chevron-down" aria-hidden="true"></i>
	            </button>
	            <div class="lang-dropdown" id="langDropdown" role="menu" aria-label="Language">
	                <button type="button"
	                        class="lang-item <%= (locals.currentLang === 'ko') ? 'current' : '' %>"
	                        role="menuitem"
                            data-lang="ko">
	                    <i class="ti ti-language-katakana" aria-hidden="true"></i>
	                    <span>한국어</span>
	                    <span class="lang-hint">KO</span>
	                </button>
	                <button type="button"
	                        class="lang-item <%= (locals.currentLang === 'en') ? 'current' : '' %>"
	                        role="menuitem"
                            data-lang="en">
	                    <i class="ti ti-language" aria-hidden="true"></i>
	                    <span>English</span>
	                    <span class="lang-hint">EN</span>
	                </button>
	            </div>
	        </div>
	    </div>
	</div>

<div class="container">

    <!-- My Groups -->
    <div class="section">
        <div class="section-header">
            <span><%= localeLabel(sectionLabels?.dashboard?.my_groups?.title, '내 그룹', 'My Groups') %></span>
            <span class="badge badge-count"><%= isEnglish ? `${groups.length} groups` : `${groups.length}개 그룹` %></span>
        </div>
        <div class="group-list">
            <% if (groups.length > 0) { %>
                <% groups.forEach(function(group) { %>
                    <span class="badge badge-group"><%= group.name %></span>
                <% }); %>
            <% } else { %>
                <span class="group-list-empty"><%= localeLabel(uuidLabels?.messages?.['msg-008'], '배정된 그룹이 없습니다. 관리자에게 문의하세요.', 'No groups assigned. Please contact admin.') %></span>
            <% } %>
        </div>
    </div>

    <!-- Dashboard Tabs -->
    <div class="tabs">
        <div class="tab active" data-tab-id="tab-vms" onclick="switchDashTab(this)"><%= localeLabel(sectionLabels?.dashboard?.tabs?.vm_list, '내 VM 목록', 'My VMs') %></div>
        <% if (groups.length > 0) { %>
        <div class="tab" data-tab-id="tab-vm-request" onclick="switchDashTab(this)"><%= vmCreateLabel(sectionLabels?.dashboard?.tabs?.vm_request) %></div>
        <% } %>
    </div>

    <script>
    // Dashboard Tab Switching - Global function
    function switchDashTab(el) {
        document.querySelectorAll('.tabs .tab').forEach(t => t.classList.remove('active'));
        document.querySelectorAll('.tab-content').forEach(c => c.classList.remove('active'));
        el.classList.add('active');
        document.getElementById(el.dataset.tabId).classList.add('active');
    }
    </script>

    <!-- Tab: VM 생성 요청 -->
    <% if (groups.length > 0) { %>
    <div id="tab-vm-request" class="tab-content">
    <div class="section">
        <div class="section-header">
            <span><%= vmCreateLabel(sectionLabels?.dashboard?.tabs?.vm_request) %></span>
        </div>

        <!-- Group Quota -->
        <% if (groupQuotas && groupQuotas.length > 0) { %>
        <div class="quota-grid">
            <% groupQuotas.forEach(function(tq) { %>
            <div class="quota-card">
                <div class="quota-card-header">
                    <span class="group-name"><%= tq.groupName %></span>
                </div>
                <% if (tq.quota.maxCpuCores === -1 && tq.quota.maxMemoryMb === -1 && tq.quota.maxDiskGb === -1 && tq.quota.maxVmCount === -1) { %>
                    <span class="quota-unlimited"><%= isEnglish ? 'No quota configured (unlimited)' : '할당량 미설정 (무제한)' %></span>
                <% } else { %>
                    <%
                    function quotaPercent(used, pending, max) {
                        if (max <= 0) return 0;
                        return Math.min(100, Math.round(((used + pending) / max) * 100));
                    }
                    function quotaClass(pct) {
                        if (pct >= 90) return 'danger';
                        if (pct >= 70) return 'warn';
                        return 'safe';
                    }
                    %>
                    <% if (tq.quota.maxCpuCores !== -1) { %>
                    <div class="quota-item">
                        <div class="quota-label"><span>CPU</span><span><%= tq.used.cpuCores %><% if (tq.pending.cpuCores > 0) { %>+<%= tq.pending.cpuCores %><% } %> / <%= tq.quota.maxCpuCores %> cores</span></div>
                        <div class="quota-bar"><div class="quota-bar-fill js-quota-fill <%= quotaClass(quotaPercent(tq.used.cpuCores, tq.pending.cpuCores, tq.quota.maxCpuCores)) %>" data-width="<%= quotaPercent(tq.used.cpuCores, tq.pending.cpuCores, tq.quota.maxCpuCores) %>"></div></div>
                    </div>
                    <% } %>
                    <% if (tq.quota.maxMemoryMb !== -1) { %>
                    <div class="quota-item">
                        <div class="quota-label"><span>Memory</span><span><%= Math.round(tq.used.memoryMb/1024) %><% if (tq.pending.memoryMb > 0) { %>+<%= Math.round(tq.pending.memoryMb/1024) %><% } %> / <%= Math.round(tq.quota.maxMemoryMb/1024) %> GB</span></div>
                        <div class="quota-bar"><div class="quota-bar-fill js-quota-fill <%= quotaClass(quotaPercent(tq.used.memoryMb, tq.pending.memoryMb, tq.quota.maxMemoryMb)) %>" data-width="<%= quotaPercent(tq.used.memoryMb, tq.pending.memoryMb, tq.quota.maxMemoryMb) %>"></div></div>
                    </div>
                    <% } %>
                    <% if (tq.quota.maxDiskGb !== -1) { %>
                    <div class="quota-item">
                        <div class="quota-label"><span>Disk</span><span><%= tq.used.diskGb %><% if (tq.pending.diskGb > 0) { %>+<%= tq.pending.diskGb %><% } %> / <%= tq.quota.maxDiskGb %> GB</span></div>
                        <div class="quota-bar"><div class="quota-bar-fill js-quota-fill <%= quotaClass(quotaPercent(tq.used.diskGb, tq.pending.diskGb, tq.quota.maxDiskGb)) %>" data-width="<%= quotaPercent(tq.used.diskGb, tq.pending.diskGb, tq.quota.maxDiskGb) %>"></div></div>
                    </div>
                    <% } %>
                    <% if (tq.quota.maxVmCount !== -1) { %>
                    <div class="quota-item">
                        <div class="quota-label"><span>VMs</span><span><%= tq.used.vmCount %><% if (tq.pending.vmCount > 0) { %>+<%= tq.pending.vmCount %><% } %> / <%= tq.quota.maxVmCount %></span></div>
                        <div class="quota-bar"><div class="quota-bar-fill js-quota-fill <%= quotaClass(quotaPercent(tq.used.vmCount, tq.pending.vmCount, tq.quota.maxVmCount)) %>" data-width="<%= quotaPercent(tq.used.vmCount, tq.pending.vmCount, tq.quota.maxVmCount) %>"></div></div>
                    </div>
                    <% } %>
                <% } %>
            </div>
            <% }); %>
        </div>
        <% } %>

        <!-- VM Creation Form - Modern Design -->
        <div class="vm-request-workspace">
        <div class="vm-request-container">
            <div class="vm-request-form">
                <%
                // 관리자는 모든 그룹, 일반 사용자는 본인 그룹만
                const availableGroups = (isAdmin && allGroups.length > 0) ? allGroups : groups;
                const showGroupSelect = isAdmin || groups.length > 1;
                const autoSelectGroup = !isAdmin && groups.length === 1 ? groups[0] : null;
                %>

                <!-- Group Selection Section -->
                <div class="form-section">
                    <div class="form-section-title">
                        <i class="ti ti-building icon" aria-hidden="true"></i>
                        <span><%= isEnglish ? 'Group Selection' : '그룹 선택' %></span>
                    </div>
                    <% if (showGroupSelect) { %>
                    <div>
                        <label class="modern-label">Group <span class="required">*</span></label>
                        <select id="req-group" class="modern-input" onchange="loadGroupQuota(this.value)" style="display:none;">
                            <option value=""><%= isEnglish ? '-- Select Group --' : '-- 그룹 선택 --' %></option>
                            <% availableGroups.forEach(function(group) { %>
                            <option value="<%= group.id %>"><%= group.name %></option>
                            <% }); %>
                        </select>
                        <div class="req-group-dd" id="reqGroupDd">
                            <button type="button" id="reqGroupBtn" class="modern-input req-group-dd-btn" onclick="toggleReqGroupMenu(event)">
                                <span id="reqGroupLabel" class="req-group-label"><%= isEnglish ? '-- Select Group --' : '-- 그룹 선택 --' %></span>
                                <i class="ti ti-chevron-down" aria-hidden="true"></i>
                            </button>
                            <div id="reqGroupMenu" class="req-group-dd-menu">
                                <button type="button" class="req-group-dd-item active" data-value="" onclick="setReqGroupFilter('', this)"><%= isEnglish ? '-- Select Group --' : '-- 그룹 선택 --' %></button>
                                <% availableGroups.forEach(function(group) { %>
                                <button type="button" class="req-group-dd-item" data-value="<%= group.id %>" onclick="setReqGroupFilter('<%= group.id %>', this)"><%= group.name %></button>
                                <% }); %>
                            </div>
                        </div>
                        <div id="req-quota-info" class="quota-info"></div>
                    </div>
                    <% } else if (autoSelectGroup) { %>
                    <input type="hidden" id="req-group" value="<%= autoSelectGroup.id %>">
                    <div>
                        <label class="modern-label">Group</label>
                        <input type="text" class="modern-input" value="<%= autoSelectGroup.name %>" readonly>
                        <div id="req-quota-info" class="quota-info"></div>
                    </div>
                    <script>
                    document.addEventListener('DOMContentLoaded', function() {
                        loadGroupQuota('<%= autoSelectGroup.id %>');
                    });
                    </script>
                    <% } %>
                </div>

                <!-- Instance Type Selection -->
                <div class="form-section">
                    <div class="form-section-title">
                        <i class="ti ti-server icon" aria-hidden="true"></i>
                        <span><%= isEnglish ? 'Select Instance Type' : '인스턴스 타입 선택' %></span>
                        <span class="required">*</span>
                    </div>
                    <div class="instance-type-grid" id="instanceTypeGrid">
                        <% if (instanceTypes && instanceTypes.length > 0) { %>
                            <% instanceTypes.forEach(function(t) { %>
                            <%
                            let iconClass = 'ti ti-server';
                            if (t.name === 'SMALL') iconClass = 'ti ti-server';
                            else if (t.name === 'MEDIUM') iconClass = 'ti ti-cpu';
                            else if (t.name === 'LARGE') iconClass = 'ti ti-database';
                            else if (t.name === 'XLARGE') iconClass = 'ti ti-cloud-computing';
                            else if (t.name === '2XLARGE') iconClass = 'ti ti-stack-2';
                            %>
                            <div class="instance-card" data-type="<%= t.name %>"
                                 data-cpu="<%= t.cpuCores %>" data-mem="<%= t.memoryMb %>" data-disk="<%= t.diskSizeGb %>"
                                 onclick="selectInstanceType(this)">
                                <div class="instance-card-icon"><i class="<%= iconClass %>" aria-hidden="true"></i></div>
                                <div class="card-name"><%= t.name %></div>
                                <div class="card-spec">
                                    <%= t.cpuCores %> vCPU<br>
                                    <%= Math.round(t.memoryMb/1024) %> GB RAM<br>
                                    <%= t.diskSizeGb %> GB Disk
                                </div>
                            </div>
                            <% }); %>
                        <% } %>
                        <div class="instance-card" data-type="CUSTOM" data-cpu="0" data-mem="0" data-disk="0"
                             onclick="selectInstanceType(this)">
                            <div class="instance-card-icon"><i class="ti ti-adjustments-horizontal" aria-hidden="true"></i></div>
                            <div class="card-name">CUSTOM</div>
                            <div class="card-spec card-spec-custom"><%= isEnglish ? 'Custom Config' : '커스텀 설정' %></div>
                            <div class="card-badge"><%= isEnglish ? 'Manual Input' : '직접 입력' %></div>
                        </div>
                    </div>

                    <!-- Custom Configuration Fields -->
                    <div class="custom-fields" id="customFields">
                        <div>
                            <label class="modern-label">vCPU</label>
                            <input type="number" id="req-cpu" class="modern-input" min="1" max="128" value="4">
                        </div>
                        <div>
                            <label class="modern-label">Memory (GB)</label>
                            <input type="number" id="req-mem-gb" class="modern-input" min="1" max="1024" value="8">
                        </div>
                        <div>
                            <label class="modern-label">Disk (GB)</label>
                            <input type="number" id="req-disk" class="modern-input" min="10" max="10000" value="100">
                        </div>
                    </div>

                    <!-- OS Selection -->
                    <div class="form-section-title" style="margin-top: 1rem;">
                        <i class="ti ti-device-desktop icon" aria-hidden="true"></i>
                        <span><%= isEnglish ? 'Select OS' : 'OS 선택' %></span>
                        <span class="required">*</span>
                    </div>
                    <div class="os-type-grid" id="osTypeGrid">
                        <div class="os-card" data-os="ubuntu-24.04" onclick="selectOs(this)">
                            <div class="os-card-icon">
                                <img src="/images/ubuntu-linux-logo.svg" alt="Ubuntu" class="os-logo-ubuntu os-logo-ubuntu-default">
                                <img src="/images/ubuntu-linux-logo-dark.svg" alt="Ubuntu" class="os-logo-ubuntu os-logo-ubuntu-dark">
                            </div>
                            <div class="card-name">Ubuntu 24.04</div>
                        </div>
                        <div class="os-card" data-os="rocky-10" onclick="selectOs(this)">
                            <div class="os-card-icon">
                                <img src="/images/rocky-linux-logo.svg" alt="Rocky Linux" class="os-logo-rocky os-logo-rocky-default">
                                <img src="/images/rocky-linux-logo-dark.svg" alt="Rocky Linux" class="os-logo-rocky os-logo-rocky-dark">
                            </div>
                            <div class="card-name">Rocky Linux 10</div>
                        </div>
                    </div>

                    <!-- VM Count (shown after instance selection) -->
                    <div id="vmCountSection" class="vm-count-section">
                        <label class="modern-label"><%= isEnglish ? 'VM Count' : 'VM 수량' %> <span class="required">*</span></label>
                        <input type="number" id="req-count" class="modern-input vm-count-input" min="1" max="50" value="1">
                    </div>
                </div>

                <!-- VM Configuration -->
                <div class="form-section form-section-hidden" id="vmConfigSection">
                    <div class="form-section-title">
                        <i class="ti ti-settings icon" aria-hidden="true"></i>
                        <span><%= isEnglish ? 'VM Information' : 'VM 정보' %></span>
                    </div>
                    <div class="info-box">
                        <i class="ti ti-info-circle info-box-icon" aria-hidden="true"></i>
                        <span><%= isEnglish ? 'Hostname and VMID are assigned automatically after admin approval.' : 'Hostname과 VMID는 관리자 승인 시 자동으로 할당됩니다' %></span>
                    </div>
                </div>

                <!-- Additional Disk Section (shown after instance selection) -->
                <div class="form-section form-section-hidden" id="extraDiskSection">
                    <div class="form-section-title">
                        <i class="ti ti-device-sd-card icon" aria-hidden="true"></i>
                        <span><%= isEnglish ? 'Additional Disk (Optional)' : '추가 디스크 (선택사항)' %></span>
                    </div>
                    <div>
                        <label class="modern-label"><%= isEnglish ? 'Additional Disk Size (GB)' : '추가 디스크 크기 (GB)' %></label>
                        <input type="number"
                               id="req-extra-gb"
                               class="modern-input"
                               min="0"
                               max="10000"
                               value="0"
                               placeholder="<%= isEnglish ? 'e.g., 50 (0 = none)' : '예: 50 (0이면 추가 안 함)' %>">
                    </div>
                    <div class="info-box info-box-top">
                        <i class="ti ti-bulb info-box-icon" aria-hidden="true"></i>
                        <span><%= isEnglish ? 'An extra disk will be mounted at /data automatically. (0 = not created)' : '추가 디스크는 /data로 자동 마운트됩니다. (0 입력 시 미생성)' %></span>
                    </div>
                </div>

                <!-- Purpose Section -->
                <div class="form-section form-section-hidden" id="purposeSection">
                    <div class="form-section-title">
                        <i class="ti ti-file-description icon" aria-hidden="true"></i>
                        <span><%= isEnglish ? 'Request Purpose' : '요청 사유' %></span>
                    </div>
                    <textarea id="req-purpose" class="modern-input" rows="3" placeholder="<%= isEnglish ? 'Briefly describe why you need this VM (optional)' : 'VM을 요청하는 이유를 간단히 입력해주세요 (선택사항)' %>"></textarea>
                </div>

                <!-- Error Message -->
                <p class="error-msg req-error-center" id="reqError"></p>

                <!-- Submit Button -->
                <button class="btn-submit-request hidden" id="reqSubmitBtn" onclick="submitVmRequest()">
                    <i class="ti ti-send" aria-hidden="true"></i> <%= isEnglish ? 'Submit VM Create Request' : 'VM 생성 요청 제출' %>
                </button>
            </div>
        </div>

        <!-- Request History -->
        <div class="request-history-wrap">
            <div class="request-history-header">
                <i class="ti ti-history" aria-hidden="true"></i>
                <span><%= isEnglish ? 'VM Create History' : '요청 내역' %></span>
            </div>

            <% if (vmRequests && vmRequests.length > 0) { %>
            <div class="request-history-table">
                <table class="req-table">
                    <thead>
                        <%
                        const reqHdrs = sectionLabels?.dashboard?.vm_request_history?.table_headers || [];
                        const reqHdr = (key, enFb, koFb) => {
                            const h = reqHdrs.find(h => h.header_key === key);
                            return h ? h.display_name : (isEnglish ? enFb : koFb);
                        };
                        %>
                        <tr>
                            <th><%= reqHdr('DATE', 'Date', 'Date') %></th>
                            <th><%= reqHdr('REQUESTER', 'Requester', '요청자') %></th>
                            <th><%= reqHdr('GROUP', 'Group', 'Group') %></th>
                            <th><%= reqHdr('TYPE', 'Type', 'Type') %></th>
                            <th><%= reqHdr('COUNT', 'Count', 'Count') %></th>
                            <th><%= reqHdr('SPEC', 'Spec', 'Spec') %></th>
                            <th><%= reqHdr('STATUS', 'Status', 'Status') %></th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        <% vmRequests.forEach(function(r) { %>
                        <tr>
                            <td class="td-082"><%= r.createdAt ? new Date(r.createdAt).toISOString().split('T')[0] : '-' %></td>
                            <td class="td-082"><%= r.requesterEmail || '-' %></td>
                            <td><span class="badge badge-group"><%= r.group.name %></span></td>
                            <td class="req-type"><%= r.instanceType %></td>
                            <td><span class="req-count"><%= r.vmCount %></span></td>
                            <td class="req-spec">
                                <div class="req-spec-row">
                                    <span><i class="ti ti-cpu" aria-hidden="true"></i> <%= r.cpuCores %>vCPU</span>
                                    <span><i class="ti ti-brain" aria-hidden="true"></i> <%= Math.round(r.memoryMb/1024) %>GB</span>
                                    <span><i class="ti ti-device-sd-card" aria-hidden="true"></i> <%= r.diskSizeGb %>GB</span>
                                </div>
                            </td>
                            <td>
                                <%
                                const statusMap = {
                                    REQUESTED: { class: 'status-requested', icon: 'ti ti-hourglass', label: isEnglish ? 'Requested' : '대기중' },
                                    APPROVED: { class: 'status-approved', icon: 'ti ti-circle-check', label: isEnglish ? 'Approved' : '승인됨' },
                                    DEPLOYING: { class: 'status-deploying', icon: 'ti ti-loader-2', label: isEnglish ? 'Deploying' : '배포중' },
                                    COMPLETED: { class: 'status-completed', icon: 'ti ti-checks', label: isEnglish ? 'Completed' : '완료' },
                                    FAILED: { class: 'status-failed', icon: 'ti ti-alert-circle', label: isEnglish ? 'Failed' : '실패' },
                                    PARTIAL: { class: 'status-partial', icon: 'ti ti-alert-triangle', label: isEnglish ? 'Partial' : '부분완료' },
                                    CANCELLED: { class: 'status-cancelled', icon: 'ti ti-ban', label: isEnglish ? 'Cancelled' : '취소됨' },
                                    REJECTED: { class: 'status-rejected', icon: 'ti ti-square-x', label: isEnglish ? 'Rejected' : '반려됨' },
                                    QUOTA_EXCEEDED: { class: 'status-quota_exceeded', icon: 'ti ti-chart-arcs-3', label: isEnglish ? 'Quota Exceeded' : '쿼터초과' },
                                };
                                const st = statusMap[r.status] || { class: '', icon: 'ti ti-circle', label: r.status };
                                %>
                                <span class="status-badge <%= st.class %>"><i class="<%= st.icon %>" aria-hidden="true"></i><%= st.label %></span>
                                <% if (r.reviewNote) { %>
                                    <span title="<%= r.reviewNote %>" class="review-note"><i class="ti ti-message-circle" aria-hidden="true"></i></span>
                                <% } %>
                            </td>
	                            <td>
	                                <% if (r.status === 'REQUESTED' || r.status === 'QUOTA_EXCEEDED') { %>
	                                <button class="btn btn-cancel-req" onclick="cancelVmRequest('<%= r.id %>')"><%= isEnglish ? 'Cancel' : '취소' %></button>
	                                <% } %>
	                            </td>
	                        </tr>
                        <% }); %>
                    </tbody>
                </table>
            </div>
            <% } else { %>
	            <div class="empty-request-box">
	                <div class="empty-request-icon"><i class="ti ti-inbox" aria-hidden="true"></i></div>
	                <p class="empty-request-title"><%= isEnglish ? 'No VM create history' : 'VM 생성 요청 내역이 없습니다' %></p>
	                <p class="empty-request-subtitle"><%= isEnglish ? 'Fill out the form above to request your first VM.' : '위의 양식을 작성하여 첫 VM을 요청해보세요' %></p>
	            </div>
	            <% } %>
	        </div>
        </div>
    </div>
    </div><!-- /tab-vm-request -->
    <% } %>

    <!-- Tab: 내 VM 목록 -->
    <div id="tab-vms" class="tab-content active">
    <div class="section">
        <div class="section-header">
            <span><%= localeLabel(sectionLabels?.dashboard?.jobs_vms?.title, 'Jobs & VMs', 'Jobs & VMs') %></span>
            <div class="section-tools">
                <div class="search-box">
                    <input type="text" id="vmSearch" autocomplete="off" placeholder="<%= localeLabel(uuidLabels?.placeholders?.['ph-017'], 'VMID, 호스트명, IP, 그룹으로 검색...', 'Search VMID, hostname, IP, Group...') %>" onkeyup="filterVMs()">
                    <span class="badge badge-count"><%= jobs.length %> jobs</span>
                </div>
                <%
                // 대시보드 섹션의 버튼들 가져오기
                const dashboardButtons = sectionLabels?.dashboard?.jobs_vms?.buttons || [];
                const exportBtn = dashboardButtons.find(b => b.button_key === 'EXPORT_MY_VMS' && b.is_visible);
                const addVmBtn = dashboardButtons.find(b => b.button_key === 'ADD_EXISTING_VM' && b.is_visible);
                %>
                <% if (exportBtn) { %>
                <button class="btn btn-export" onclick="exportMyVMs()">
                    <i class="menu-icon ti ti-file-export" aria-hidden="true"></i><%= stripLeadingIconText(exportBtn.display_name) %>
                </button>
                <% } %>
                <% if (isAdmin && addVmBtn) { %>
                <%
                const rawAddVmLabel = stripLeadingIconText(addVmBtn.display_name);
                const normalizedAddVmLabel = (isEnglish && /[가-힣]/.test(rawAddVmLabel))
                    ? 'Add Existing VM'
                    : ((rawAddVmLabel === '기존 VM 추가' || rawAddVmLabel === '기존 VM 등록')
                        ? 'VM 수동 추가'
                        : rawAddVmLabel);
                %>
                <button class="btn btn-add-vm" onclick="openAddVmModal()">
                    <i class="menu-icon ti ti-plus" aria-hidden="true"></i><%= normalizedAddVmLabel %>
                </button>
                <% } %>
            </div>
        </div>

        <%
        // 모든 VM을 하나의 배열로 평탄화
        let allVms = [];
        jobs.forEach(function(job) {
            if (job.vms && job.vms.length > 0) {
                job.vms.forEach(function(vm) {
                    // createdAt 안전하게 처리
                    let createdDate = '-';
                    if (job.createdAt) {
                        try {
                            const dateObj = typeof job.createdAt === 'string' ? new Date(job.createdAt) : job.createdAt;
                            createdDate = dateObj.toISOString().split('T')[0];
                        } catch (e) {
                            createdDate = '-';
                        }
                    }

                    allVms.push({
                        id: vm.id,
                        vmid: vm.vmid,
                        hostname: vm.hostname,
                        ip: vm.ip,
                        node: vm.node,
                        cpuCores: vm.cpuCores,
                        memoryMb: vm.memoryMb,
                        diskSizeGb: vm.diskSizeGb,
                        status: vm.status || 'unknown',
                        groupId: vm.groupId,
                        jobId: job.jobId,
                        jobIdShort: job.jobId.substring(0, 8),
                        group: vm.group.name,
                        created: createdDate,
                        osType: vm.osType || 'linux',
                        winUsername: vm.winUsername || null,
                        key: job.key
                    });
                });
            }
        });

        // Standalone VMs 추가
        standaloneVms.forEach(function(vm) {
            let createdDate = '-';
            if (vm.createdAt) {
                try {
                    const dateObj = typeof vm.createdAt === 'string' ? new Date(vm.createdAt) : vm.createdAt;
                    createdDate = dateObj.toISOString().split('T')[0];
                } catch (e) {
                    createdDate = '-';
                }
            }
            allVms.push({
                id: vm.id,
                vmid: vm.vmid,
                hostname: vm.hostname,
                ip: vm.ip,
                node: vm.node,
                cpuCores: vm.cpuCores,
                memoryMb: vm.memoryMb,
                diskSizeGb: vm.diskSizeGb,
                status: vm.status || 'unknown',
                groupId: vm.groupId,
                jobId: null,
                jobIdShort: '-',
                group: vm.group.name,
                created: createdDate,
                osType: vm.osType || 'linux',
                winUsername: vm.winUsername || null,
                key: null
            });
        });
        %>

	        <% if (allVms.length === 0) { %>
	            <div class="empty-state">
	                <p><%= isEnglish ? 'No VMs registered.' : '등록된 VM이 없습니다.' %></p>
	            </div>
	        <% } else { %>
            <table class="vm-table" id="vmTable">
                <thead>
                    <tr>
                        <th class="sortable" data-column="status" onclick="sortVMs('status')"><%= isEnglish ? 'VM Status' : 'VM 상태' %></th>
                        <th class="sortable" data-column="vmid" onclick="sortVMs('vmid')">VMID</th>
                        <th class="sortable" data-column="hostname" onclick="sortVMs('hostname')">Hostname</th>
                        <th class="sortable" data-column="ip" onclick="sortVMs('ip')">IP Address</th>
                        <th class="sortable" data-column="cpu" onclick="sortVMs('cpu')">CPU</th>
                        <th class="sortable" data-column="memory" onclick="sortVMs('memory')">Memory</th>
                        <th class="sortable" data-column="disk" onclick="sortVMs('disk')">Disk</th>
                        <th class="text-center"><%= isEnglish ? 'Power' : '전원' %></th>
                        <th>Job ID</th>
                        <th class="sortable" data-column="group" onclick="sortVMs('group')">Group</th>
                        <th class="sortable" data-column="created" onclick="sortVMs('created')">Created</th>
                        <th class="text-center"><%= isEnglish ? 'Key / Cred' : '자격증명' %></th>
                        <% if (isAdmin) { %>
                        <th class="text-center"><%= localeLabel(sectionLabels?.dashboard?.jobs_vms?.table_headers?.find(h => h.header_key === 'ACTIONS')?.display_name, '관리', 'Manage') %></th>
                        <% } %>
                    </tr>
                </thead>
                <tbody id="vmTableBody">
                    <!-- Will be rendered by JavaScript -->
                </tbody>
            </table>

	            <script>
	            const DASH_IS_ENGLISH = <%= isEnglish ? 'true' : 'false' %>;
	            const DASH_KEY_ROTATE_ADMIN_ONLY = <%= keyRotateAdminOnly ? 'true' : 'false' %>;
	            const DASH_IS_ADMIN = <%= isAdmin ? 'true' : 'false' %>;
	            // Pass server data to JavaScript
	            const allVmsData = <%- JSON.stringify(allVms) %>;
	            const allGroupsData = <%- JSON.stringify(allGroups.map(t => ({id: t.id, name: t.name}))) %>;
            const isAdmin = <%= isAdmin %>;

            // UUID-based labels for JavaScript usage
            const uuidLabels = <%- JSON.stringify(uuidLabels || {}) %>;
            const sectionLabels = <%- JSON.stringify(sectionLabels || {}) %>;
            const plainText = (value, fallback) => String(value || fallback || '').replace(/^[^A-Za-z0-9가-힣(\\[]+/u, '').trim();

            // Get button labels
            const dashboardButtons = sectionLabels?.dashboard?.jobs_vms?.buttons || [];
            const deleteLabel = dashboardButtons.find(b => b.button_key === 'DELETE_VM')?.display_name || (DASH_IS_ENGLISH ? 'Delete' : '삭제');
            const downloadLabel = dashboardButtons.find(b => b.button_key === 'DOWNLOAD_KEY')?.display_name || (DASH_IS_ENGLISH ? 'Download' : '다운로드');

            let sortColumn = null;
            let sortDirection = 'asc';

            function applyQuotaFillWidths(scope = document) {
                scope.querySelectorAll('.js-quota-fill').forEach(el => {
                    const raw = parseFloat(el.dataset.width || '0');
                    const pct = Number.isFinite(raw) ? Math.max(0, Math.min(100, raw)) : 0;
                    el.style.width = pct + '%';
                });
            }

            // Render VM table
            function renderVMTable(vms = allVmsData) {
                const tbody = document.getElementById('vmTableBody');
                if (!tbody) return;

                tbody.innerHTML = vms.map((vm, index) => {
                    const hasKey = vm.key && vm.key.fingerprint;
                    const isWindowsVm = vm.osType === 'windows' && vm.winUsername;
                    const rowClickHandler = (hasKey || isWindowsVm) ? `onclick="toggleKeySection(this, '${vm.jobId}', ${index})"` : '';

                    // Group column - display only (no dropdown)
                    const groupColumn = `<span class="badge badge-group">${vm.group}</span>`;

                    let keyColumn = '';
                    if (isWindowsVm) {
                        keyColumn = `<span id="toggle-text-${index}" class="toggle-key-link"><i class="ti ti-lock" aria-hidden="true"></i> ${DASH_IS_ENGLISH ? 'Click to view' : '클릭하여 보기'}</span>`;
                    } else if (hasKey) {
                        const clickToViewText = plainText(uuidLabels?.sshKey?.['ssh-006'], 'Click to view');
                        keyColumn = `<span id="toggle-text-${index}" class="toggle-key-link"><i class="ti ti-clipboard-text" aria-hidden="true"></i> ${clickToViewText}</span>`;
                    } else if (isAdmin) {
                        keyColumn = `
                            <button class="btn btn-sm btn-assign-job"
                                    onclick="event.stopPropagation(); openAssignJobModal('${vm.id}', '${vm.hostname || vm.vmid}')">
                                Assign Job
                            </button>
                        `;
                    } else {
                        keyColumn = `<span class="text-muted-08">-</span>`;
                    }

                    let actionsColumn = '';
                    if (isAdmin) {
                        actionsColumn = `
                            <td class="text-center">
                                <button class="btn btn-sm btn-delete-vm"
                                        onclick="event.stopPropagation(); confirmDeleteVm('${vm.id}', '${vm.hostname || vm.vmid}')">
                                    ${deleteLabel}
                                </button>
                            </td>
                        `;
                    }

                    // Format resource display
                    const cpuDisplay = vm.cpuCores ? `${vm.cpuCores} vCPU` : '-';
                    const memDisplay = vm.memoryMb ? (vm.memoryMb >= 1024 ? `${(vm.memoryMb / 1024).toFixed(0)} GB` : `${vm.memoryMb} MB`) : '-';
                    const diskDisplay = vm.diskSizeGb ? `${vm.diskSizeGb} GB` : '-';

	                    // VM Status badge
	                    const statusLabels = DASH_IS_ENGLISH
	                        ? { running: 'Running', stopped: 'Stopped', paused: 'Paused', unknown: '-' }
	                        : { running: '실행중', stopped: '중지', paused: '일시정지', unknown: '-' };
                    const statusIcons = {
                        running: 'ti ti-player-play',
                        stopped: 'ti ti-player-stop',
                        paused: 'ti ti-player-pause',
                        unknown: 'ti ti-help-circle'
                    };
                    const statusClass = `vm-status vm-status-${vm.status || 'unknown'}`;
                    const statusLabel = statusLabels[vm.status] || vm.status || '-';
                    const statusIcon = statusIcons[vm.status] || statusIcons.unknown;
                    const statusBadge = `<span class="${statusClass}"><i class="vm-status-icon ${statusIcon}" aria-hidden="true"></i>${statusLabel}</span>`;

                    // Power control buttons
                    const isRunning = vm.status === 'running';
                    const isStopped = vm.status === 'stopped';
	                    const powerButtons = vm.node && vm.vmid ? `
	                        <div class="power-actions">
	                            <button class="power-btn power-btn-start" title="${DASH_IS_ENGLISH ? 'Start' : '시작'}" ${isRunning ? 'disabled' : ''}
	                                    onclick="event.stopPropagation(); vmPower('${vm.id}', 'start')">&#9654;</button>
	                            <button class="power-btn power-btn-stop" title="${DASH_IS_ENGLISH ? 'Stop' : '중지'}" ${isStopped ? 'disabled' : ''}
	                                    onclick="event.stopPropagation(); vmPower('${vm.id}', 'stop')">&#9632;</button>
	                            <button class="power-btn power-btn-reboot" title="${DASH_IS_ENGLISH ? 'Reboot' : '재부팅'}" ${isStopped ? 'disabled' : ''}
	                                    onclick="event.stopPropagation(); vmPower('${vm.id}', 'reboot')">&#8635;</button>
	                        </div>
	                    ` : '<span class="text-muted-08">-</span>';

                    let keyRow = '';
                    if (isWindowsVm) {
                        const colspan = isAdmin ? 13 : 12;
                        keyRow = `
                            <tr class="key-row key-row-hidden" id="key-row-${index}">
                                <td colspan="${colspan}" class="td-no-pad">
                                    <div class="key-section show key-section-flat" id="cred-section-${index}">
                                        <div class="key-info">
                                            <span class="badge badge-key">Windows</span>
                                            <span class="fingerprint fingerprint-top">User: ${vm.winUsername}</span>
                                        </div>
                                        <div style="display:flex;gap:0.5rem;align-items:center;">
                                            <button class="btn btn-download"
                                                    onclick="event.stopPropagation(); openCredRevealModal('${vm.id}', '${(vm.winUsername || '').replace(/'/g, "\\'")}', ${index})">
                                                ${DASH_IS_ENGLISH ? 'Reveal' : '자격증명 보기'}
                                            </button>
                                            ${(!DASH_KEY_ROTATE_ADMIN_ONLY || DASH_IS_ADMIN) ? `
                                            <button class="btn btn-win-rotate"
                                                    data-vmid="${vm.id}"
                                                    onclick="event.stopPropagation(); openRotateWinPwModal(this.dataset.vmid)">
                                                ${IS_ENGLISH ? 'Change PW' : '비밀번호 변경'}
                                            </button>` : ''}
                                        </div>
                                    </div>
                                </td>
                            </tr>
                        `;
                    } else if (hasKey) {
                        const colspan = isAdmin ? 13 : 12;
                        keyRow = `
                            <tr class="key-row key-row-hidden" id="key-row-${index}">
                                <td colspan="${colspan}" class="td-no-pad">
                                    <div class="key-section show key-section-flat">
                                        <div class="key-info">
                                            <span class="badge badge-key">SSH Key: ${vm.key.keyVersion}</span>
                                            <span class="fingerprint fingerprint-top">${vm.key.fingerprint}</span>
                                        </div>
                                        <div style="display:flex;gap:0.5rem;align-items:center;">
                                            <button class="btn btn-download"
                                                    onclick="event.stopPropagation(); openDownloadModal('${vm.key.fingerprint}', '${vm.hostname || vm.vmid || "vm"}')">
                                                ${downloadLabel}
                                            </button>
                                            ${(!DASH_KEY_ROTATE_ADMIN_ONLY || DASH_IS_ADMIN) ? `
                                            <button class="btn btn-rotate" id="rotate-btn-${index}"
                                                    data-vmid="${vm.id}"
                                                    data-fp="${vm.key.fingerprint}"
                                                    data-hostname="${vm.hostname || vm.vmid || ''}"
                                                    onclick="event.stopPropagation(); openRotateModal(this.dataset.vmid, this.dataset.fp, this.dataset.hostname)">
                                                ${IS_ENGLISH ? 'Rotate Key' : '키 교체'}
                                            </button>` : ''}
                                        </div>
                                    </div>
                                </td>
                            </tr>
                        `;
                    }

                    return `
                        <tr class="vm-row"
                            data-hostname="${(vm.hostname || '').toLowerCase()}"
                            data-vmid="${vm.vmid || ''}"
                            data-ip="${vm.ip || ''}"
                            data-jobid="${vm.jobIdShort.toLowerCase()}"
                            data-group="${vm.group.toLowerCase()}"
                            data-status="${vm.status || 'unknown'}"
                            ${rowClickHandler}>
                            <td>${statusBadge}</td>
                            <td class="mono">${vm.vmid || '-'}</td>
                            <td class="vm-hostname">${vm.hostname || '-'}</td>
