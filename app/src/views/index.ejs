async function submitAssignJob() {
    const jobId = document.getElementById('jobSelect').value;
    if (!jobId) {
        document.getElementById('assignJobError').textContent = IS_ENGLISH ? 'Please select a job' : 'Job을 선택해 주세요';
        document.getElementById('assignJobError').style.display = 'block';
        return;
    }

    const btn = document.getElementById('assignJobBtn');
    btn.disabled = true;
    btn.textContent = IS_ENGLISH ? 'Assigning...' : '연결 중...';

    try {
        const response = await fetch(`/api/admin/vms/${currentVmId}/assign-job`, {
            method: 'PATCH',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ jobId })
        });
        if (response.status === 401) {
            window.location.href = '/auth/login?returnUrl=' + encodeURIComponent(location.pathname + location.search);
            return;
        }

        if (response.ok) {
            showToastMessage(IS_ENGLISH ? 'Job assigned successfully.' : '작업이 성공적으로 연결되었습니다.', 'success');
            setTimeout(function() { location.reload(); }, 500);
        } else {
            const error = await response.json();
            throw new Error(error.error || (IS_ENGLISH ? 'Failed to assign job.' : '작업 연결에 실패했습니다.'));
        }
    } catch (error) {
        console.error('Assign job error:', error);
        document.getElementById('assignJobError').textContent = error.message;
        document.getElementById('assignJobError').style.display = 'block';
        btn.disabled = false;
        btn.textContent = IS_ENGLISH ? 'Assign' : '연결';
    }
}

