                                                data-hostname="<%= vm.hostname || vm.vmid || '' %>"
                                                onclick="event.stopPropagation(); openRotateModal(this.dataset.vmid, this.dataset.fp, this.dataset.hostname)">
                                            <%= isEnglish ? 'Rotate Key' : '키 교체' %>
                                        </button>
                                        <% } %>
                                    </div>
	                                </div>
	                            </td>
	                        </tr>
                        <% } %>
                    <% }); %>
            <% } %>
        <% } %>
