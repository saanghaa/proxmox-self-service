let _credVmId = null, _credIndex = null, _credUsername = null;

function openCredRevealModal(vmId, username, index) {
    _credVmId = vmId;
    _credIndex = index;
    _credUsername = username;
    document.getElementById('credOtpInput').value = '';
    document.getElementById('credOtpError').textContent = '';
    document.getElementById('credOtpError').style.display = 'none';
    document.getElementById('credOtpSubmitBtn').disabled = false;
    document.getElementById('credOtpSubmitBtn').textContent = IS_ENGLISH ? 'Verify & View' : '인증 후 조회';
    document.getElementById('credOtpModal').classList.add('active');
    setTimeout(() => document.getElementById('credOtpInput').focus(), 100);
}

function closeCredOtpModal() {
    document.getElementById('credOtpModal').classList.remove('active');
}

async function submitCredReveal() {
    const otp = document.getElementById('credOtpInput').value.trim();
    const errEl = document.getElementById('credOtpError');
    const btn = document.getElementById('credOtpSubmitBtn');
    if (!otp || otp.length < 6) {
        errEl.textContent = IS_ENGLISH ? 'Enter your 6-digit OTP.' : '6자리 OTP를 입력하세요.';
        return;
    }

    btn.disabled = true;
    btn.textContent = IS_ENGLISH ? 'Verifying...' : '인증 중...';
    errEl.textContent = '';

    try {
        const res = await fetch('/api/vms/' + _credVmId + '/reveal-credentials', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ otp })
        });
        const data = await res.json();
        if (!res.ok) throw new Error(data.error || (IS_ENGLISH ? 'Failed' : '조회 실패'));

        closeCredOtpModal();

        const section = document.getElementById('cred-section-' + _credIndex);
        if (section) {
            const savedVmId = _credVmId;
            const savedUsername = _credUsername;
            const savedIndex = _credIndex;
            const pw = data.password;
            section.innerHTML =
                '<div class="key-info">' +
                '<span class="badge badge-key">Windows</span>' +
                '<span class="fingerprint fingerprint-top">ID: ' + escHtml(data.username) + '</span>' +
                '<span class="fingerprint fingerprint-top" id="cred-pw-' + savedIndex + '">PW: \u2022\u2022\u2022\u2022\u2022\u2022\u2022\u2022</span>' +
                '</div>' +
                '<div style="display:flex;gap:0.5rem;">' +
                '<button class="btn btn-download" onclick="event.stopPropagation();toggleCredPw(' + savedIndex + ')">' + (IS_ENGLISH ? 'Show' : '보기') + '</button>' +
                '<button class="btn btn-secondary" onclick="event.stopPropagation();copyCredPw(this,' + savedIndex + ')">' + (IS_ENGLISH ? 'Copy Password' : '비밀번호 복사') + '</button>' +
                '</div>';

            // Store password in closure for toggle
            window['_credPw_' + savedIndex] = pw;

            // Auto-hide after 30s
            setTimeout(() => {
                const s = document.getElementById('cred-section-' + savedIndex);
                if (s) {
                    s.innerHTML =
                        '<div class="key-info"><span class="badge badge-key">Windows</span>' +
                        '<span class="fingerprint fingerprint-top">User: ' + escHtml(savedUsername) + '</span></div>' +
                        '<div style="display:flex;gap:0.5rem;align-items:center;">' +
                        '<button class="btn btn-download" onclick="event.stopPropagation();openCredRevealModal(\'' + savedVmId + '\',\'' + escHtml(savedUsername).replace(/'/g, "\\'") + '\',' + savedIndex + ')">' +
                        (IS_ENGLISH ? 'Reveal' : '자격증명 보기') + '</button>' +
                        ((!DASH_KEY_ROTATE_ADMIN_ONLY || DASH_IS_ADMIN) ?
                            '<button class="btn btn-win-rotate" onclick="event.stopPropagation();openRotateWinPwModal(\'' + savedVmId + '\')">' +
                            (IS_ENGLISH ? 'Change PW' : '비밀번호 변경') + '</button>' : '') +
                        '</div>';
                }
                delete window['_credPw_' + savedIndex];
            }, 30000);
        }
    } catch (e) {
        errEl.style.display = 'block';
        errEl.textContent = (IS_ENGLISH ? 'Failed: ' : '실패: ') + e.message;
        btn.disabled = false;
        btn.textContent = IS_ENGLISH ? 'Verify & View' : '인증 후 조회';
    }
}

function toggleCredPw(index) {
    const el = document.getElementById('cred-pw-' + index);
    if (!el) return;
    const pw = window['_credPw_' + index] || '';
    const isHidden = el.textContent.includes('\u2022');
    el.textContent = isHidden ? 'PW: ' + pw : 'PW: \u2022\u2022\u2022\u2022\u2022\u2022\u2022\u2022';
}

function copyCredPw(btnEl, index) {
    const pw = window['_credPw_' + index] || '';
    const btn = btnEl || null;
    const originalLabel = btn ? btn.textContent : null;
    if (!pw) {
        if (btn && originalLabel) {
            btn.textContent = IS_ENGLISH ? 'No Password' : '비밀번호 없음';
            setTimeout(() => { btn.textContent = originalLabel; }, 1500);
        }
        return;
    }
    copyTextWithFallback(pw).then((ok) => {
        if (!btn || !originalLabel) return;
        btn.textContent = ok
            ? (IS_ENGLISH ? 'Copied' : '복사됨')
            : (IS_ENGLISH ? 'Copy failed' : '복사 실패');
        setTimeout(() => { btn.textContent = originalLabel; }, 1500);
    });
}

function escHtml(str) {
    if (!str) return '';
    return String(str).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
}

function openDownloadModal(fingerprint, hostname) {
    currentFingerprint = fingerprint;
    currentHostname = hostname || 'vm';
    document.getElementById('otpInput').value = '';
    document.getElementById('otpError').style.display = 'none';
    document.getElementById('otpSubmitBtn').disabled = false;
    document.getElementById('otpSubmitBtn').textContent = IS_ENGLISH ? 'Verify & Download' : '인증 후 다운로드';
    document.getElementById('otpModal').classList.add('active');

    // 1단계: Challenge 발급 요청
    fetch('/api/download/prepare', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ fingerprint, hostname })
    })
    .then(r => r.json())
    .then(data => {
        if (data.challenge_id) {
            currentChallengeId = data.challenge_id;
            document.getElementById('otpInput').focus();
        } else {
            showError(IS_ENGLISH ? 'Failed to create challenge.' : 'Challenge 생성에 실패했습니다.');
        }
    })
    .catch(() => showError(IS_ENGLISH ? 'Network error. Please try again.' : '네트워크 오류. 다시 시도해 주세요.'));
}

function submitDownload() {
    const otp = document.getElementById('otpInput').value.trim();
    if (!otp || otp.length !== 6) {
        showError(IS_ENGLISH ? 'Please enter a 6-digit OTP code.' : '6자리 OTP 코드를 입력해 주세요.');
        return;
    }
    if (!currentChallengeId) {
        showError(IS_ENGLISH ? 'Challenge expired. Close the dialog and try again.' : 'Challenge가 만료되었습니다. 창을 닫고 다시 시도해 주세요.');
        return;
    }

    const btn = document.getElementById('otpSubmitBtn');
    btn.disabled = true;
    btn.textContent = IS_ENGLISH ? 'Verifying...' : '인증 중...';

    // 2단계: OTP 검증 + 키 다운로드
    fetch('/api/download/key', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
            fingerprint: currentFingerprint,
            challenge_id: currentChallengeId,
            hostname: currentHostname,
            otp: otp
        })
    })
    .then(async (response) => {
        if (response.ok) {
            const blob = await response.blob();
            const disposition = response.headers.get('Content-Disposition') || '';
            const match = disposition.match(/filename="?(.+?)"?$/);
            const filename = match ? match[1] : 'ssh_key.pem';

            const url = window.URL.createObjectURL(blob);
            const a = document.createElement('a');
            a.href = url;
            a.download = filename;
            document.body.appendChild(a);
            a.click();
            a.remove();
            window.URL.revokeObjectURL(url);

            closeModal();
        } else {
            const err = await response.json();
            if (err.error === 'INVALID_OTP') {
                showError(IS_ENGLISH ? 'Invalid OTP code. Please try again.' : 'OTP 코드가 일치하지 않습니다. 다시 입력해 주세요.');
            } else if (err.error === 'CHALLENGE_EXPIRED') {
                showError(IS_ENGLISH ? 'Challenge expired (60s). Close the dialog and try again.' : 'Challenge가 만료되었습니다 (60초). 창을 닫고 다시 시도해 주세요.');
                currentChallengeId = null;
            } else {
                showError(err.message || (IS_ENGLISH ? 'Download failed.' : '다운로드에 실패했습니다.'));
            }
        }
    })
    .catch(() => showError(IS_ENGLISH ? 'Network error occurred.' : '네트워크 오류가 발생했습니다.'))
    .finally(() => {
        btn.disabled = false;
        btn.textContent = IS_ENGLISH ? 'Verify & Download' : '인증 후 다운로드';
    });
}

function showError(msg) {
    const el = document.getElementById('otpError');
    el.textContent = msg;
    el.style.display = 'block';
}

function closeModal() {
    document.getElementById('otpModal').classList.remove('active');
    currentFingerprint = null;
    currentChallengeId = null;
}

