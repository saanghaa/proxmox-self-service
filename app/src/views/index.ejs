function openRotateModal(vmId, fingerprint, hostname) {
    currentRotateVmId = vmId;
    currentRotateHostname = hostname || '';
    currentRotateChallengeId = null;
    document.getElementById('rotateOtpInput').value = '';
    document.getElementById('rotateOtpError').style.display = 'none';
    document.getElementById('rotateOtpError').textContent = '';
    const btn = document.getElementById('rotateOtpSubmitBtn');
    btn.disabled = false;
    btn.textContent = IS_ENGLISH ? 'Verify & Rotate' : '인증 후 교체';
    document.getElementById('rotateOtpModal').classList.add('active');

    fetch(`/api/vms/${vmId}/rotate-key/prepare`, { method: 'POST' })
        .then(r => r.json())
        .then(data => {
            if (data.challenge_id) {
                currentRotateChallengeId = data.challenge_id;
                setTimeout(() => document.getElementById('rotateOtpInput').focus(), 100);
            } else if (data.error === 'VM_NOT_RUNNING') {
                showRotateError(IS_ENGLISH
                    ? `VM is not running (${data.detail || 'stopped'}). Start the VM first.`
                    : `VM이 실행 중이 아닙니다. VM을 먼저 시작하세요.`);
            } else if (data.error === 'AGENT_UNAVAILABLE') {
                showRotateError(IS_ENGLISH
                    ? 'Guest Agent is not responding. Check that qemu-guest-agent is installed and running.'
                    : 'Guest Agent가 응답하지 않습니다. qemu-guest-agent 설치·실행 여부를 확인하세요.');
            } else if (data.error === 'PVE_NODE_OFFLINE') {
                showRotateError(IS_ENGLISH ? 'Proxmox node is offline.' : 'Proxmox 노드가 오프라인입니다.');
            } else {
                showRotateError(data.error || (IS_ENGLISH ? 'Failed to initiate rotation.' : '교체 시작에 실패했습니다.'));
            }
        })
        .catch(() => showRotateError(IS_ENGLISH ? 'Network error.' : '네트워크 오류.'));
}

function closeRotateModal() {
    document.getElementById('rotateOtpModal').classList.remove('active');
    currentRotateVmId = null;
    currentRotateChallengeId = null;
    currentRotateHostname = null;
}

function showRotateError(msg) {
    const el = document.getElementById('rotateOtpError');
    el.textContent = msg;
    el.style.display = 'block';
}

async function submitRotate() {
    const otp = document.getElementById('rotateOtpInput').value.trim();
    if (!otp || otp.length !== 6) {
        showRotateError(IS_ENGLISH ? 'Enter a 6-digit OTP.' : '6자리 OTP를 입력하세요.');
        return;
    }
    if (!currentRotateChallengeId) {
        showRotateError(IS_ENGLISH ? 'Challenge expired. Close and retry.' : 'Challenge 만료. 닫고 다시 시도하세요.');
        return;
    }
    const btn = document.getElementById('rotateOtpSubmitBtn');
    btn.disabled = true;
    btn.textContent = IS_ENGLISH ? 'Rotating...' : '교체 중...';
    try {
        const response = await fetch(`/api/vms/${currentRotateVmId}/rotate-key`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ challenge_id: currentRotateChallengeId, otp })
        });
        const data = await response.json();
        if (response.ok) {
            const savedVmId = currentRotateVmId;
            const savedHostname = currentRotateHostname;
            const newFingerprint = data.newFingerprint;
            const oldKeyRemoved = data.oldKeyRemoved === true;
            closeRotateModal();
            // allVmsData 갱신 후 재렌더
            if (typeof allVmsData !== 'undefined') {
                const vm = allVmsData.find(v => v.id === savedVmId);
                if (vm && vm.key) { vm.key.fingerprint = newFingerprint; vm.key.keyVersion = data.keyVersion; }
                if (typeof renderVMTable === 'function') renderVMTable(allVmsData);
            }
            // 키 자동 다운로드 (OTP 재입력 불필요)
            if (data.privateKey) {
                const blob = new Blob([data.privateKey], { type: 'application/x-pem-file' });
                const url = URL.createObjectURL(blob);
                const a = document.createElement('a');
                a.href = url;
                a.download = `${savedHostname}_${data.keyVersion}.pem`;
                document.body.appendChild(a);
                a.click();
                document.body.removeChild(a);
                URL.revokeObjectURL(url);
            }
            // 토스트
            const t = document.getElementById('toast');
            if (t) {
                t.textContent = oldKeyRemoved
                    ? (IS_ENGLISH ? 'Key rotated & downloaded.' : '키 교체 완료, 다운로드됐습니다.')
                    : (IS_ENGLISH ? 'Key rotated. Old key removal failed — check VM manually.' : '키 교체됐지만 구 키 제거 실패. VM 수동 확인 필요.');
                t.style.background = oldKeyRemoved ? '#059669' : '#b45309';
                t.classList.add('show');
                setTimeout(() => { t.classList.remove('show'); t.style.background = ''; }, 3000);
            }
        } else {
            if (data.error === 'INVALID_OTP') {
                showRotateError(IS_ENGLISH ? 'Invalid OTP. Try again.' : 'OTP가 틀렸습니다.');
            } else if (data.error === 'CHALLENGE_EXPIRED') {
                showRotateError(IS_ENGLISH ? 'Challenge expired (60s). Close and retry.' : 'Challenge 만료(60초). 닫고 다시 시도하세요.');
                currentRotateChallengeId = null;
            } else if (data.error === 'AGENT_EXEC_FAILED') {
                showRotateError((IS_ENGLISH ? 'Agent exec failed: ' : 'Guest Agent 실행 실패: ') + (data.detail || ''));
            } else {
                showRotateError(data.error || (IS_ENGLISH ? 'Rotation failed.' : '교체에 실패했습니다.'));
            }
            btn.disabled = false;
            btn.textContent = IS_ENGLISH ? 'Verify & Rotate' : '인증 후 교체';
        }
    } catch (err) {
        showRotateError(IS_ENGLISH ? 'Network error.' : '네트워크 오류.');
        btn.disabled = false;
        btn.textContent = IS_ENGLISH ? 'Verify & Rotate' : '인증 후 교체';
    }
}

