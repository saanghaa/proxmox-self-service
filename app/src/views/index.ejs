function applyThemeTemplate(template) {
    document.body.className = String(document.body.className || '')
        .replace(/theme-template-\w+/g, '')
        .trim() + ' theme-template-' + template;
}

function updateThemeMenuUI(template) {
    document.querySelectorAll('.theme-item').forEach(item => {
        item.classList.toggle('current', item.dataset.themeTemplate === template);
    });
}

async function changeThemeTemplate(template) {
    try {
        const response = await fetch('/api/theme-template', {
            method: 'PATCH',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ template })
        });
        const data = await response.json();
        if (!response.ok || !data.ok) throw new Error(data.error || 'THEME_UPDATE_FAILED');

        applyThemeTemplate(template);
        updateThemeMenuUI(template);
        closePersonalMenu();

        showToastMessage(
            IS_ENGLISH ? 'Theme updated.' : '테마가 변경되었습니다.',
            'success',
            1800
        );
    } catch (error) {
        console.error('Theme change error:', error);
        showToastMessage(
            (IS_ENGLISH ? 'Theme update failed: ' : '테마 변경 실패: ') + (error?.message || ''),
            'error',
            2600
        );
    }
}

