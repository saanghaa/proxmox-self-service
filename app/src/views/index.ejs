	                    <%= isEnglish ? 'Upload the existing SSH key pair from your VM. The private key is required.' : '기존 VM의 SSH 키 페어를 업로드하세요. 개인 키는 필수입니다.' %>
	                </p>
	                <div class="form-group form-group-mb-05">
	                    <label class="label-08"><%= isEnglish ? 'Private Key (Required)' : '개인 키 (필수)' %> *</label>
	                    <div class="file-picker">
	                        <input type="file" id="vm-private-key" name="privateKey" required accept=".pem,.key,.txt" class="input-file-08 file-native">
	                        <button type="button" class="file-btn" onclick="document.getElementById('vm-private-key').click()"><%= isEnglish ? 'Choose file' : '파일 선택' %></button>
	                        <span class="file-name" id="vm-private-key-name"><%= isEnglish ? 'No file selected' : '선택된 파일 없음' %></span>
	                    </div>
	                </div>
	                <div class="form-group form-group-mb-0">
	                    <label class="label-08"><%= isEnglish ? 'Public Key (Optional)' : '공개 키 (선택)' %></label>
	                    <div class="file-picker">
	                        <input type="file" id="vm-public-key" name="publicKey" accept=".pub,.txt" class="input-file-08 file-native">
	                        <button type="button" class="file-btn" onclick="document.getElementById('vm-public-key').click()"><%= isEnglish ? 'Choose file' : '파일 선택' %></button>
	                        <span class="file-name" id="vm-public-key-name"><%= isEnglish ? 'No file selected' : '선택된 파일 없음' %></span>
	                    </div>
	                    <small class="small-note-07"><%= isEnglish ? 'If not provided, it will be derived from the private key.' : '입력하지 않으면 개인 키에서 자동 추출됩니다.' %></small>
	                </div>
	            </div>
	            </div>
	            <div id="win-cred-section" style="display:none;">
	            <div class="ssh-upload-box">
	                <p class="ssh-upload-title">
	                    <strong><i class="ti ti-lock" aria-hidden="true"></i> <%= isEnglish ? 'Windows Credentials' : 'Windows 자격증명' %></strong><br>
	                    <%= isEnglish ? 'Enter the Windows login credentials for this VM.' : 'Windows VM 접속 자격증명을 입력하세요.' %>
	                </p>
	                <div class="form-group form-group-mb-05">
	                    <label class="label-08"><%= isEnglish ? 'Username' : '사용자명' %> *</label>
	                    <input type="text" id="vm-win-username" placeholder="<%= isEnglish ? 'e.g., Administrator' : '예: Administrator' %>">
	                </div>
	                <div class="form-group form-group-mb-0">
	                    <label class="label-08"><%= isEnglish ? 'Password' : '비밀번호' %> *</label>
	                    <div class="pw-wrapper">
	                        <input type="password" id="vm-win-password" placeholder="<%= isEnglish ? 'Password' : '비밀번호' %>">
	                        <button type="button" class="pw-toggle" onclick="(function(btn){var inp=document.getElementById('vm-win-password');var show=inp.type==='password';inp.type=show?'text':'password';btn.querySelector('i').className=show?'ti ti-eye-off':'ti ti-eye';})(this)" aria-label="비밀번호 표시">
	                            <i class="ti ti-eye"></i>
	                        </button>
	                    </div>
	                </div>
	            </div>
	            </div>
	            <div class="btn-row">
	                <button type="button" class="btn btn-danger" onclick="closeAllModals()"><%= isEnglish ? 'Cancel' : '취소' %></button>
	                <button type="submit" class="btn btn-primary"><%= isEnglish ? 'Add VM' : 'VM 수동 추가' %></button>
	            </div>
	        </form>
	    </div>
	</div>

<script>
    function normalizeVmHostname(raw, vmidHint) {
        const fallback = (IS_ENGLISH ? 'vm-' : 'vm-') + String(vmidHint || '').trim();
        const text = String(raw || '').trim();
        if (!text) return fallback || 'vm-host';
        let normalized = text
            .toLowerCase()
            .replace(/\s+/g, '-')
            .replace(/[^a-z0-9-]/g, '-')
            .replace(/-+/g, '-')
            .replace(/^-+|-+$/g, '');
        if (!normalized) normalized = fallback || 'vm-host';
        if (/^\d/.test(normalized)) normalized = 'vm-' + normalized;
        return normalized.slice(0, 63);
    }

	// Add VM form submit handler (must be after modal HTML)
	document.getElementById('addVmForm').addEventListener('submit', async (e) => {
	    e.preventDefault();
    if (window.__manualVmSubmitting) return;

    const vmidRaw = document.getElementById('vm-vmid').value;
    const hostnameRaw = document.getElementById('vm-hostname').value;
    const vmid = parseInt(vmidRaw, 10);
    const hostname = normalizeVmHostname(hostnameRaw, vmid);
    document.getElementById('vm-hostname').value = hostname;

    if (!Number.isInteger(vmid) || vmid < 100) {
        showToastMessage(IS_ENGLISH ? 'Please enter a valid VMID (100 or higher).' : '올바른 VMID(100 이상)를 입력해 주세요.', 'warning');
        return;
    }

    if (!hostname) {
        showToastMessage(IS_ENGLISH ? 'Hostname is required.' : '호스트명을 입력해 주세요.', 'warning');
        return;
    }

    const formData = new FormData();
    formData.append('vmid', String(vmid));
    formData.append('hostname', hostname);

    const ip = document.getElementById('vm-ip').value.trim();
    if (ip) formData.append('ip', ip);

    const node = document.getElementById('vm-node').value.trim();
    if (node) formData.append('node', node);

    const cpuCores = document.getElementById('vm-cpu').value;
    if (cpuCores) formData.append('cpuCores', cpuCores);

    const memoryGb = document.getElementById('vm-memory').value;
    if (memoryGb) formData.append('memoryMb', String(parseInt(memoryGb) * 1024));

    const diskSizeGb = document.getElementById('vm-disk').value;
    if (diskSizeGb) formData.append('diskSizeGb', diskSizeGb);

    formData.append('groupId', document.getElementById('vm-group').value);

    if (!formData.get('groupId')) {
	        showToastMessage(IS_ENGLISH ? 'Please select a group.' : '그룹을 선택해 주세요.', 'warning');
	        return;
	    }

    const osType = document.getElementById('vm-ostype').value;
    formData.append('osType', osType);

    if (osType === 'linux') {
        const privateKeyFile = document.getElementById('vm-private-key').files[0];
        const publicKeyFile = document.getElementById('vm-public-key').files[0];
        if (!privateKeyFile) {
            showToastMessage(IS_ENGLISH ? 'Private key file is required.' : '개인키 파일은 필수입니다.', 'warning');
            return;
        }
        formData.append('privateKey', privateKeyFile);
        if (publicKeyFile) formData.append('publicKey', publicKeyFile);
    } else {
        const winUsername = document.getElementById('vm-win-username').value.trim();
        const winPassword = document.getElementById('vm-win-password').value;
        if (!winUsername || !winPassword) {
            showToastMessage(IS_ENGLISH ? 'Windows username and password are required.' : 'Windows 사용자명과 비밀번호를 입력하세요.', 'warning');
            return;
        }
        formData.append('winUsername', winUsername);
        formData.append('winPassword', winPassword);
    }

    try {
        window.__manualVmSubmitting = true;
        const submitBtn = document.querySelector('#addVmForm button[type="submit"]');
        const submitOriginal = submitBtn ? submitBtn.textContent : '';
        if (submitBtn) {
            submitBtn.disabled = true;
            submitBtn.textContent = IS_ENGLISH ? 'Adding...' : '추가 중...';
        }

        const response = await fetch('/api/admin/vms/manual', {
            method: 'POST',
            body: formData
        });

	        const result = await response.json();
	        if (!response.ok) {
	            throw new Error(result.error || (IS_ENGLISH ? 'Failed to add VM manually.' : 'VM 수동 추가에 실패했습니다.'));
	        }

        const successMsg = osType === 'windows'
            ? (IS_ENGLISH ? 'Windows VM registered successfully.' : 'Windows VM이 성공적으로 등록되었습니다.')
            : (IS_ENGLISH ? 'VM registered successfully with SSH key.' : 'SSH 키와 함께 VM이 성공적으로 등록되었습니다.');
	        showToastMessage(successMsg, 'success');
	        // 성공 메시지를 확인할 수 있도록 모달 닫힘/리로드를 너무 빠르게 하지 않음
	        setTimeout(function() { closeAllModals(); }, 900);
	        setTimeout(function() { location.reload(); }, 1800);
	    } catch (e) {
	        showToastMessage((IS_ENGLISH ? 'VM registration failed: ' : 'VM 등록 실패: ') + e.message, 'error', 3200);
	    } finally {
	        window.__manualVmSubmitting = false;
            const submitBtn = document.querySelector('#addVmForm button[type="submit"]');
            if (submitBtn) {
                submitBtn.disabled = false;
                submitBtn.textContent = IS_ENGLISH ? 'Add VM' : 'VM 수동 추가';
            }
	    }
	});

    async function probeManualVm() {
        const vmidRaw = document.getElementById('vm-vmid').value;
        const vmid = parseInt(vmidRaw, 10);
        const node = (document.getElementById('vm-node').value || '').trim();
        if (!Number.isInteger(vmid) || vmid < 100) {
            showToastMessage(IS_ENGLISH ? 'Please enter a valid VMID (100 or higher).' : '올바른 VMID(100 이상)를 입력해 주세요.', 'warning');
            return;
        }

        const btn = document.getElementById('vm-probe-btn');
        const original = btn ? btn.textContent : '';
        if (btn) {
            btn.disabled = true;
            btn.textContent = IS_ENGLISH ? 'Checking...' : '확인 중...';
        }

        try {
            const qs = new URLSearchParams({ vmid: String(vmid) });
            if (node) qs.set('node', node);
            const response = await fetch('/api/admin/vms/manual/probe?' + qs.toString());
            const result = await response.json();

            if (!response.ok || !result?.ok || !result?.vm) {
                throw new Error(result?.error || (IS_ENGLISH ? 'VM not found on Proxmox.' : 'Proxmox에서 VM을 찾을 수 없습니다.'));
            }

            const vm = result.vm;
            if (vm.hostname) {
                const normalized = normalizeVmHostname(vm.hostname, vmid);
                document.getElementById('vm-hostname').value = normalized;
            }
            if (vm.ip) document.getElementById('vm-ip').value = vm.ip;
            if (vm.node) document.getElementById('vm-node').value = vm.node;
            if (vm.cpuCores != null) document.getElementById('vm-cpu').value = String(vm.cpuCores);
            if (vm.memoryMb != null) document.getElementById('vm-memory').value = String(Math.max(1, Math.round(Number(vm.memoryMb) / 1024)));
            if (vm.diskSizeGb != null) document.getElementById('vm-disk').value = String(vm.diskSizeGb);

            showToastMessage(IS_ENGLISH ? 'VM information loaded.' : 'VM 정보를 불러왔습니다.', 'success');
        } catch (e) {
            showToastMessage((IS_ENGLISH ? 'Lookup failed: ' : '조회 실패: ') + (e.message || e), 'error', 3200);
        } finally {
            if (btn) {
                btn.disabled = false;
                btn.textContent = original || (IS_ENGLISH ? 'Check' : '확인');
            }
        }
    }

	function selectOsType(type) {
	    document.getElementById('vm-ostype').value = type;
	    document.getElementById('ssh-key-section').style.display = type === 'linux' ? '' : 'none';
	    document.getElementById('win-cred-section').style.display = type === 'windows' ? '' : 'none';
	    document.getElementById('vm-private-key').required = (type === 'linux');
	    document.getElementById('os-linux-btn').className = 'btn ' + (type === 'linux' ? 'btn-primary' : 'btn-secondary');
	    document.getElementById('os-windows-btn').className = 'btn ' + (type === 'windows' ? 'btn-primary' : 'btn-secondary');
	}

	(function bindManualVmFilePickers() {
	    const noneText = IS_ENGLISH ? 'No file selected' : '선택된 파일 없음';
	    function bind(inputId, labelId) {
	        const inp = document.getElementById(inputId);
	        const lab = document.getElementById(labelId);
	        if (!inp || !lab) return;
	        const update = () => {
	            lab.textContent = (inp.files && inp.files.length > 0) ? inp.files[0].name : noneText;
	        };
	        update();
	        inp.addEventListener('change', update);
	    }
	    bind('vm-private-key', 'vm-private-key-name');
	    bind('vm-public-key', 'vm-public-key-name');
	})();
	</script>

<!-- VM 요청 모달 -->
<div id="toast" class="toast"></div>
<script>
function showToastMessage(message, type = 'success', duration = 2200, iconName = null) {
    var t = document.getElementById('toast');
    if (!t) return;
    const safeMsg = String(message || '');
    if (iconName) {
        t.innerHTML = '<i class="ti ti-' + String(iconName) + ' toast-icon" aria-hidden="true"></i><span>' + safeMsg + '</span>';
        t.classList.add('has-icon');
    } else {
        t.textContent = safeMsg;
        t.classList.remove('has-icon');
    }
    t.classList.remove('show', 'is-error', 'is-warning');
    if (type === 'error') t.classList.add('is-error');
    else if (type === 'warning') t.classList.add('is-warning');
    void t.offsetWidth;
    t.classList.add('show');
    clearTimeout(window.__dashToastTimer);
    window.__dashToastTimer = setTimeout(function() { t.classList.remove('show'); }, duration);
}

(function() {
    var params = new URLSearchParams(window.location.search);
	    if (params.get('pwChanged') === 'true') {
	        showToastMessage((IS_ENGLISH ? 'Password changed.' : '비밀번호가 변경되었습니다.'), 'success', 3000);
	        history.replaceState(null, '', '/');
	    }
})();
</script>

<script>
// ─── VM 요청 기능 ───
let selectedInstanceType = null;

function syncReqGroupUi() {
    const select = document.getElementById('req-group');
    const label = document.getElementById('reqGroupLabel');
    const menu = document.getElementById('reqGroupMenu');
    if (!select || !label || !menu) return;
    const selected = select.options[select.selectedIndex];
    label.textContent = selected ? selected.textContent : '';
    menu.querySelectorAll('.req-group-dd-item').forEach(item => {
        item.classList.toggle('active', item.dataset.value === select.value);
    });
}

function positionReqGroupMenu(menu, btn) {
    if (!menu || !btn) return;
    const r = btn.getBoundingClientRect();
    const width = Math.max(220, Math.min(window.innerWidth - 24, r.width));
    menu.style.width = width + 'px';
    menu.style.minWidth = width + 'px';
    menu.style.maxWidth = width + 'px';
    menu.style.left = Math.max(12, Math.min(window.innerWidth - width - 12, r.left)) + 'px';
    menu.style.top = Math.min(window.innerHeight - 12, r.bottom + 6) + 'px';
}

function toggleReqGroupMenu(e) {
    e?.stopPropagation?.();
    const dd = document.getElementById('reqGroupDd');
    const menu = document.getElementById('reqGroupMenu');
    const btn = document.getElementById('reqGroupBtn');
    if (!dd) return;
    const willOpen = !dd.classList.contains('open');
    dd.classList.toggle('open', willOpen);
    if (willOpen) positionReqGroupMenu(menu, btn);
}

function setReqGroupFilter(value, el) {
    if (el) el.stopPropagation?.();
    const select = document.getElementById('req-group');
    const dd = document.getElementById('reqGroupDd');
    if (!select) return;
    select.value = value;
    if (dd) dd.classList.remove('open');
    syncReqGroupUi();
    loadGroupQuota(value);
}

// Modal functions removed - form is now inline

function selectInstanceType(card) {
    document.querySelectorAll('.instance-card').forEach(c => c.classList.remove('selected'));
    card.classList.add('selected');
    selectedInstanceType = card.dataset.type;

    // Show VM count section within instance type section
    document.getElementById('vmCountSection').style.display = 'block';

    // Show all form sections when instance type is selected
    document.getElementById('vmConfigSection').style.display = 'block';
    document.getElementById('extraDiskSection').style.display = 'block';
    document.getElementById('purposeSection').style.display = 'block';
    document.getElementById('reqSubmitBtn').style.display = 'block';

    const custom = document.getElementById('customFields');
    if (selectedInstanceType === 'CUSTOM') {
        custom.classList.add('show');
    } else {
        custom.classList.remove('show');
        document.getElementById('req-cpu').value = card.dataset.cpu;
        document.getElementById('req-mem-gb').value = Math.round(parseInt(card.dataset.mem) / 1024);
        document.getElementById('req-disk').value = card.dataset.disk;
    }

    // Smooth scroll to VM config section
    document.getElementById('vmConfigSection').scrollIntoView({ behavior: 'smooth', block: 'nearest' });
}

function selectOs(card) {
    document.querySelectorAll('.os-card').forEach(c => c.classList.remove('selected'));
    card.classList.add('selected');
}

async function loadGroupQuota(groupId) {
    const info = document.getElementById('req-quota-info');
    if (!groupId) { info.innerHTML = ''; return; }

    try {
        const res = await fetch('/api/vm-requests/quota/' + groupId);
        const data = await res.json();
        if (!data.ok) { info.innerHTML = ''; return; }

        if (data.quota.maxCpuCores === -1 && data.quota.maxMemoryMb === -1 && data.quota.maxDiskGb === -1 && data.quota.maxVmCount === -1) {
            info.innerHTML = '<span class="quota-unlimited-ok">' +
                (IS_ENGLISH ? 'No quota configured (unlimited)' : '할당량 제한 없음 (무제한)') +
                '</span>';
        } else {
            const parts = [];
            if (data.quota.maxCpuCores !== -1) parts.push('CPU: ' + (data.used.cpuCores + data.pending.cpuCores) + '/' + data.quota.maxCpuCores);
            if (data.quota.maxMemoryMb !== -1) parts.push('Mem: ' + Math.round((data.used.memoryMb + data.pending.memoryMb)/1024) + '/' + Math.round(data.quota.maxMemoryMb/1024) + 'GB');
            if (data.quota.maxDiskGb !== -1) parts.push('Disk: ' + (data.used.diskGb + data.pending.diskGb) + '/' + data.quota.maxDiskGb + 'GB');
            if (data.quota.maxVmCount !== -1) parts.push('VMs: ' + (data.used.vmCount + data.pending.vmCount) + '/' + data.quota.maxVmCount);
            info.innerHTML = (IS_ENGLISH ? 'Current usage: ' : '현재 사용량: ') + parts.join(' | ');
        }
    } catch (e) {
        info.innerHTML = '';
    }
}

async function submitVmRequest() {
    const groupId = document.getElementById('req-group').value;
    const vmCount = parseInt(document.getElementById('req-count').value) || 0;
    const errEl = document.getElementById('reqError');

    const selectedOsCard = document.querySelector('.os-card.selected');
    const preferredOs = selectedOsCard ? selectedOsCard.dataset.os : null;

    if (!groupId || !selectedInstanceType || vmCount < 1 || !preferredOs) {
        errEl.textContent = IS_ENGLISH ? 'Please select Group, Instance Type, OS, and VM Count.' : 'Group, Instance Type, OS, VM 수량을 모두 선택하세요.';
        errEl.style.display = 'block';
        return;
    }

    let cpuCores, memoryMb, diskSizeGb;
    if (selectedInstanceType === 'CUSTOM') {
        cpuCores = parseInt(document.getElementById('req-cpu').value) || 0;
        memoryMb = (parseInt(document.getElementById('req-mem-gb').value) || 0) * 1024;
        diskSizeGb = parseInt(document.getElementById('req-disk').value) || 0;
    } else {
        const card = document.querySelector('.instance-card.selected');
        cpuCores = parseInt(card.dataset.cpu);
        memoryMb = parseInt(card.dataset.mem);
        diskSizeGb = parseInt(card.dataset.disk);
    }

    if (cpuCores < 1 || memoryMb < 1024 || diskSizeGb < 10) {
        errEl.textContent = IS_ENGLISH ? 'Please check vCPU/Memory/Disk values.' : 'vCPU, Memory, Disk 값을 확인하세요.';
        errEl.style.display = 'block';
        return;
    }

    const btn = document.getElementById('reqSubmitBtn');
    btn.disabled = true;
    btn.textContent = IS_ENGLISH ? 'Submitting...' : '제출 중...';
    errEl.style.display = 'none';

    try {
	        const body = {
	            groupId,
	            instanceType: selectedInstanceType,
	            vmCount,
	            purpose: document.getElementById('req-purpose').value.trim() || null,
	            cpuCores,
	            memoryMb,
	            diskSizeGb,
	            extraDiskGb: parseInt(document.getElementById('req-extra-gb').value) || 0,
	            extraDiskCount: (parseInt(document.getElementById('req-extra-gb').value) || 0) > 0 ? 1 : 0,
	            preferredOs,
	        };

        const res = await fetch('/api/vm-requests', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(body)
        });

        const data = await res.json();
        if (!res.ok) throw new Error(data.error || (IS_ENGLISH ? 'Failed to submit request' : '요청 제출에 실패했습니다.'));

        if (data.quotaExceeded) {
            showToastMessage(
                IS_ENGLISH
                    ? ('Request submitted. Quota exceeded: ' + data.exceededResources.join(', ') + '. Admin quota approval is required.')
                    : ('요청이 제출되었습니다. 할당량 초과 항목: ' + data.exceededResources.join(', ') + '. 관리자 쿼터 승인이 필요합니다.'),
                'warning',
                3600
            );
        } else {
            showToastMessage(
                IS_ENGLISH ? 'VM create request submitted. It will be created after admin approval.' : 'VM 생성 요청이 제출되었습니다. 관리자 승인 후 배포됩니다.',
                'success',
                2600
            );
        }

        setTimeout(function() { location.reload(); }, 600);
    } catch (e) {
        errEl.textContent = e.message;
        errEl.style.display = 'block';
    } finally {
        btn.disabled = false;
        btn.textContent = IS_ENGLISH ? 'Submit VM Create Request' : '요청 제출';
    }
}

async function cancelVmRequest(requestId) {
    if (!await themedConfirmDash(
        IS_ENGLISH ? 'Cancel this VM create request?' : '이 VM 요청을 취소하시겠습니까?',
        IS_ENGLISH ? 'Cancel Request' : '요청 취소'
    )) return;

    try {
        const res = await fetch('/api/vm-requests/' + requestId + '/cancel', { method: 'DELETE' });
        if (!res.ok) {
            const data = await res.json();
            throw new Error(data.error || (IS_ENGLISH ? 'Failed to cancel' : '취소에 실패했습니다.'));
        }
        location.reload();
    } catch (e) {
        showToastMessage((IS_ENGLISH ? 'Cancel failed: ' : '취소 실패: ') + e.message, 'error', 3200);
    }
}

// ESC key handler removed - no longer using modal
</script>

</body>
