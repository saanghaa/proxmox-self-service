// VM 전원 제어 (시작/중지/재부팅)
async function vmPower(vmId, action) {
    const actionLabels = IS_ENGLISH
        ? { start: 'start', stop: 'stop', reboot: 'reboot' }
        : { start: '시작', stop: '중지', reboot: '재부팅' };
    const label = actionLabels[action] || action;

    if (!await themedConfirmDash(
        IS_ENGLISH ? `Are you sure you want to ${label} this VM?` : `VM을 ${label}하시겠습니까?`,
        IS_ENGLISH ? 'VM Power Action' : 'VM 전원 작업'
    )) return;

    try {
        const response = await fetch(`/api/vms/${vmId}/${action}`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' }
        });

        const data = await response.json();
        if (!response.ok) {
            throw new Error(data.error || `${label} 실패`);
        }

        // 상태 업데이트 반영
        const vm = allVmsData.find(v => v.id === vmId);
        if (vm && data.status) {
            vm.status = data.status;
        }
        renderVMTable(allVmsData);

        const t = document.getElementById('toast');
        t.textContent = IS_ENGLISH ? `VM ${label} completed` : `VM ${label} 완료`;
        t.classList.add('show');
        setTimeout(() => t.classList.remove('show'), 3000);
    } catch (error) {
        console.error(`VM ${action} error:`, error);
        showToastMessage((IS_ENGLISH ? `VM ${label} failed: ` : `VM ${label} 실패: `) + error.message, 'error', 3200);
    }
}

// VM 삭제 (Admin 전용)
async function confirmDeleteVm(vmId, vmName) {
    var m = document.getElementById('deleteConfirmModal');
    if (!m) {
        if (await themedConfirmDash(
            (IS_ENGLISH ? 'Delete VM: ' : 'VM 삭제: ') + vmName + '?',
            IS_ENGLISH ? 'Delete VM' : 'VM 삭제'
        )) deleteVm(vmId);
        return;
    }
    window._dcmVmId = vmId;
    window._dcmVmName = vmName || '';
    document.getElementById('dcm-loading').style.display = 'none';
    document.getElementById('dcm-body').style.display = 'none';
    document.getElementById('dcm-error').textContent = '';
    document.getElementById('dcm-error').style.display = 'none';
    document.getElementById('dcm-error').style.color = '#dc2626';
    document.getElementById('dcm-warn').style.display = 'none';
    document.getElementById('dcm-actions').style.display = 'flex';
    document.getElementById('dcm-cancel-link').style.display = 'none';
    var btn = document.getElementById('dcm-confirm-btn');
    if (btn) { btn.disabled = false; btn.textContent = IS_ENGLISH ? 'Confirm Delete' : '삭제 확인'; }
    m.classList.add('active');
}

function closeDcm() {
    var m = document.getElementById('deleteConfirmModal');
    if (m) m.classList.remove('active');
    window._dcmVmId = null;
    window._dcmVmName = null;
}

async function executeDcmDelete() {
    if (!window._dcmVmId) return;
    var btn = document.getElementById('dcm-confirm-btn');
    btn.disabled = true;
    btn.textContent = IS_ENGLISH ? 'Deleting...' : '삭제 중...';
    document.getElementById('dcm-error').textContent = '';
    var dcmModalBox = document.querySelector('#deleteConfirmModal .modal-delete-vm');
    try {
        var r = await fetch('/api/admin/vms/' + window._dcmVmId, { method: 'DELETE', headers: { 'Content-Type': 'application/json' } });
        if (!r.ok) { var e = await r.json(); throw new Error(e.error || 'failed'); }
        var deletedName = window._dcmVmName || '-';
        closeDcm();
        showToastMessage(
            IS_ENGLISH ? ('VM deleted: ' + deletedName) : ('VM 삭제 완료: ' + deletedName),
            'success',
            3200,
            'trash'
        );
        setTimeout(function() { location.reload(); }, 1100);
    } catch (err) {
        document.getElementById('dcm-error').textContent = (IS_ENGLISH ? 'Delete failed: ' : '삭제 실패: ') + err.message;
        document.getElementById('dcm-error').style.color = '#dc2626';
        document.getElementById('dcm-error').style.display = 'block';
        btn.disabled = false;
        btn.textContent = IS_ENGLISH ? 'Confirm Delete' : '삭제 확인';
    }
}

async function deleteVm(vmId, vmName) {
    try {
        var r = await fetch('/api/admin/vms/' + vmId, { method: 'DELETE', headers: { 'Content-Type': 'application/json' } });
        if (!r.ok) { var e = await r.json(); throw new Error(e.error || 'failed'); }
        showToastMessage(IS_ENGLISH ? 'VM deleted.' : 'VM이 삭제되었습니다.', 'success', 3200);
        setTimeout(function() { location.reload(); }, 500);
    } catch (error) {
        showToastMessage((IS_ENGLISH ? 'Delete failed: ' : '삭제 실패: ') + error.message, 'error', 3200);
    }
}

