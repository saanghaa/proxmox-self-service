// VM 검색 기능 (VMID, 호스트네임, IP 주소, Job ID, Group)
function filterVMs() {
    const query = document.getElementById('vmSearch').value.toLowerCase().trim();
    const rows = document.querySelectorAll('.vm-row');

    rows.forEach(row => {
        const hostname = row.getAttribute('data-hostname') || '';
        const vmid = row.getAttribute('data-vmid') || '';
        const ip = row.getAttribute('data-ip') || '';
        const jobid = row.getAttribute('data-jobid') || '';
        const group = row.getAttribute('data-group') || '';

        if (query === '' ||
            hostname.includes(query) ||
            vmid.toLowerCase().includes(query) ||
            ip.includes(query) ||
            jobid.includes(query) ||
            group.includes(query)) {
            row.style.display = '';
        } else {
            row.style.display = 'none';
        }
    });
}

// VM 행 클릭 시 SSH 키 섹션 토글
function toggleKeySection(row, jobId, index) {
    const keyRow = document.getElementById('key-row-' + index);
    const toggleText = document.getElementById('toggle-text-' + index);

    if (keyRow) {
        const isHidden = keyRow.classList.contains('key-row-hidden');

        if (isHidden) {
            keyRow.classList.remove('key-row-hidden');
            keyRow.style.display = '';
            // 다음 프레임에서 open 클래스 추가 (CSS 트랜지션 적용)
            requestAnimationFrame(function() {
                keyRow.classList.add('key-row-open');
            });
            if (toggleText) toggleText.innerHTML = '<i class="ti ti-clipboard-text" aria-hidden="true"></i> ' + plainText(uuidLabels?.sshKey?.['ssh-007'], 'Click to hide');
        } else {
            keyRow.classList.remove('key-row-open');
            // 트랜지션 완료 후 숨기기
            keyRow.addEventListener('transitionend', function handler() {
                if (!keyRow.classList.contains('key-row-open')) {
                    keyRow.classList.add('key-row-hidden');
                    keyRow.style.display = 'none';
                }
                keyRow.removeEventListener('transitionend', handler);
            }, { once: true });
            if (toggleText) toggleText.innerHTML = '<i class="ti ti-clipboard-text" aria-hidden="true"></i> ' + plainText(uuidLabels?.sshKey?.['ssh-006'], 'Click to view');
        }
    }
}

