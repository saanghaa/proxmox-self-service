        .modern-input:focus {
            border-color: var(--vr-accent);
            box-shadow: 0 0 0 3px rgba(var(--vr-accent-rgb), 0.12);
        }
        .modern-input:disabled,
        .modern-input[readonly] {
            background: #f1f5f9;
            cursor: not-allowed;
            color: #64748b;
        }
        textarea.modern-input {
            min-height: 80px;
            resize: vertical;
        }
        .modern-label {
            display: block;
            font-size: 0.8rem;
            font-weight: 600;
            color: #475569;
            margin-bottom: 0.5rem;
        }
        .modern-label .required {
            color: #ef4444;
            margin-left: 0.2rem;
        }

        /* Info Box */
        .info-box {
            display: flex;
            align-items: flex-start;
            gap: 0.6rem;
            padding: 0.7rem 0.9rem;
            background: var(--vr-accent-soft);
