                            <td class="td-082">${memDisplay}</td>
                            <td class="td-082">${diskDisplay}</td>
                            <td class="text-center">${powerButtons}</td>
                            <td class="mono mono-sm">${vm.jobIdShort}</td>
                            <td>${groupColumn}</td>
                            <td class="td-085">${vm.created}</td>
                            <td class="text-center">${keyColumn}</td>
                            ${actionsColumn}
                        </tr>
                        ${keyRow}
                    `;
                }).join('');
            }

            // Sort VMs
            function sortVMs(column) {
                // Toggle sort direction if same column
                if (sortColumn === column) {
                    sortDirection = sortDirection === 'asc' ? 'desc' : 'asc';
                } else {
                    sortColumn = column;
                    sortDirection = 'asc';
                }

                // Update header classes
                document.querySelectorAll('.vm-table th.sortable').forEach(th => {
                    th.classList.remove('asc', 'desc');
                });
                const header = document.querySelector(`.vm-table th[data-column="${column}"]`);
                if (header) {
                    header.classList.add(sortDirection);
                }

                // Sort data
                const sorted = [...allVmsData].sort((a, b) => {
                    let aVal = a[column];
                    let bVal = b[column];

                    // Handle null/undefined
                    if (!aVal && !bVal) return 0;
                    if (!aVal) return 1;
                    if (!bVal) return -1;

                    // Numeric sort for vmid, cpu, memory, disk
                    if (['vmid', 'cpu', 'memory', 'disk'].includes(column)) {
                        const fieldMap = { vmid: 'vmid', cpu: 'cpuCores', memory: 'memoryMb', disk: 'diskSizeGb' };
                        aVal = parseInt(a[fieldMap[column]] || aVal) || 0;
                        bVal = parseInt(b[fieldMap[column]] || bVal) || 0;
                    } else if (column === 'status') {
                        const statusOrder = { running: 1, paused: 2, stopped: 3, unknown: 4 };
                        aVal = statusOrder[a.status] || 4;
                        bVal = statusOrder[b.status] || 4;
                    } else {
                        // String sort (case insensitive)
                        aVal = String(aVal).toLowerCase();
                        bVal = String(bVal).toLowerCase();
                    }

                    if (aVal < bVal) return sortDirection === 'asc' ? -1 : 1;
                    if (aVal > bVal) return sortDirection === 'asc' ? 1 : -1;
                    return 0;
                });

                // Re-render
                renderVMTable(sorted);
            }

            // Initial render
            document.addEventListener('DOMContentLoaded', function() {
                renderVMTable();
            });
            </script>

