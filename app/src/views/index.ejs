<script>
// Using `var` avoids TDZ crashes if any initializer references it before declaration.
var IS_ENGLISH = <%= isEnglish ? 'true' : 'false' %>;
let currentFingerprint = null;
let currentRotateVmId = null;
let currentRotateChallengeId = null;
let currentRotateHostname = null;
let currentChallengeId = null;
let currentHostname = null;
let currentVmId = null;
let _dashConfirmResolver = null;

function closeDashConfirm(result) {
    const m = document.getElementById('dashConfirmModal');
    if (m) m.classList.remove('active');
    if (_dashConfirmResolver) {
        const resolve = _dashConfirmResolver;
        _dashConfirmResolver = null;
        resolve(!!result);
    }
}

function themedConfirmDash(message, title) {
    const m = document.getElementById('dashConfirmModal');
    const titleEl = document.getElementById('dashConfirmTitle');
    const msgEl = document.getElementById('dashConfirmMessage');
    const okBtn = document.getElementById('dashConfirmOkBtn');
    const cancelBtn = document.getElementById('dashConfirmCancelBtn');
    if (!m || !titleEl || !msgEl || !okBtn || !cancelBtn) return Promise.resolve(confirm(message));

    titleEl.textContent = title || (IS_ENGLISH ? 'Confirm' : '확인');
    msgEl.textContent = message || '';
    okBtn.textContent = IS_ENGLISH ? 'Confirm' : '확인';
    cancelBtn.textContent = IS_ENGLISH ? 'Cancel' : '취소';
    m.classList.add('active');

    return new Promise((resolve) => {
        _dashConfirmResolver = resolve;
        okBtn.onclick = () => closeDashConfirm(true);
        cancelBtn.onclick = () => closeDashConfirm(false);
    });
}

document.addEventListener('click', function(e) {
