    }
}

function copyTextWithFallback(text) {
    const value = String(text || '');
    if (!value) return Promise.resolve(false);

    function fallbackCopy() {
        try {
            const ta = document.createElement('textarea');
            ta.value = value;
            ta.setAttribute('readonly', '');
            ta.style.position = 'fixed';
            ta.style.top = '-9999px';
            ta.style.left = '-9999px';
            document.body.appendChild(ta);
            ta.select();
            ta.setSelectionRange(0, ta.value.length);
            const ok = document.execCommand('copy');
            document.body.removeChild(ta);
            return Promise.resolve(!!ok);
        } catch (_) {
            return Promise.resolve(false);
        }
    }

    if (navigator.clipboard && window.isSecureContext) {
        return navigator.clipboard.writeText(value).then(() => true).catch(() => fallbackCopy());
    }
    return fallbackCopy();
}

function copyWinNewPw() {
    const pw = document.getElementById('winNewPwValue').textContent;
    if (!pw) return;
    copyTextWithFallback(pw).then((ok) => {
        const btn = document.getElementById('winNewPwCopyBtn');
        if (!btn) return;
        btn.textContent = ok ? (IS_ENGLISH ? 'Copied!' : '복사됨!') : (IS_ENGLISH ? 'Copy failed' : '복사 실패');
        setTimeout(() => { btn.textContent = IS_ENGLISH ? 'Copy Password' : '비밀번호 복사'; }, 1500);
    });
}

