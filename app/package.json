{
  "name": "proxmox-horizon",
  "version": "2.0.0",
  "description": "Proxmox Horizon - Self-Service Portal",
  "author": "Lee Sangha <saanghaa@gmail.com> (DevOps Engineer, Site Reliability Engineer, Cloud Solutions Architect)",
  "main": "dist/server.js",
  "scripts": {
    "start": "node dist/server.js",
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "tsc -p tsconfig.json && npm run copy-assets",
    "copy-assets": "cp -r src/views dist/ && cp -r defaults dist/",
    "seed": "ts-node prisma/seed.ts",
    "db-delete-vm": "tsx src/scripts/db-delete-vm.ts",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@otplib/v12-adapter": "^13.2.1",
    "@prisma/client": "^6.19.2",
    "@types/multer": "^2.0.0",
    "bcryptjs": "^2.4.3",
    "connect-redis": "^7.1.1",
    "cookie-parser": "^1.4.6",
    "dotenv": "^16.4.5",
    "ejs": "^3.1.9",
    "express": "^4.18.2",
    "express-rate-limit": "^7.4.1",
    "express-session": "^1.18.0",
    "@tabler/icons-webfont": "^3.35.0",
    "flatpickr": "^4.6.13",
    "helmet": "^7.1.0",
    "ioredis": "^5.4.1",
    "multer": "^2.0.2",
    "prisma": "^6.19.2",
    "qrcode": "^1.5.4",
    "sshpk": "^1.18.0",
    "uuid": "^9.0.1",
    "chart.js": "^4.4.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^4.17.25",
    "@types/express-session": "^1.18.2",
    "@types/node": "^20.19.32",
    "@types/qrcode": "^1.5.6",
    "@types/sshpk": "^1.17.0",
    "@types/uuid": "^9.0.8",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^5.3.3"
  }
}
