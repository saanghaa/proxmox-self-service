# [Database] PostgreSQL 설정
# 참고: install.sh 최초 실행 시 .env 파일이 자동 생성됩니다.
# 수동으로 설정하려면 이 파일을 .env로 복사한 뒤 값을 변경하세요.
# 주의: POSTGRES_PASSWORD에 '@' 같은 문자가 포함되면 DATABASE_URL에서 반드시 URL-encode 해야 합니다.
POSTGRES_PASSWORD=your_strong_password_here
DATABASE_URL=postgresql://proxmox:your_strong_password_here@postgres:5432/proxmox

# [Cache] Redis 설정
REDIS_URL=redis://redis:6379

# [Security] 세션 및 암호화 시크릿
# SESSION_SECRET: 세션 쿠키 서명용 (유출 시 세션 하이재킹 위험)
# 생성 방법: openssl rand -hex 32
SESSION_SECRET=your_session_secret_here_generate_with_openssl_rand_hex_32

# KEY_ENCRYPTION_SECRET: DB에 저장되는 Private Key를 암호화하는 마스터 키
# 중요: 이 키를 잃어버리면 DB에 있는 모든 키를 복호화할 수 없습니다! 반드시 백업하세요.
# 권장: openssl rand -hex 32 명령어로 생성한 값을 사용하세요.
KEY_ENCRYPTION_SECRET=your_key_encryption_secret_here_generate_with_openssl_rand_hex_32

# [App Settings] 서비스 주소 및 포트
PORT=3000
# BASE_URL is optional. If empty, the app works behind reverse proxies for any domain.
# Example: BASE_URL=https://portal.example.com
BASE_URL=
NODE_ENV=production
HTTP_PORT=80
HTTPS_PORT=443
